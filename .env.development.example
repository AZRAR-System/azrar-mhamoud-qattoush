# Copy to .env.development (gitignored) for local Vite dev.
# Never commit real passwords.

# Optional: seed SuperAdmin when db_users is empty (dev/desktop only)
# VITE_SEED_DEFAULT_ADMIN=true
# VITE_SEED_DEFAULT_ADMIN_USERNAME=admin
# VITE_SEED_DEFAULT_ADMIN_PASSWORD=choose_a_strong_password

# Prefill login fields in dev only
# VITE_LOGIN_PREFILL=true
