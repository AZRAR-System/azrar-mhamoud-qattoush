{
  "name": "azrar-real-estate-desktop",
  "description": "AZRAR Real Estate Management System (Desktop)",
  "author": "AZRAR",
  "private": true,
  "version": "3.2.51",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run desktop:dev",
    "dev:web": "vite",
    "build:app": "npm run desktop:build",
    "electron:rebuild": "npm run electron:build",
    "run:built": "npm run desktop:run",
    "dist": "npm run desktop:dist",
    "dist:quick": "npm run desktop:dist:skipWU",
    "dist:signed": "npm run desktop:dist:signed",
    "dist:signed:quick": "npm run desktop:dist:signed:skipWU",
    "pack": "npm run desktop:dist",
    "pack:quick": "npm run desktop:dist:skipWU",
    "check": "npm run typecheck",
    "ci": "npm run verify",
    "ci:full": "npm run verify:full",
    "license:pack": "npm run license-admin:dist",
    "licensegen:pack": "npm run licensegen:dist",
    "integrity:generate": "node scripts/generate-integrity-manifest.mjs",
    "sync:favicon": "node scripts/sync-web-favicon.mjs",
    "server:marquee": "node server/marquee-server.js",
    "server:license": "node server/license-server.mjs",
    "dev": "npm run sync:favicon && vite",
    "desktop": "npm run desktop:dev",
    "native:ensure:electron": "node scripts/ensure-better-sqlite3-electron.mjs",
    "build": "npm run sync:favicon && vite build",
    "typecheck": "tsc --noEmit",
    "routes:check": "node scripts/routes-check.mjs",
    "verify": "npm run typecheck && npm run routes:check && npm run desktop:build",
    "verify:desktop": "npm run desktop:e2e",
    "verify:full": "npm run verify && npm run verify:desktop",
    "postinstall": "electron-builder install-app-deps",
    "preview": "npm run sync:favicon && vite preview",
    "electron:dev": "npm run desktop:dev",
    "electron:preload": "npx --no-install esbuild electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=electron/preload.cjs",
    "electron:main": "npx --no-install esbuild electron/main.ts --bundle --platform=node --format=esm --packages=external --external:electron --external:better-sqlite3 --external:electron-updater --external:mssql --outfile=electron/main.js",
    "electron:ipc": "npx --no-install esbuild electron/ipc/index.ts --bundle --platform=node --format=esm --packages=external --external:electron --external:better-sqlite3 --external:electron-updater --external:mssql --outfile=electron/ipc.js",
    "electron:db": "npx --no-install esbuild electron/db.ts --bundle --platform=node --format=esm --external:electron --external:better-sqlite3 --external:better-sqlite3-multiple-ciphers --outfile=electron/db.js",
    "electron:obfuscate": "node scripts/obfuscate-electron-bundles.mjs",
    "electron:build:dev": "npm run electron:preload && npm run electron:main && npm run electron:ipc && npm run electron:db && npm run electron:obfuscate",
    "electron:build": "npm run electron:build:dev && npm run integrity:generate",
    "electron:licensegen:preload": "npx --no-install esbuild electron/licensegen-preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=electron/licensegen-preload.cjs",
    "electron:licensegen:main": "npx --no-install esbuild electron/licensegen-main.ts --bundle --platform=node --format=esm --external:electron --external:electron-log --outfile=electron/licensegen-main.js",
    "license:keygen": "node scripts/license-keygen.mjs",
    "license:sign": "node scripts/license-sign.mjs",
    "license:verify:file": "node scripts/license-verify.mjs --license",
    "license:admin": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/license-admin.ps1",
    "license-admin:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File start-license-admin.ps1",
    "license-admin:dev:withLicense": "powershell -NoProfile -ExecutionPolicy Bypass -File start-license-admin-with-license-server.ps1",
    "license-admin:dist": "npm run desktop:build && npx --no-install electron-builder --config electron-builder.licenseadmin.config.cjs --win --x64",
    "licensegen:dev": "npm run electron:licensegen:preload && npm run electron:licensegen:main && node node_modules/electron/cli.js electron/licensegen-main.js",
    "licensegen:dev:verbose": "node scripts/run-licensegen-dev.mjs",
    "licensegen:dist": "npm run electron:licensegen:preload && npm run electron:licensegen:main && npx --no-install electron-builder --config electron-builder.licensegen.config.cjs --win --x64",
    "desktop:dev": "npm run sync:favicon && npm run native:ensure:electron && npm run electron:build:dev && concurrently -k --success first \"wait-on http-get://127.0.0.1:3000 && node node_modules/electron/cli.js electron/main.js\" \"vite --mode desktop --port 3000 --host 127.0.0.1\"",
    "desktop:dev:withLicense": "powershell -NoProfile -ExecutionPolicy Bypass -File start-desktop-with-license-server.ps1",
    "desktop:dev:tests": "node scripts/desktop-dev-tests.mjs --autorun",
    "desktop:e2e": "node scripts/desktop-dev-tests.mjs --autorun",
    "desktop:build": "npm run sync:favicon && vite build --mode desktop && npm run electron:build",
    "desktop:run": "npm run desktop:build && npm run native:ensure:electron && node node_modules/electron/cli.js electron/main.js",
    "desktop:run:withLicense": "powershell -NoProfile -ExecutionPolicy Bypass -File start-desktop-run-with-license-server.ps1",
    "desktop:dist": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1",
    "desktop:dist:skipWU": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -SkipWinUnpacked",
    "desktop:dist:strictWU": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -StrictWinUnpacked",
    "desktop:dist:nobump": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -NoBump",
    "desktop:dist:skipWU:nobump": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -SkipWinUnpacked -NoBump",
    "desktop:dist:strictWU:nobump": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -StrictWinUnpacked -NoBump",
    "desktop:dist:signed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -Sign",
    "desktop:dist:signed:skipWU": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -SkipWinUnpacked -Sign",
    "desktop:dist:signed:strictWU": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -StrictWinUnpacked -Sign",
    "desktop:dist:signed:nobump": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -Sign -NoBump",
    "desktop:dist:signed:skipWU:nobump": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -SkipWinUnpacked -Sign -NoBump",
    "desktop:dist:signed:strictWU:nobump": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dist.ps1 -StrictWinUnpacked -Sign -NoBump",
    "desktop:version:bump": "node scripts/bump-desktop-version.mjs",
    "desktop:dist:auto": "npm run desktop:dist",
    "desktop:dist:autoSkipWU": "npm run desktop:dist:skipWU",
    "desktop:dist:watch": "node scripts/watch-desktop-dist.mjs",
    "desktop:dev+dist": "concurrently -k -n APP,INSTALLER -c cyan,magenta \"npm run desktop:dev\" \"npm run desktop:dist:watch\"",
    "desktop:release": "npm run desktop:dist",
    "desktop:dist:legacy": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { ./scripts/generate-icon.ps1; npm run desktop:build; npx --no-install electron-builder --config electron-builder.config.cjs --win --x64 --config.directories.output=release2_build }\"",
    "test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "test:watch": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs --watch",
    "test:coverage": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs --coverage",
    "lint": "node scripts/lint.mjs",
    "format": "prettier --write \"src/**/*\" \"electron/**/*\" \"tests/**/*\"",
    "format:check": "prettier --check \"src/**/*\" \"electron/**/*\" \"tests/**/*\"",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "smoke:ui+": "node scripts/smoke-ui.mjs --fail-on-warnings",
    "db:audit": "node scripts/db-audit-readonly-sqljs.mjs",
    "db:fix": "npx --no-install electron scripts/db-apply-fixes-electron.mjs --",
    "db:fix:node": "node scripts/db-apply-fixes-node.mjs"
  },
  "dependencies": {
    "@fontsource/tajawal": "^5.2.7",
    "@noble/ed25519": "^3.0.0",
    "@types/file-saver": "^2.0.7",
    "better-sqlite3": "^12.8.0",
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "chart.js": "^4.5.1",
    "docxtemplater": "^3.67.6",
    "dompurify": "^3.3.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "i18next": "^25.5.2",
    "lucide-react": "^0.556.0",
    "mammoth": "^1.10.0",
    "mssql": "^12.2.0",
    "pdfjs-dist": "^5.4.530",
    "pizzip": "^3.2.0",
    "react": "^19.2.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.1",
    "react-grid-layout": "^1.5.0",
    "react-i18next": "^16.1.1",
    "react-resizable": "^3.0.5",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.5.1",
    "sonner": "^2.0.7",
    "tar": "^7.4.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/electron": "^1.4.38",
    "@types/jest": "^30.0.0",
    "@types/mssql": "^9.1.8",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "chokidar": "^3.6.0",
    "concurrently": "^9.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.5.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "playwright-core": "^1.57.0",
    "postcss": "^8.5.1",
    "prettier": "^3.7.4",
    "sql.js": "^1.13.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.6",
    "typescript": "~5.8.2",
    "vite": "^6.4.1",
    "wait-on": "^8.0.2"
  }
}
