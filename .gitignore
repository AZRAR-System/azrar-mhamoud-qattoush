# ===========================
# AZRAR Desktop - .gitignore
# ===========================

# Dependencies
node_modules/
jspm_packages/
bower_components/

# Build Output
dist/
dist-ssr/
# Ignore build artifacts but keep installer resources tracked (see electron-builder.config.cjs)
build/*
!build/installer.nsh
!build/sql-express-install.ps1
!build/TERMS_AND_PRIVACY.txt
!build/icon.png
out/
release*/
release2_build/
release2_build_archive/
release_licenseadmin_build/
release_licensegen_build/
release-artifacts/
win-unpacked/
*.exe
*.blockmap
.icon-ico/
.icon-icns/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Environment & Secrets
.env
.env.local
.env.development
.env.*.local
.cursor/

# Local overrides (keep secrets out of git)
.env.desktop.local
*.local
*.pfx
*.p12
*.key
*.pem
certificates/
secrets/

# OS Files
.DS_Store
Thumbs.db
*.lnk
.AppleDouble
.LSOverride

# IDEs & Editors
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json
.vs/
.idea/
*.suo
*.user
*.iml

# Testing
coverage/
.nyc_output/
test-results/
playwright-report/
.cache/

# Temporary Files
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup
tmp/

# Microsoft Office temporary files
~$*.doc
~$*.docx
~$*.xls
~$*.xlsx
~$*.ppt
~$*.pptx
~WRL*.tmp

# Local QA outputs (generated)
lint-output.txt
tmp-*.txt
tmp.*.json
tmp-db-audit*.json
tmp_check_*.mjs
smoke-report*.json
.eslint-pages.json

# Database
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Electron Specific
electron/**/*.js
electron/**/*.cjs
!electron/**/*.config.js
.electron/

# License server runtime data
server/data/

# Generated integrity manifest
electron/assets/integrity.manifest.json

# TypeScript
*.tsbuildinfo

# Misc
.eslintcache
.npm/
*.pid
*.seed

# Keep These
!.gitkeep
!.npmrc
!.editorconfig

# OneDrive Git workaround (temporary)
.git.oneDrive-broken-*/

# Temp diagnostic files
*.py
tsc_*.txt
tsc_output*.txt
test_output*.txt
tsc_error*.txt
tsconfig.test.json
azrar_system_overview.md
