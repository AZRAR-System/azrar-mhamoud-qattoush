# ===========================
# AZRAR Desktop - .gitignore
# ===========================

# Dependencies
node_modules/
jspm_packages/
bower_components/

# Build Output
dist/
dist-ssr/
build/
out/
release*/
release2_build/
release2_build_archive/
release_licenseadmin_build/
release_licensegen_build/
release-artifacts/
win-unpacked/
*.exe
*.blockmap
.icon-ico/
.icon-icns/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Environment & Secrets
.env
.env.local
.env.*.local
*.local
*.pfx
*.p12
*.key
*.pem
certificates/
secrets/

# OS Files
.DS_Store
Thumbs.db
*.lnk
.AppleDouble
.LSOverride

# IDEs & Editors
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json
.vs/
.idea/
*.suo
*.user
*.iml

# Testing
coverage/
.nyc_output/
test-results/
playwright-report/
.cache/

# Temporary Files
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup
tmp/

# Microsoft Office temporary files
~$*.doc
~$*.docx
~$*.xls
~$*.xlsx
~$*.ppt
~$*.pptx
~WRL*.tmp

# Local QA outputs (generated)
lint-output.txt
tmp-*.txt
tmp.*.json
tmp-db-audit*.json
tmp_check_*.mjs
smoke-report*.json
.eslint-pages.json

# Database
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Electron Specific
electron/**/*.js
electron/**/*.cjs
!electron/**/*.config.js
.electron/

# License server runtime data
server/data/

# Generated integrity manifest
electron/assets/integrity.manifest.json

# Package Managers
package-lock.json

# TypeScript
*.tsbuildinfo

# Misc
.eslintcache
.npm/
*.pid
*.seed

# Keep These
!.gitkeep
!.npmrc
!.editorconfig

# OneDrive Git workaround (temporary)
.git.oneDrive-broken-*/
