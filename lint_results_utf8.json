  });\n\n      const result = asUnknownRecord(resultUnknown);\n      if (result['success'] !== true || typeof result['relativePath'] !== 'string') {\n        return fail(String(result['message'] || 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв”ҳГ в”ҳГӨв”ҳГј в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв”ҳГ©в•Әв–’в•Әв•Ў'));\n      }\n\n      const all = get<Attachment>(KEYS.ATTACHMENTS);\n      const att: Attachment = {\n        id: `ATT-${Date.now()}`,\n        referenceType: type,\n        referenceId: id,\n        fileName: file.name,\n        fileSize: file.size,\n        fileType: file.type,\n        fileExtension: file.name.split('.').pop() || '',\n        uploadDate: new Date().toISOString(),\n        uploadedBy: 'Admin',\n        filePath: result['relativePath'] as string,\n      };\n\n      save(KEYS.ATTACHMENTS, [...all, att]);\n      return ok(att);\n    } catch (e) {\n      return fail(e instanceof Error ? e.message : 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв”ҳГ в”ҳГӨв”ҳГј');\n    }\n  }\n\n  return new Promise((resolve, reject) => {\n    const reader = new FileReader();\n    reader.readAsDataURL(file);\n    reader.onload = () => {\n      const all = get<Attachment>(KEYS.ATTACHMENTS);\n      const att: Attachment = {\n        id: `ATT-${Date.now()}`,\n        referenceType: type,\n        referenceId: id,\n        fileName: file.name,\n        fileSize: file.size,\n        fileType: file.type,\n        fileExtension: file.name.split('.').pop() || '',\n        uploadDate: new Date().toISOString(),\n        uploadedBy: 'Admin',\n        fileData: reader.result as string,\n      };\n      try {\n        save(KEYS.ATTACHMENTS, [...all, att]);\n        resolve(ok(att));\n      } catch {\n        reject('File too large for mock storage');\n      }\n    };\n    reader.onerror = reject;\n  });\n};\n\nexport const deleteAttachment = async (id: string): Promise<DbResult<null>> => {\n  const all = get<Attachment>(KEYS.ATTACHMENTS);\n  const att = all.find((a) => a.id === id);\n\n  const desktopDb = getDesktopBridge();\n  if (att?.filePath && desktopDb?.deleteAttachmentFile) {\n    try {\n      await desktopDb.deleteAttachmentFile(att.filePath);\n    } catch { /* best-effort */ }\n  }\n\n  save(KEYS.ATTACHMENTS, all.filter((a) => a.id !== id));\n  return ok();\n};\n\nexport const readWordTemplate = async (\n  templateName: string,\n  templateType?: 'contracts' | 'installments' | 'handover'\n): Promise<DbResult<ArrayBuffer>> => {\n  const desktopDb = getDesktopBridge();\n  if (!desktopDb?.readTemplateFile) return fail('в”ҳГ в”ҳГЁв•Әв–“в•ӘвҢҗ в”ҳГ©в”ҳГӘв•ӘВәв”ҳГӨв•ӘВҝ Word в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎв•ӘвҢҗ в”ҳГјв”ҳГЁ в”ҳГҘв•Әв”Ӯв•ӘВ«в•ӘвҢҗ в•Әв”Ӯв•Әв•–в•ӘВЎ в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•ӘВҝ в”ҳГјв”ҳГ©в•Әв•–');\n\n  try {\n    const resUnknown = await desktopDb.readTemplateFile({ templateName, templateType });\n    const res = asUnknownRecord(resUnknown);\n    if (res['success'] !== true || typeof res['dataUri'] !== 'string') {\n      return fail(String(res['message'] || 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ Word'));\n    }\n\n    const dataUri = res['dataUri'];\n    const commaIdx = dataUri.indexOf(',');\n    if (commaIdx < 0) return fail('в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ Word в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘВәв”ҳГӨв•ӘВЎ (dataUri)');\n    const payload = dataUri.slice(commaIdx + 1);\n    const bin = atob(payload);\n    const bytes = new Uint8Array(bin.length);\n    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);\n    return ok(bytes.buffer);\n  } catch (e) {\n    return fail(e instanceof Error ? e.message : 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ Word');\n  }\n};\n\nexport const listWordTemplates = async (\n  templateType?: 'contracts' | 'installments' | 'handover'\n): Promise<DbResult<string[]>> => {\n  const desktopDb = getDesktopBridge();\n  if (!desktopDb?.listTemplates) return fail('в”ҳГ в”ҳГЁв•Әв–“в•ӘвҢҗ в”ҳГ©в”ҳГӘв•ӘВәв”ҳГӨв•ӘВҝ Word в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎв•ӘвҢҗ в”ҳГјв”ҳГЁ в”ҳГҘв•Әв”Ӯв•ӘВ«в•ӘвҢҗ в•Әв”Ӯв•Әв•–в•ӘВЎ в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•ӘВҝ в”ҳГјв”ҳГ©в•Әв•–');\n\n  try {\n    const resUnknown = await desktopDb.listTemplates({ templateType });\n    const res = asUnknownRecord(resUnknown);\n    if (res['success'] !== true) return fail(String(res['message'] || 'в•ӘВ¬в•Әв•Јв•Әв–‘в•Әв–’ в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в”ҳГ©в•ӘВәв•ӘВӘв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ©в”ҳГӘв•ӘВәв”ҳГӨв•ӘВҝ'));\n    const items = res['items'];\n    return ok(Array.isArray(items) ? items.filter((x) => typeof x === 'string') : []);\n  } catch (e) {\n    return fail(e instanceof Error ? e.message : 'в•ӘВ¬в•Әв•Јв•Әв–‘в•Әв–’ в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в”ҳГ©в•ӘВәв•ӘВӘв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ©в”ҳГӘв•ӘВәв”ҳГӨв•ӘВҝ');\n  }\n};\n\nexport const downloadAttachment = async (id: string): Promise<string | null> => {\n  const bridge = getDesktopBridge();\n  if (bridge && typeof bridge.get === 'function') {\n    try {\n      const raw = await bridge.get(KEYS.ATTACHMENTS);\n      const parsed = JSON.parse(String(raw || '[]'));\n      const match = parsed.find((x: Attachment) => x.id === id);\n      if (match && match.filePath && typeof bridge.readAttachmentFile === 'function') {\n        const res = await bridge.readAttachmentFile(match.filePath);\n        if (res && res.success) return res.dataUri;\n      }\n      return match?.fileData || null;\n    } catch { return null; }\n  }\n  const all = get<Attachment>(KEYS.ATTACHMENTS);\n  return all.find((a) => a.id === id)?.fileData || null;\n};\n","usedDeprecatedRules":[]},{"filePath":"g:\\pk\\pk\\azrar-mhamoud-qattoush-recovered\\src\\services\\db\\system\\dynamic.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"g:\\pk\\pk\\azrar-mhamoud-qattoush-recovered\\src\\services\\db\\system\\followups.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount