1) return fail('в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ»в•ӘвҢҗ');\n\n  const current = all[idx];\n  const next: в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘВәв•ӘВ¬_tbl = { ...current, ...patch };\n\n  // Recalculate Total if any constituent part was modified\n  const changedAny = [\n    'в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•ӘВәв”ҳГӨв”ҳГў',\n    'в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘГәв•ӘВјв•Әв–’',\n    'в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј',\n    'в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ',\n    'в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’',\n  ].some((key) => key in patch);\n\n  if (changedAny) {\n    const isSale = next.в”ҳГҘв”ҳГӘв•Әв•Ј_в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ === 'Sale';\n    if (isSale) {\n      next.в•ӘВәв”ҳГӨв”ҳГ в•ӘВјв”ҳГ в”ҳГӘв•Әв•Ј = \n        Number(next.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј || 0) + \n        Number(next.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ || 0) + \n        Number(next.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’ || 0);\n    } else {\n      next.в•ӘВәв”ҳГӨв”ҳГ в•ӘВјв”ҳГ в”ҳГӘв•Әв•Ј = \n        Number(next.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•ӘВәв”ҳГӨв”ҳГў || 0) + \n        Number(next.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘГәв•ӘВјв•Әв–’ || 0);\n    }\n  }\n\n  const updated = [...all];\n  updated[idx] = next;\n  save(KEYS.COMMISSIONS, updated);\n  return ok(next);\n};\n\nexport const postponeCommissionCollection = (\n  commissionId: string,\n  newDate: string,\n  target?: 'Owner' | 'Tenant',\n  note?: string\n): DbResult<в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘВәв•ӘВ¬_tbl> => {\n  const date = String(newDate || '').trim();\n  if (!/^\\d{4}-\\d{2}-\\d{2}$/.test(date)) return fail('в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ« в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘВәв”ҳГӨв•ӘВЎ');\n\n  const all = get<в•ӘВәв”ҳГӨв•Әв•Јв”