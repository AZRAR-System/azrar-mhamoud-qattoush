PaginationControls } from '@/components/shared/PaginationControls';\r\nimport type { в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ»_tbl, в•ӘВәв”ҳГӨв”ҳГўв”ҳГ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬_tbl } from '@/types/types';\r\nimport {\r\n  PieChart,\r\n  Pie,\r\n  Cell,\r\n  Tooltip,\r\n  ResponsiveContainer,\r\n  BarChart,\r\n  Bar,\r\n  XAxis,\r\n  YAxis,\r\n  CartesianGrid,\r\n  Legend,\r\n} from 'recharts';\r\n\r\ntype TabKey = 'diagnostics' | 'predictive' | 'performance' | 'testing' | 'database';\r\n\r\ninterface PerformanceRow {\r\n  name: string;\r\n  before: number;\r\n  after: number;\r\n}\r\n\r\ntype ViteMeta = {\r\n  env?: {\r\n    VITE_AUTORUN_SYSTEM_TESTS?: unknown;\r\n    VITE_AUTORUN_SYSTEM_TESTS_MUTATION?: unknown;\r\n    VITE_ENABLE_INTEGRATION_TEST_DATA?: unknown;\r\n  };\r\n};\r\n\r\n/* ========================= */\r\n/*   Helper UI Components    */\r\n/* ========================= */\r\n\r\nconst LoadingScreen = memo(() => (\r\n  <div className=\"flex flex-col h-[60vh] items-center justify-center space-y-6 animate-fade-in\">\r\n    <div className=\"relative\">\r\n      <div className=\"w-20 h-20 border-4 border-slate-200 dark:border-slate-700 rounded-full\" />\r\n      <div className=\"w-20 h-20 border-4 border-indigo-600 border-t-transparent rounded-full animate-spin absolute top-0 left-0\" />\r\n      <Activity\r\n        className=\"absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-indigo-600\"\r\n        size={24}\r\n      />\r\n    </div>\r\n    <p className=\"text-slate-500 dark:text-slate-400 font-bold animate-pulse\">\r\n      в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в”ҳГјв•ӘВЎв•Әв•Ў в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в”ҳГӘв•ӘВ¬в•Әв”Өв•ӘВ«в”ҳГЁв•Әв•Ў в•ӘВәв”ҳГӨв•ӘГәв•ӘВ»в•ӘВәв•ӘГӯ...\r\n    </p>\r\n  </div>\r\n));\r\n\r\ninterface HeaderProps {\r\n  onRecheck: () => void;\r\n  loading: boolean;\r\n  activeTab: TabKey;\r\n}\r\n\r\nconst MaintenanceHeader = memo<HeaderProps>(({ onRecheck, loading, activeTab }) => (\r\n  <div className={DS.components.pageHeader}>\r\n    <div>\r\n      <h2 className={`${DS.components.pageTitle} flex items-center gap-2`}>\r\n        <BrainCircuit size={22} />\r\n        в•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв•Әв–‘в”ҳГўв”ҳГЁв•ӘвҢҗ\r\n      </h2>\r\n      <p className=\"text-sm text-slate-500 dark:text-slate-400 mt-1\">\r\n        в•ӘГәв•ӘВ»в”ҳГӘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв”Өв•ӘВ«в”ҳГЁв•Әв•Ў в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в”ҳГ©в•ӘВ»в”ҳГ в•ӘвҢҗв•ӘГ® в•ӘГ‘в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎ в•ӘВәв”ҳГӨв•ӘГәв•ӘВ«в•Әв•–в•ӘВәв•ӘГӯв•ӘГ® в”ҳГӘв•ӘВ¬в•ӘВЎв”ҳГӨв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘГәв•ӘВ»в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГјв”ҳГҘв”ҳГЁ\r\n      </p>\r\n    </div>\r\n    <Button\r\n      variant=\"secondary\"\r\n      onClick={onRecheck}\r\n      isLoading={loading}\r\n      title={activeTab !== 'diagnostics' ? 'в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•Әв–’в•ӘВјв”ҳГӘв•Әв•Ј в”ҳГӨв•ӘВ¬в•ӘВҝв”ҳГӘв”ҳГЁв•ӘВҝ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв”Өв•ӘВ«в”ҳГЁв•Әв•Ў в•ӘВҝв•Әв•Јв•ӘВ» в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў' : undefined}\r\n      rightIcon={<RotateCcw size={16} />}\r\n    >\r\n      в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў\r\n    </Button>\r\n  </div>\r\n));\r\n\r\ninterface TabsProps {\r\n  activeTab: TabKey;\r\n  setActiveTab: (tab: TabKey) => void;\r\n  onRunPerfTest: () => void;\r\n}\r\n\r\nconst MaintenanceTabs = memo<TabsProps>(({ activeTab, setActiveTab, onRunPerfTest }) => (\r\n  <div className=\"flex flex-wrap gap-2\">\r\n    <Button\r\n      variant={activeTab === 'diagnostics' ? 'primary' : 'secondary'}\r\n      onClick={() => setActiveTab('diagnostics')}\r\n      rightIcon={<Stethoscope size={18} />}\r\n    >\r\n      в•ӘВәв”ҳГӨв•ӘВ¬в•Әв”Өв•ӘВ«в”ҳГЁв•Әв•Ў в•ӘВәв”ҳГӨв•Әв•Ўв•ӘВЎв”ҳГЁ\r\n    </Button>\r\n    <Button\r\n      variant={activeTab === 'predictive' ? 'primary' : 'secondary'}\r\n      onClick={() => setActiveTab('predictive')}\r\n      rightIcon={<TrendingUp size={18} />}\r\n    >\r\n      в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГӨв”ҳГЁв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГҘв•ӘВҝв•ӘГұв”ҳГЁв•ӘвҢҗ\r\n    </Button>\r\n    <Button\r\n      variant={activeTab === 'performance' ? 'primary' : 'secondary'}\r\n      onClick={onRunPerfTest}\r\n      rightIcon={<Gauge size={18} />}\r\n    >\r\n      в•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•ӘГәв•ӘВ»в•ӘВәв•ӘГӯ\r\n    </Button>\r\n    <Button\r\n      variant={activeTab === 'testing' ? 'primary' : 'secondary'}\r\n      onClick={() => setActiveTab('testing')}\r\n      rightIcon={<Terminal size={18} />}\r\n    >\r\n      в•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ \r\n    </Button>\r\n    <Button\r\n      variant={activeTab === 'database' ? 'primary' : 'secondary'}\r\n      onClick={() => setActiveTab('database')}\r\n      rightIcon={<Database size={18} />}\r\n    >\r\n      в”ҳГ©в•ӘВәв•Әв•Јв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬\r\n    </Button>\r\n  </div>\r\n));\r\n\r\n/* ========================= */\r\n/*     Diagnostics View      */\r\n/* ========================= */\r\n\r\ninterface DiagnosticsViewProps {\r\n  health: SystemHealth;\r\n  optimizing: boolean;\r\n  onAutoFix: () => void;\r\n}\r\n\r\nconst DiagnosticsView = memo<DiagnosticsViewProps>(({ health, optimizing, onAutoFix }) => {\r\n  // Simple HTML/CSS Circular Progress to avoid SVG complexity causing layout shifts\r\n  const scoreColor =\r\n    health.score > 80\r\n      ? 'text-emerald-500 border-emerald-500'\r\n      : health.score > 60\r\n        ? 'text-amber-500 border-amber-500'\r\n        : 'text-red-500 border-red-500';\r\n\r\n  const statusConfig = (() => {\r\n    switch (health.status) {\r\n      case 'Excellent':\r\n        return {\r\n          icon: CheckCircle,\r\n          className: 'bg-emerald-100 text-emerald-700 border-emerald-200',\r\n          label: 'в”ҳГ в”ҳГ в•ӘВ¬в•ӘВәв•Әв–“в•ӘвҢҗ',\r\n        };\r\n      case 'Good':\r\n        return {\r\n          icon: ShieldCheck,\r\n          className: 'bg-indigo-100 text-indigo-700 border-indigo-200',\r\n          label: 'в•ӘВјв”ҳГЁв•ӘВ»в•ӘвҢҗ',\r\n        };\r\n      case 'Warning':\r\n        return {\r\n          icon: AlertTriangle,\r\n          className: 'bg-amber-100 text-amber-700 border-amber-200',\r\n          label: 'в”ҳГ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•–в•ӘвҢҗ',\r\n        };\r\n      case 'Critical':\r\n      default:\r\n        return {\r\n          icon: XCircle,\r\n          className: 'bg-red-100 text-red-700 border-red-200',\r\n          label: 'в•ӘВЎв•Әв–’в•ӘВјв•ӘвҢҗ',\r\n        };\r\n    }\r\n  })();\r\n\r\n  const StatusIcon = statusConfig.icon;\r\n\r\n  return (\r\n    <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 animate-slide-up\">\r\n      {/* 1. Health Score Card (Left Column) */}\r\n      <div className=\"lg:col-span-4 app-card p-8 rounded-3xl flex flex-col items-center justify-center text-center relative overflow-hidden min-h-[350px]\">\r\n        <div className=\"absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500\" />\r\n\r\n        <div\r\n          className={`relative w-48 h-48 rounded-full border-[12px] flex items-center justify-center mb-8 ${scoreColor} bg-gray-50 dark:bg-slate-900 transition-all duration-500`}\r\n        >\r\n          <div className=\"flex flex-col items-center\">\r\n            <span className=\"text-5xl font-black text-slate-800 dark:text-white tracking-tighter\">\r\n              {health.score}%\r\n            </span>\r\n            <span className=\"text-xs text-slate-400 font-bold uppercase tracking-wider mt-1\">\r\n              в•ӘВ»в•Әв–’в•ӘВјв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Ўв•ӘВЎв•ӘвҢҗ\r\n            </span>\r\n          </div>\r\n        </div>\r\n\r\n        <div\r\n          className={`px-6 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2 border ${statusConfig.className}`}\r\n        >\r\n          <StatusIcon size={18} />\r\n          в•ӘВәв”ҳГӨв•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ: {statusConfig.label}\r\n        </div>\r\n      </div>\r\n\r\n      {/* 2. Stats & Issues (Right Column) */}\r\n      <div className=\"lg:col-span-8 flex flex-col gap-6\">\r\n        {/* Stats Row */}\r\n        <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\r\n          {[\r\n            {\r\n              label: 'в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬',\r\n              val: health.stats.integrityWarnings,\r\n              icon: Database,\r\n              color: 'text-indigo-600',\r\n              bg: 'bg-indigo-50 dark:bg-indigo-900/20',\r\n            },\r\n            {\r\n              label: 'в•Әв”Ӯв•ӘВјв”ҳГӨв•ӘВәв•ӘВ¬ в”ҳГЁв•ӘВ¬в”ҳГЁв”ҳГ в•ӘвҢҗ',\r\n              val: health.stats.orphans,\r\n              icon: FileQuestion,\r\n              color: 'text-amber-600',\r\n              bg: 'bg-amber-50 dark:bg-amber-900/20',\r\n            },\r\n            {\r\n              label: 'в•ӘГәв•ӘВ«в•Әв•–в•ӘВәв•ӘГӯ в”ҳГ в”ҳГҘв•Әв•–в”ҳГ©в”ҳГЁв•ӘвҢҗ',\r\n              val: health.stats.logicErrors,\r\n              icon: AlertOctagon,\r\n              color: 'text-red-600',\r\n              bg: 'bg-red-50 dark:bg-red-900/20',\r\n            },\r\n          ].map((item, idx) => (\r\n            <div\r\n              key={idx}\r\n              className=\"app-card p-5 flex flex-col items-start hover:shadow-md transition\"\r\n            >\r\n              <div className={`p-3 rounded-xl ${item.bg} ${item.color} mb-3`}>\r\n                <item.icon size={24} />\r\n              </div>\r\n              <span className=\"text-3xl font-bold text-slate-800 dark:text-white mb-1\">\r\n                {item.val}\r\n              </span>\r\n              <span className=\"text-xs text-slate-500 dark:text-slate-400 font-medium\">\r\n                {item.label}\r\n              </span>\r\n            </div>\r\n          ))}\r\n        </div>\r\n\r\n        {/* Detailed Issues List */}\r\n        <div className=\"flex-1 app-card rounded-3xl flex flex-col min-h-[300px]\">\r\n          <div className=\"p-5 border-b border-gray-100 dark:border-slate-700 bg-gray-50 dark:bg-slate-900/30 flex items-center justify-between\">\r\n            <h3 className=\"font-bold text-slate-800 dark:text-white flex items-center gap-2\">\r\n              <FileSearch size={20} className=\"text-indigo-500\" />\r\n              в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВәв”ҳГўв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•Әв”Өв”ҳГјв•ӘвҢҗ ({health.issues.length})\r\n            </h3>\r\n            {health.issues.length > 0 && (\r\n              <button\r\n                onClick={onAutoFix}\r\n                disabled={optimizing}\r\n                className=\"flex items-center gap-2 bg-indigo-600 text-white px-4 py-2 rounded-xl text-xs font-bold hover:bg-indigo-700 disabled:opacity-50 transition shadow-lg shadow-indigo-600/20\"\r\n              >\r\n                {optimizing ? (\r\n                  <>\r\n                    <RotateCcw size={14} className=\"animate-spin\" /> в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв•ӘВәв”ҳГӨв•ӘВјв•ӘвҢҗ...\r\n                  </>\r\n                ) : (\r\n                  <>\r\n                    <Wrench size={14} /> в•ӘГ‘в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎ в•Әв–‘в”ҳГўв”ҳГЁ\r\n                  </>\r\n                )}\r\n              </button>\r\n            )}\r\n          </div>\r\n\r\n          <div className=\"flex-1 overflow-y-auto max-h-[400px] custom-scrollbar p-4 space-y-3\">\r\n            {health.issues.length === 0 ? (\r\n              <div className=\"h-full flex flex-col items-center justify-center p-8 text-center\">\r\n                <div className=\"w-16 h-16 bg-green-50 dark:bg-green-900/20 rounded-full flex items-center justify-center mb-4\">\r\n                  <CheckCircle size={32} className=\"text-green-500\" />\r\n                </div>\r\n                <h4 className=\"text-slate-800 dark:text-white font-bold\">в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•Әв”Ӯв”ҳГӨв”ҳГЁв”ҳГ  в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в•ӘВәв”ҳГҜ</h4>\r\n                <p className=\"text-sm text-slate-500 mt-1\">\r\n                  в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в•ӘГәв•ӘВ«в•Әв•–в•ӘВәв•ӘГӯ в”ҳГјв”ҳГЁ в•ӘВ¬в”ҳГўв•ӘВәв”ҳГ в”ҳГӨ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘГәв”ҳГӘ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГӨв•ӘВәв”ҳГ©в•ӘВәв•ӘВ¬.\r\n                </p>\r\n              </div>\r\n            ) : (\r\n              health.issues.map((issue) => (\r\n                <div\r\n                  key={issue.id}\r\n                  className=\"p-4 bg-gray-50 dark:bg-slate-700/20 rounded-xl border border-gray-100 dark:border-slate-700 flex gap-4\"\r\n                >\r\n                  <div\r\n                    className={`mt-1 p-2 rounded-lg h-fit ${issue.type === 'Critical' ? 'bg-red-100 text-red-600' : 'bg-amber-100 text-amber-600'}`}\r\n                  >\r\n                    {issue.type === 'Critical' ? (\r\n                      <AlertOctagon size={18} />\r\n                    ) : (\r\n                      <AlertTriangle size={18} />\r\n                    )}\r\n                  </div>\r\n                  <div>\r\n                    <div className=\"flex items-center gap-2 mb-1\">\r\n                      <span className=\"font-bold text-slate-800 dark:text-white text-sm\">\r\n                        {issue.category} Issue\r\n                      </span>\r\n                      <StatusBadge\r\n                        status={issue.type}\r\n                        showIcon={false}\r\n                        className=\"!text-[10px] !px-2 !py-0.5 uppercase\"\r\n                      />\r\n                    </div>\r\n                    <p className=\"text-sm text-slate-600 dark:text-slate-300 leading-relaxed\">\r\n                      {issue.description}\r\n                    </p>\r\n                  </div>\r\n                </div>\r\n              ))\r\n            )}\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n});\r\n\r\n/* ========================= */\r\n/*     Predictive View       */\r\n/* ========================= */\r\n\r\ninterface PredictiveViewProps {\r\n  predictiveInsight: PredictiveInsight;\r\n}\r\n\r\nconst PredictiveView = memo<PredictiveViewProps>(({ predictiveInsight }) => {\r\n  const hasRiskFactors = predictiveInsight.riskFactors.length > 0;\r\n  const riskColors = ['#3b82f6', '#ef4444', '#f59e0b', '#10b981'];\r\n\r\n  return (\r\n    <div className=\"space-y-8 animate-slide-up\">\r\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\r\n        {/* Score Card */}\r\n        <div className=\"bg-gradient-to-br from-indigo-600 to-violet-800 rounded-3xl p-8 text-white shadow-xl shadow-indigo-500/20 relative overflow-hidden flex flex-col justify-between min-h-[300px]\">\r\n          <div className=\"relative z-10\">\r\n            <h3 className=\"text-indigo-100 font-bold flex items-center gap-2 mb-4\">\r\n              <Activity size={20} /> в”ҳГ в•ӘГұв•Әв”Өв•Әв–’ в•ӘВәв”ҳГӨв•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳГ©в•Әв–’в•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в•ӘВҝв”ҳГӨв”ҳГЁ\r\n            </h3>\r\n            <div className=\"flex items-baseline gap-2 mb-6\">\r\n              <span className=\"text-7xl font-black tracking-tight\">{predictiveInsight.score}</span>\r\n              <span className=\"text-2xl opacity-60 font-medium\">/ 100</span>\r\n            </div>\r\n\r\n            <div className=\"flex flex-wrap gap-2 mb-4\">\r\n              <span className=\"px-3 py-1 rounded-lg text-sm font-bold bg-white/20 border border-white/10 backdrop-blur-md\">\r\n                {predictiveInsight.status === 'Safe' ? 'О“ВЈГ  в•ӘВәв”ҳГӨв”ҳГӘв•Әв•ўв•Әв•Ј в•ӘГів”ҳГ в”ҳГҘ' : 'О“ГңГЎвҲ©в••Г… в”ҳГЁв•ӘВ¬в•Әв•–в”ҳГӨв•ӘВҝ в”ҳГ в•Әв–’в•ӘВәв”ҳГ©в•ӘВҝв•ӘвҢҗ'}\r\n              </span>\r\n              <span className=\"px-3 py-1 rounded-lg text-sm font-bold bg-white/20 border border-white/10 backdrop-blur-md\">\r\n                {predictiveInsight.trend === 'Improving' ? 'вүЎЖ’ГҙГӘ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в•ӘВјв•ӘВәв”ҳГ§ в•Әв•Ўв•ӘВәв•Әв•Јв•ӘВ»' : 'О“вӮ§ГӯвҲ©в••Г… в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в•ӘВјв•ӘВәв”ҳГ§ в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в•Әв–’'}\r\n              </span>\r\n            </div>\r\n\r\n            <p className=\"text-sm text-indigo-100 opacity-90 leading-relaxed whitespace-normal break-words\">\r\n              {predictiveInsight.status === 'Safe'\r\n                ? 'в•ӘВ«в”ҳГӘв•ӘВәв•Әв–’в•Әв–“в”ҳГ в”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв–‘в”ҳГўв•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв•ӘВәв•Әв•Ўв•Әв•–в”ҳГҘв•ӘВәв•Әв•Јв”ҳГЁ в•ӘВ¬в•ӘВ¬в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳГ©в•Әв–’в•ӘВәв•Әв–’в•ӘВәв”ҳГҜ в”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘВәв”ҳГҜ в”ҳГӘв•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨв”ҳГЁв•ӘВәв”ҳГҜ в•Әв•Јв•ӘВәв”ҳГӨв”ҳГЁв•ӘВәв”ҳГҜ в•ӘВ«в”ҳГӨв•ӘВәв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГҮ 30 в”ҳГЁв”ҳГӘв”ҳГ в•ӘВәв”ҳГҜ в•ӘВәв”ҳГӨв”ҳГ©в•ӘВәв•ӘВ»в”ҳГ в•ӘвҢҗ.'\r\n                : 'в•ӘВ¬в”ҳГ  в•Әв–’в•Әв•Ўв•ӘВ» в”ҳГ в•ӘГұв•Әв”Өв•Әв–’в•ӘВәв•ӘВ¬ в”ҳГ©в•ӘВ» в•ӘВ¬в•ӘГұв•ӘВ»в”ҳГЁ в”ҳГӨв•ӘВ¬в•Әв•Јв•ӘВҪв•Әв–’ в”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘГәв”ҳГӘ в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в”ҳГЁв•ӘГ® в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в”ҳГ в•Әв–’в•ӘВәв•ӘВјв•Әв•Јв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГӘв•Әв•Ўв”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВҝв•Әв•Јв”ҳГҘв•ӘВәв”ҳГЁв•ӘвҢҗ.'}\r\n            </p>\r\n          </div>\r\n\r\n          {/* Background Decor */}\r\n          <BrainCircuit className=\"absolute bottom-[-20px] left-[-20px] text-white opacity-10 w-64 h-64 rotate-12 pointer-events-none\" />\r\n          <div className=\"absolute top-0 right-0 w-64 h-64 bg-purple-500 opacity-20 blur-3xl rounded-full mix-blend-overlay pointer-events-none\" />\r\n        </div>\r\n\r\n        {/* AI Recommendations */}\r\n        <div className=\"app-card p-8 rounded-3xl flex flex-col min-h-[300px]\">\r\n          <h3 className=\"font-bold text-slate-800 dark:text-white mb-6 flex items-center gap-2 text-lg\">\r\n            <Zap size={24} className=\"text-amber-500 fill-amber-500\" /> в•ӘВ¬в”ҳГӘв•Әв•Ўв”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв–‘в”ҳГўв•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв•ӘВәв•Әв•Ўв•Әв•–в”ҳГҘв•ӘВәв•Әв•Јв”ҳГЁ\r\n          </h3>\r\n\r\n          <div className=\"flex-1 overflow-y-auto custom-scrollbar pr-2 space-y-3 max-h-[300px]\">\r\n            {predictiveInsight.recommendations.length === 0 ? (\r\n              <div className=\"h-full flex flex-col items-center justify-center text-gray-400 py-4\">\r\n                <CheckCircle size={40} className=\"mb-2 opacity-30\" />\r\n                <p>в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в•ӘВ¬в”ҳГӘв•Әв•Ўв”ҳГЁв•ӘВәв•ӘВ¬в•ӘГ® в•ӘВәв”ҳГӨв•ӘГәв•ӘВ»в•ӘВәв•ӘГӯ в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨв”ҳГЁ.</p>\r\n              </div>\r\n            ) : (\r\n              predictiveInsight.recommendations.map((rec, i) => (\r\n                <div\r\n                  key={i}\r\n                  className=\"flex gap-3 p-3 bg-amber-50 dark:bg-amber-900/10 rounded-xl border border-amber-100 dark:border-amber-800/30\"\r\n                >\r\n                  <span className=\"w-6 h-6 rounded-full bg-amber-200 dark:bg-amber-800 text-amber-900 dark:text-amber-100 flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5\">\r\n                    {i + 1}\r\n                  </span>\r\n                  <p className=\"text-sm text-slate-700 dark:text-slate-300 leading-relaxed whitespace-normal\">\r\n                    {rec}\r\n                  </p>\r\n                </div>\r\n              ))\r\n            )}\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Risk Analysis Chart */}\r\n      <div className=\"app-card p-8 rounded-3xl\">\r\n        <h3 className=\"font-bold text-slate-800 dark:text-white mb-6 flex items-center gap-2 text-lg\">\r\n          <AlertOctagon size={24} className=\"text-red-500\" /> в•ӘВ¬в”ҳГӘв•Әв–“в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв”ҳГ в•ӘВ«в•ӘВәв•Әв•–в•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•ӘВ¬в”ҳГ в”ҳГӨв•ӘвҢҗ\r\n        </h3>\r\n\r\n        <div className=\"flex flex-col md:flex-row items-center gap-12\">\r\n          {/* Pie Chart */}\r\n          <div className=\"w-full md:w-[350px] h-[300px] relative flex-shrink-0\">\r\n            {hasRiskFactors ? (\r\n              <ResponsiveContainer width=\"100%\" height=\"100%\">\r\n                <PieChart>\r\n                  <Pie\r\n                    data={predictiveInsight.riskFactors}\r\n                    cx=\"50%\"\r\n                    cy=\"50%\"\r\n                    innerRadius={80}\r\n                    outerRadius={120}\r\n                    paddingAngle={5}\r\n                    dataKey=\"count\"\r\n                    stroke=\"none\"\r\n                  >\r\n                    {predictiveInsight.riskFactors.map((entry, index) => (\r\n                      <Cell key={`cell-${index}`} fill={riskColors[index % riskColors.length]} />\r\n                    ))}\r\n                  </Pie>\r\n                  <Tooltip\r\n                    contentStyle={{\r\n                      borderRadius: '12px',\r\n                      border: 'none',\r\n                      boxShadow: '0 10px 15px -3px rgba(0,0,0,0.1)',\r\n                    }}\r\n                  />\r\n                </PieChart>\r\n              </ResponsiveContainer>\r\n            ) : (\r\n              <div className=\"flex flex-col items-center justify-center text-gray-400 border-4 border-dashed border-gray-100 dark:border-slate-700 rounded-full w-64 h-64 mx-auto\">\r\n                <ShieldCheck size={48} className=\"mb-2 text-emerald-500 opacity-50\" />\r\n                <p className=\"text-sm font-bold\">в”ҳГӨв•ӘВә в”ҳГЁв”ҳГӘв•ӘВјв•ӘВ» в”ҳГ в•ӘВ«в•ӘВәв•Әв•–в•Әв–’</p>\r\n              </div>\r\n            )}\r\n            {hasRiskFactors && (\r\n              <div className=\"absolute inset-0 flex flex-col items-center justify-center pointer-events-none\">\r\n                <span className=\"text-4xl font-bold text-slate-800 dark:text-white\">\r\n                  {predictiveInsight.riskFactors.reduce((a, b) => a + b.count, 0)}\r\n                </span>\r\n                <span className=\"text-[10px] text-gray-400 uppercase tracking-widest font-bold\">\r\n                  Risk Items\r\n                </span>\r\n              </div>\r\n            )}\r\n          </div>\r\n\r\n          {/* Custom Legend / List - MOVED OUTSIDE PIE */}\r\n          <div className=\"flex-1 w-full grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n            {predictiveInsight.riskFactors.map((factor, idx) => (\r\n              <div\r\n                key={idx}\r\n                className=\"flex items-center justify-between p-5 bg-gray-50 dark:bg-slate-900/50 rounded-xl border border-gray-100 dark:border-slate-800\"\r\n              >\r\n                <div className=\"flex items-center gap-3\">\r\n                  <svg className=\"w-4 h-4\" viewBox=\"0 0 16 16\" aria-hidden=\"true\" focusable=\"false\">\r\n                    <circle cx=\"8\" cy=\"8\" r=\"8\" fill={riskColors[idx % riskColors.length]} />\r\n                  </svg>\r\n                  <span className=\"font-bold text-slate-700 dark:text-slate-200 text-sm\">\r\n                    {factor.category}\r\n                  </span>\r\n                </div>\r\n                <div className=\"flex items-center gap-3\">\r\n                  <span className=\"text-sm font-bold text-slate-500 dark:text-slate-400\">\r\n                    {factor.count} в•Әв”Ӯв•ӘВјв”ҳГӨ\r\n                  </span>\r\n                  <span className=\"text-xs font-mono font-bold bg-white dark:bg-slate-800 px-2 py-1 rounded border border-gray-200 dark:border-slate-700\">\r\n                    {factor.percentage}%\r\n                  </span>\r\n                </div>\r\n              </div>\r\n            ))}\r\n            {!hasRiskFactors && (\r\n              <div className=\"col-span-2 p-6 bg-emerald-50 dark:bg-emerald-900/10 border border-emerald-100 dark:border-emerald-900/30 rounded-xl text-center\">\r\n                <p className=\"text-emerald-700 dark:text-emerald-400 font-bold\">\r\n                  в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в”ҳГЁв•Әв•Јв”ҳГ в”ҳГӨ в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в”ҳГҘв•Әв•–в”ҳГ©в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГів”ҳГ в”ҳГҘв•ӘвҢҗ в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в•ӘВәв”ҳГҜ.\r\n                </p>\r\n                <p className=\"text-xs text-emerald-600/70 mt-1\">\r\n                  в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в•ӘГәв”ҳГЁ в•ӘВ¬в”ҳГ§в•ӘВ»в”ҳГЁв•ӘВ»в•ӘВәв•ӘВ¬ в”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ в•ӘГәв”ҳГӘ в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨв”ҳГЁв•ӘвҢҗ в”ҳГ в•Әв–’в•Әв•Ўв”ҳГӘв•ӘВ»в•ӘвҢҗ.\r\n                </p>\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n});\r\n\r\n/* ========================= */\r\n/*    Performance View       */\r\n/* ========================= */\r\n\r\ninterface PerformanceViewProps {\r\n  performanceReport: PerformanceRow[];\r\n}\r\n\r\nconst PerformanceView = memo<PerformanceViewProps>(({ performanceReport }) => {\r\n  const [page, setPage] = useState(1);\r\n  const pageSize = 12;\r\n  const pageCount = Math.max(1, Math.ceil(performanceReport.length / pageSize));\r\n\r\n  useEffect(() => {\r\n    setPage((p) => Math.min(Math.max(1, p), pageCount));\r\n  }, [pageCount]);\r\n\r\n  const visible = performanceReport.slice((page - 1) * pageSize, page * pageSize);\r\n\r\n  return (\r\n    <div className=\"app-card p-8 rounded-3xl animate-slide-up\">\r\n      <div className=\"flex flex-col md:flex-row md:items-start gap-6 mb-8\">\r\n        <div className=\"p-4 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 rounded-2xl flex-shrink-0\">\r\n          <Gauge size={32} />\r\n        </div>\r\n        <div>\r\n          <h3 className=\"text-xl font-bold text-slate-800 dark:text-white\">\r\n            в•ӘВ¬в”ҳГ©в•Әв–’в”ҳГЁв•Әв–’ в•ӘГәв•ӘВ»в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГјв”ҳГ§в•Әв–’в•Әв”Ӯв•ӘвҢҗ (Caching Performance) - в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ\r\n          </h3>\r\n          <p className=\"text-sm text-slate-500 dark:text-slate-400 mt-2 leading-relaxed max-w-3xl\">\r\n            в”ҳГ в”ҳГ©в•ӘВәв•Әв–’в”ҳГҘв•ӘвҢҗ в•Әв–“в”ҳГ в”ҳГҘ в•ӘВәв”ҳГӨв”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в•ӘВҝв”ҳГЁв”ҳГҘ в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨв”ҳГЁв”ҳГҘ в”ҳГ в•ӘВ¬в•ӘВ¬в•ӘВәв”ҳГӨв”ҳГЁв”ҳГЁв”ҳГҘ (в”ҳГӨв•ӘВ¬в”ҳГ©в•ӘВ»в”ҳГЁв•Әв–’ в•ӘГәв•ӘВҪв•Әв–’ в•ӘВәв”ҳГӨв”ҳГўв•ӘВәв•Әв”Ө/в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВјв”ҳГ§в”ҳГЁв•Әв–“)\r\n          </p>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Chart Section */}\r\n      <div className=\"h-[450px] w-full mb-10 bg-slate-50 dark:bg-slate-900/20 rounded-2xl p-4 border border-slate-100 dark:border-slate-800\">\r\n        <ResponsiveContainer width=\"100%\" height=\"100%\">\r\n          <BarChart\r\n            data={performanceReport}\r\n            barGap={12}\r\n            barSize={24}\r\n            margin={{ top: 20, right: 30, left: 20, bottom: 60 }} // Extra bottom margin for Arabic labels\r\n          >\r\n            <CartesianGrid\r\n              strokeDasharray=\"3 3\"\r\n              vertical={false}\r\n              stroke=\"#e2e8f0\"\r\n              strokeOpacity={0.5}\r\n            />\r\n            <XAxis\r\n              dataKey=\"name\"\r\n              tick={{ fill: '#64748b', fontSize: 11, fontWeight: 600 }}\r\n              tickLine={false}\r\n              axisLine={false}\r\n              dy={15}\r\n              interval={0}\r\n              angle={-10} // Slight angle to prevent overlap\r\n              textAnchor=\"end\"\r\n            />\r\n            <YAxis\r\n              label={{\r\n                value: 'в•ӘВәв”ҳГӨв•Әв–“в”ҳГ в”ҳГҘ (ms)',\r\n                angle: -90,\r\n                position: 'insideLeft',\r\n                fill: '#94a3b8',\r\n                fontSize: 12,\r\n                dx: -10,\r\n              }}\r\n              tick={{ fill: '#94a3b8', fontSize: 11 }}\r\n              tickLine={false}\r\n              axisLine={false}\r\n              width={60} // Ensure width for Y labels\r\n            />\r\n            <Tooltip\r\n              cursor={{ fill: 'rgba(0,0,0,0.04)' }}\r\n              contentStyle={{\r\n                borderRadius: '12px',\r\n                border: 'none',\r\n                boxShadow: '0 10px 15px -3px rgba(0,0,0,0.1)',\r\n                padding: '12px',\r\n                backgroundColor: 'rgba(255, 255, 255, 0.95)',\r\n              }}\r\n            />\r\n            <Legend\r\n              verticalAlign=\"top\"\r\n              height={36}\r\n              iconType=\"circle\"\r\n              formatter={(value) => (\r\n                <span className=\"text-slate-600 dark:text-slate-300 font-bold text-sm mr-4\">\r\n                  {value}\r\n                </span>\r\n              )}\r\n            />\r\n            <Bar\r\n              dataKey=\"before\"\r\n              fill=\"#f87171\" // Red-400\r\n              name=\"в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв”ҳГ§в•Әв–’в•Әв”Ӯв•ӘвҢҗ (Original)\"\r\n              radius={[4, 4, 0, 0]}\r\n            />\r\n            <Bar\r\n              dataKey=\"after\"\r\n              fill=\"#10b981\" // Emerald-500\r\n              name=\"в•ӘВҝв•Әв•Јв•ӘВ» в•ӘВәв”ҳГӨв”ҳГјв”ҳГ§в•Әв–’в•Әв”Ӯв•ӘвҢҗ (Optimized)\"\r\n              radius={[4, 4, 0, 0]}\r\n            />\r\n          </BarChart>\r\n        </ResponsiveContainer>\r\n      </div>\r\n\r\n      {/* Table Details */}\r\n      <div className=\"app-table-wrapper mt-8\">\r\n        <div className=\"p-4 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 flex items-center justify-between gap-4\">\r\n          <div className=\"text-[10px] font-black text-slate-500 uppercase tracking-widest px-2\">\r\n            в•ӘВ¬в”ҳГјв•ӘВәв•Әв•Ўв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘГәв•ӘВ»в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГ в”ҳГ©в•ӘВәв•Әв–’в”ҳГҘ\r\n          </div>\r\n          <PaginationControls page={page} pageCount={pageCount} onPageChange={setPage} />\r\n        </div>\r\n        <div className=\"overflow-x-auto no-scrollbar\">\r\n          <table className=\"app-table\">\r\n            <thead className=\"app-table-thead\">\r\n              <tr>\r\n                <th className=\"app-table-th\">в”ҳГҘв”ҳГӘв•Әв•Ј в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘвҢҗ</th>\r\n                <th className=\"app-table-th\">в•ӘВәв”ҳГӨв•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘГәв”ҳГӘв”ҳГӨ (ms)</th>\r\n                <th className=\"app-table-th\">в•ӘВәв”ҳГӨв•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВҪв•ӘВәв”ҳГҘв”ҳГЁ (ms)</th>\r\n                <th className=\"app-table-th\">в”ҳГјв•Әв–’в”ҳГ© в•ӘВәв”ҳГӨв•Әв–“в”ҳГ в”ҳГҘ / в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв•Әв”Ӯв”ҳГҘ</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody className=\"divide-y divide-slate-100/50 dark:divide-slate-800/50\">\r\n              {visible.map((res) => {\r\n                const improvement =\r\n                  res.before > 0 ? ((res.before - res.after) / res.before) * 100 : 0;\r\n                return (\r\n                  <tr key={res.name} className=\"app-table-row app-table-row-striped group\">\r\n                    <td className=\"app-table-td font-black text-slate-700 dark:text-slate-200 flex items-center gap-3\">\r\n                      <div className=\"p-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-slate-400 group-hover:text-indigo-500 transition-colors\">\r\n                        <Calculator size={14} />\r\n                      </div>\r\n                      {res.name}\r\n                    </td>\r\n                    <td className=\"app-table-td\">\r\n                      <span className=\"text-rose-500 font-mono text-sm font-bold bg-rose-50 dark:bg-rose-900/10 px-2.5 py-1 rounded-lg border border-rose-100 dark:border-rose-900/30\">\r\n                        {res.before.toFixed(2)}\r\n                      </span>\r\n                    </td>\r\n                    <td className=\"app-table-td\">\r\n                      <span className=\"text-emerald-600 font-mono text-sm font-black bg-emerald-50 dark:bg-emerald-900/10 px-2.5 py-1 rounded-lg border border-emerald-100 dark:border-emerald-900/30\">\r\n                        {res.after.toFixed(4)}\r\n                      </span>\r\n                    </td>\r\n                    <td className=\"app-table-td\">\r\n                      <div className=\"flex items-center gap-4 min-w-[120px]\">\r\n                        <div className=\"flex-1 h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden shadow-inner\">\r\n                          <div\r\n                            className=\"h-full bg-gradient-to-r from-emerald-400 to-emerald-600 transition-all duration-1000 ease-out\"\r\n                            style={{ width: `${Math.min(improvement, 100)}%` }}\r\n                          />\r\n                        </div>\r\n                        <span className=\"text-[11px] font-black text-emerald-600 dark:text-emerald-400 w-12 text-left\">\r\n                          {improvement.toFixed(1)}%\r\n                        </span>\r\n                      </div>\r\n                    </td>\r\n                  </tr>\r\n                );\r\n              })}\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n});\r\n\r\n/* ========================= */\r\n/*     Testing View (NEW)    */\r\n/* ========================= */\r\n\r\nlet systemTestsAutorunStarted = false;\r\n\r\nconst SystemTestView = memo(() => {\r\n  const toast = useToast();\r\n  const { user } = useAuth();\r\n  const { openPanel } = useSmartModal();\r\n  const [running, setRunning] = useState(false);\r\n  const [allowMutation, setAllowMutation] = useState(false);\r\n  const [results, setResults] = useState<UiTestResult[] | null>(null);\r\n  const [resultsPage, setResultsPage] = useState(1);\r\n  const resultsPageSize = 12;\r\n\r\n  const isAutorunEnabled = (() => {\r\n    const flag = (import.meta as unknown as ViteMeta)?.env?.VITE_AUTORUN_SYSTEM_TESTS;\r\n    if (typeof flag === 'string') return flag.toLowerCase() === 'true';\r\n    try {\r\n      if (typeof window !== 'undefined') {\r\n        const qs = new URLSearchParams(window.location.search);\r\n        const v = qs.get('autorun');\r\n        if (v) {\r\n          const s = String(v).toLowerCase();\r\n          return s === '1' || s === 'true' || s === 'yes' || s === 'on';\r\n        }\r\n      }\r\n    } catch {\r\n      // ignore\r\n    }\r\n    return !!flag;\r\n  })();\r\n\r\n  const isIntegrationDataEnabled = (() => {\r\n    const flag = (import.meta as unknown as ViteMeta)?.env?.VITE_ENABLE_INTEGRATION_TEST_DATA;\r\n    if (typeof flag === 'string') return flag.toLowerCase() === 'true';\r\n    try {\r\n      if (typeof window !== 'undefined') {\r\n        const qs = new URLSearchParams(window.location.search);\r\n        const v = qs.get('integrationData');\r\n        if (v) {\r\n          const s = String(v).toLowerCase();\r\n          return s === '1' || s === 'true' || s === 'yes' || s === 'on';\r\n        }\r\n      }\r\n    } catch {\r\n      // ignore\r\n    }\r\n    return !!flag;\r\n  })();\r\n\r\n  const runTests = useCallback(async () => {\r\n    setRunning(true);\r\n    try {\r\n      const r = await runSystemScenarioTests({ allowDataMutation: allowMutation });\r\n      setResults(r);\r\n      const failed = r.filter((x) => x.status === 'FAIL').length;\r\n      toast[failed > 0 ? 'warning' : 'success'](\r\n        failed > 0 ? `в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВәв”ҳГҘв•ӘВ¬в”ҳГ§в•ӘВәв•ӘГӯ: ${failed} в•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в”ҳГјв•Әв”Өв”ҳГӨ` : 'в•ӘВ¬в”ҳГ  в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ'\r\n      );\r\n    } catch (e: unknown) {\r\n      toast.error(getErrorMessage(e) || 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬');\r\n    } finally {\r\n      setRunning(false);\r\n    }\r\n  }, [allowMutation, toast]);\r\n\r\n  // Optional automation: run tests immediately and print a summary for terminal logs.\r\n  useEffect(() => {\r\n    if (!isAutorunEnabled) return;\r\n    if (systemTestsAutorunStarted) return;\r\n    if (running) return;\r\n    if (results) return;\r\n\r\n    systemTestsAutorunStarted = true;\r\n\r\n    const forceMutation = (() => {\r\n      const flag = (import.meta as unknown as ViteMeta)?.env?.VITE_AUTORUN_SYSTEM_TESTS_MUTATION;\r\n      if (typeof flag === 'string') return flag.toLowerCase() === 'true';\r\n      try {\r\n        if (typeof window !== 'undefined') {\r\n          const qs = new URLSearchParams(window.location.search);\r\n          const v = qs.get('mutation');\r\n          if (v) {\r\n            const s = String(v).toLowerCase();\r\n            return s === '1' || s === 'true' || s === 'yes' || s === 'on';\r\n          }\r\n        }\r\n      } catch {\r\n        // ignore\r\n      }\r\n      return !!flag;\r\n    })();\r\n\r\n    const allowDataMutation = forceMutation || isIntegrationDataEnabled;\r\n    setAllowMutation(allowDataMutation);\r\n    setRunning(true);\r\n\r\n    (async () => {\r\n      try {\r\n        try {\r\n          console.warn(\r\n            `[autorun] system tests start (mutation=${allowDataMutation ? 'on' : 'off'})`\r\n          );\r\n        } catch {\r\n          // ignore\r\n        }\r\n        const r = await runSystemScenarioTests({ allowDataMutation });\r\n        setResults(r);\r\n\r\n        const fail = r.filter((x) => x.status === 'FAIL').length;\r\n        try {\r\n          console.warn(`[autorun] system tests done (failed=${fail})`);\r\n        } catch {\r\n          // ignore\r\n        }\r\n        toast[fail > 0 ? 'warning' : 'success'](\r\n          fail > 0 ? `в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВәв”ҳГҘв•ӘВ¬в”ҳГ§в•ӘВәв•ӘГӯ: ${fail} в•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в”ҳГјв•Әв”Өв”ҳГӨ` : 'в•ӘВ¬в”ҳГ  в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ'\r\n        );\r\n      } catch (e: unknown) {\r\n        toast.error(getErrorMessage(e) || 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬');\r\n      } finally {\r\n        setRunning(false);\r\n\r\n        // Desktop automation: request a clean Electron quit so dev-tests can complete\r\n        // without SIGTERM noise from the dev server. Fallback to window.close().\r\n        try {\r\n          const isDesktop = typeof window !== 'undefined' && !!window.desktopDb;\r\n          if (isDesktop) {\r\n            setTimeout(() => {\r\n              try {\r\n                const quit = (window.desktopDb as unknown as { quitApp?: () => Promise<unknown> })\r\n                  ?.quitApp;\r\n                if (typeof quit === 'function') {\r\n                  void quit();\r\n                  return;\r\n                }\r\n\r\n                window.close();\r\n              } catch {\r\n                // ignore\r\n              }\r\n            }, 900);\r\n          }\r\n        } catch {\r\n          // ignore\r\n        }\r\n      }\r\n    })();\r\n  }, [isAutorunEnabled, isIntegrationDataEnabled, results, running, toast]);\r\n\r\n  const handleResetAllData = useCallback(() => {\r\n    if (user?.в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’ !== 'SuperAdmin') {\r\n      toast.error('в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘвҢҗ в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎв•ӘвҢҗ в”ҳГӨв”ҳГӨв•Әв”Ӯв”ҳГӘв•ӘВҝв•Әв–’ в•ӘГәв•ӘВ»в”ҳГ в”ҳГҘ в”ҳГјв”ҳГ©в•Әв•–');\r\n      return;\r\n    }\r\n\r\n    openPanel('CONFIRM_MODAL', 'reset_all_data_step1', {\r\n      title: 'в•ӘВ¬в•ӘВЎв•Әв–‘в”ҳГЁв•Әв–’',\r\n      variant: 'danger',\r\n      confirmText: 'в”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗ',\r\n      message:\r\n        'О“ГңГЎвҲ©в••Г… в•ӘВ¬в•ӘВЎв•Әв–‘в”ҳГЁв•Әв–’: в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВЎв•Әв–‘в”ҳГј в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨв”ҳГЁв•ӘвҢҗ (в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’в•ӘВәв•ӘВ¬/в•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ»/в•ӘВ»в”ҳГјв•Әв•Јв•ӘВәв•ӘВ¬/в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘВәв•ӘВ¬/в•ӘВ¬в”ҳГҘв•ӘВҝв”ҳГЁв”ҳГ§в•ӘВәв•ӘВ¬/в•Әв”Ӯв•ӘВјв”ҳГӨв•ӘВәв•ӘВ¬... в•ӘГ‘в”ҳГӨв•ӘВ«) в”ҳГ в•Әв•Ј в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВҝв”ҳГ©в•ӘВәв•ӘГӯ в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ в”ҳГӘв•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬ в”ҳГӘв•ӘВәв”ҳГӨв”ҳГ©в”ҳГӘв•ӘВәв”ҳГӨв•ӘВҝ.\\n\\nв”ҳГ§в”ҳГӨ в•ӘВ¬в•Әв–’в”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗв•ӘЖ’',\r\n      onConfirm: () => {\r\n        openPanel('CONFIRM_MODAL', 'reset_all_data_step2', {\r\n          title: 'в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ',\r\n          variant: 'danger',\r\n          confirmText: 'в”ҳГҘв•Әв•Јв”ҳГ в•ӘГ® в•ӘВәв•ӘВЎв•Әв–‘в”ҳГј',\r\n          message: 'в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ: в”ҳГӨв•ӘВә в”ҳГЁв”ҳГӘв•ӘВјв•ӘВ» в•ӘВ¬в•Әв–’в•ӘВәв•ӘВјв•Әв•Ј (Undo). в”ҳГ§в”ҳГӨ в•ӘГәв”ҳГҘв•ӘВ¬ в”ҳГ в•ӘВ¬в•ӘГәв”ҳГўв•ӘВ» 100%в•ӘЖ’',\r\n          onConfirm: () => {\r\n            try {\r\n              const result = DbService.resetAllData?.();\r\n              if (result?.success === false) {\r\n                toast.error(result?.message || 'в”ҳГјв•Әв”Өв”ҳГӨ в”ҳГ в•Әв”Ӯв•ӘВЎ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬');\r\n                return;\r\n              }\r\n              toast.success(result?.message || 'в•ӘВ¬в”ҳГ  в”ҳГ в•Әв”Ӯв•ӘВЎ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ');\r\n              setTimeout(() => window.location.reload(), 800);\r\n            } catch (e: unknown) {\r\n              toast.error(getErrorMessage(e) || 'в”ҳГјв•Әв”Өв”ҳГӨ в”ҳГ в•Әв”Ӯв•ӘВЎ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬');\r\n            }\r\n          },\r\n        });\r\n      },\r\n    });\r\n  }, [openPanel, toast, user?.в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’]);\r\n\r\n  const summary = results\r\n    ? {\r\n        pass: results.filter((r) => r.status === 'PASS').length,\r\n        fail: results.filter((r) => r.status === 'FAIL').length,\r\n        skip: results.filter((r) => r.status === 'SKIP').length,\r\n      }\r\n    : null;\r\n\r\n  const resultsPageCount = Math.max(1, Math.ceil((results?.length ?? 0) / resultsPageSize));\r\n\r\n  useEffect(() => {\r\n    setResultsPage(1);\r\n  }, [results?.length]);\r\n\r\n  useEffect(() => {\r\n    setResultsPage((p) => Math.min(Math.max(1, p), resultsPageCount));\r\n  }, [resultsPageCount]);\r\n\r\n  const visibleResults = (results || []).slice(\r\n    (resultsPage - 1) * resultsPageSize,\r\n    resultsPage * resultsPageSize\r\n  );\r\n\r\n  return (\r\n    <div className=\"app-card p-8 rounded-3xl animate-slide-up space-y-6\">\r\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\r\n        <div className=\"flex items-start gap-3\">\r\n          <div className=\"p-3 bg-orange-100 dark:bg-orange-900/30 text-orange-600 rounded-xl\">\r\n            <Terminal size={24} />\r\n          </div>\r\n          <div>\r\n            <h3 className=\"text-xl font-bold text-slate-800 dark:text-white\">\r\n              в•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в•Әв”Ӯв”ҳГЁв”ҳГҘв•ӘВәв•Әв–’в”ҳГЁв”ҳГӘв”ҳГ§в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ \r\n            </h3>\r\n            <p className=\"text-sm text-slate-500 dark:text-slate-400 mt-2\">\r\n              в•ӘВәв”ҳГӨв”ҳГӘв•Әв•ўв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВәв”ҳГјв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв”ҳГЁ в•ӘГів”ҳГ в”ҳГҘ (в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в”ҳГјв”ҳГ©в•Әв•–) в”ҳГӘв”ҳГӨв•ӘВә в”ҳГЁв•Әв•ўв”ҳГЁв”ҳГј в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬. в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘв”ҳГў в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘГ‘в”ҳГҘв•Әв”Өв•ӘВәв•ӘГӯ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в•ӘГ‘в•Әв–‘в•ӘВә\r\n              в•Әв–’в•Әв•‘в•ӘВҝв•ӘВ¬.\r\n            </p>\r\n          </div>\r\n        </div>\r\n\r\n        <button\r\n          onClick={runTests}\r\n          disabled={running}\r\n          className=\"flex items-center gap-2 bg-orange-600 text-white px-4 py-2 rounded-xl text-sm font-bold hover:bg-orange-700 disabled:opacity-50 transition\"\r\n        >\r\n          {running ? (\r\n            <>\r\n              <RotateCcw size={16} className=\"animate-spin\" /> в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ...\r\n            </>\r\n          ) : (\r\n            <>\r\n              <Play size={16} /> в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬\r\n            </>\r\n          )}\r\n        </button>\r\n      </div>\r\n\r\n      <div className=\"app-card bg-slate-50 dark:bg-slate-900/30 border-slate-100 dark:border-slate-700 flex flex-col md:flex-row gap-4 md:items-center justify-between rounded-2xl p-4\">\r\n        <label className=\"flex items-center gap-3 text-sm font-bold text-slate-700 dark:text-slate-200\">\r\n          <input\r\n            type=\"checkbox\"\r\n            checked={allowMutation}\r\n            onChange={(e) => setAllowMutation(e.target.checked)}\r\n          />\r\n          в•ӘВәв”ҳГӨв•Әв”Ӯв”ҳГ в•ӘВәв•ӘВЎ в•ӘВҝв•ӘГ‘в”ҳГҘв•Әв”Өв•ӘВәв•ӘГӯ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ (в”ҳГЁв•Әв•‘в”ҳГЁв”ҳГҰв•Әв–’ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ )\r\n        </label>\r\n        <p className=\"text-xs text-slate-500 dark:text-slate-400\">\r\n          в”ҳГӨв•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в”ҳГ…в”ҳГӘв”ҳГӨв”ҳГҰв”ҳГүв•ӘВ»в•ӘвҢҗ в”ҳГӨв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГ©в•ӘВ» в•ӘВ¬в•ӘВЎв•ӘВ¬в•ӘВәв•ӘВј в•ӘГәв”ҳГЁв•Әв•ўв•ӘВәв”ҳГҜ в”ҳГӨв•Әв•ўв•ӘВҝв•Әв•–\r\n          `VITE_ENABLE_INTEGRATION_TEST_DATA=true` в•ӘГәв”ҳГӘ `window.ENABLE_INTEGRATION_TEST_DATA=true`.\r\n        </p>\r\n      </div>\r\n\r\n      {summary && (\r\n        <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\r\n          <div className=\"p-4 rounded-2xl border border-emerald-200 bg-emerald-50 dark:bg-emerald-900/10 dark:border-emerald-900/30\">\r\n            <div className=\"text-2xl font-black text-emerald-700 dark:text-emerald-400\">\r\n              {summary.pass}\r\n            </div>\r\n            <div className=\"text-xs font-bold text-emerald-800/70 dark:text-emerald-300/70\">\r\n              в”ҳГҘв•ӘВјв•ӘВЎ\r\n            </div>\r\n          </div>\r\n          <div className=\"p-4 rounded-2xl border border-red-200 bg-red-50 dark:bg-red-900/10 dark:border-red-900/30\">\r\n            <div className=\"text-2xl font-black text-red-700 dark:text-red-400\">{summary.fail}</div>\r\n            <div className=\"text-xs font-bold text-red-800/70 dark:text-red-300/70\">в”ҳГјв•Әв”Өв”ҳГӨ</div>\r\n          </div>\r\n          <div className=\"app-card p-4 rounded-2xl dark:bg-slate-900/10\">\r\n            <div className=\"text-2xl font-black text-slate-700 dark:text-slate-200\">\r\n              {summary.skip}\r\n            </div>\r\n            <div className=\"text-xs font-bold text-slate-500 dark:text-slate-400\">в•ӘВ¬в”ҳГ  в•ӘВ¬в•ӘВ«в•Әв•–в”ҳГЁв”ҳГ§</div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {!results ? (\r\n        <div className=\"text-sm text-slate-500 dark:text-slate-400\">\r\n          в•ӘВәв•Әв•ўв•Әв•‘в•Әв•– \"в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬\" в”ҳГӨв•ӘВҝв•ӘВ»в•ӘГӯ в”ҳГјв•ӘВЎв•Әв•Ў в•ӘВәв”ҳГӨв•Әв”Ӯв”ҳГЁв”ҳГҘв•ӘВәв•Әв–’в”ҳГЁв”ҳГӘв”ҳГ§в•ӘВәв•ӘВ¬.\r\n        </div>\r\n      ) : (\r\n        <div className=\"space-y-3\">\r\n          <PaginationControls\r\n            page={resultsPage}\r\n            pageCount={resultsPageCount}\r\n            onPageChange={setResultsPage}\r\n          />\r\n\r\n          {visibleResults.map((r) => (\r\n            <div key={r.id} className=\"app-card p-4 rounded-2xl bg-white dark:bg-slate-900/20\">\r\n              <div className=\"flex items-center justify-between gap-3\">\r\n                <div className=\"font-bold text-slate-800 dark:text-white text-sm\">{r.name}</div>\r\n                <StatusBadge\r\n                  status={r.status === 'PASS' ? 'в”ҳГҘв•ӘВјв•ӘВЎ' : r.status === 'FAIL' ? 'в”ҳГјв•Әв”Өв”ҳГӨ' : 'в•ӘВ¬в”ҳГ  в•ӘВ¬в•ӘВ«в•Әв•–в”ҳГЁв”ҳГ§'}\r\n                  className=\"text-[10px] px-2 py-1 rounded font-black\"\r\n                />\r\n              </div>\r\n              <div className=\"text-sm text-slate-600 dark:text-slate-300 mt-2\">{r.message}</div>\r\n              {typeof r.durationMs === 'number' && (\r\n                <div className=\"text-xs text-slate-400 mt-1\">\r\n                  в•ӘВәв”ҳГӨв”ҳГ в•ӘВ»в•ӘвҢҗ: {r.durationMs.toFixed(2)}ms\r\n                </div>\r\n              )}\r\n              {r.details && (\r\n                <details className=\"mt-3\">\r\n                  <summary className=\"text-xs font-bold text-slate-600 dark:text-slate-300 cursor-pointer\">\r\n                    в•ӘВ¬в”ҳГјв•ӘВәв•Әв•Ўв”ҳГЁв”ҳГӨ\r\n                  </summary>\r\n                  <pre className=\"mt-2 text-xs bg-slate-50 dark:bg-slate-900/40 p-3 rounded-xl overflow-auto border border-slate-100 dark:border-slate-700\">\r\n                    {JSON.stringify(r.details, null, 2)}\r\n                  </pre>\r\n                </details>\r\n              )}\r\n            </div>\r\n          ))}\r\n\r\n          {user?.в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’ === 'SuperAdmin' && (\r\n            <div className=\"bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900/30 rounded-2xl p-5\">\r\n              <div className=\"flex items-start justify-between gap-4\">\r\n                <div>\r\n                  <div className=\"text-sm font-black text-red-800 dark:text-red-300\">\r\n                    в”ҳГ в”ҳГҘв•Әв•–в”ҳГ©в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ«в•Әв•–в•Әв–’ (SuperAdmin)\r\n                  </div>\r\n                  <div className=\"text-xs text-red-700/80 dark:text-red-300/80 mt-1\">\r\n                    в”ҳГ в•Әв”Ӯв•ӘВЎ в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨв”ҳГЁв•ӘвҢҗ в”ҳГӘв•ӘГ‘в•ӘВҝв”ҳГ©в•ӘВәв•ӘГӯ в•ӘВ¬в”ҳГўв”ҳГӘв”ҳГЁв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв•ӘГәв•Әв”Ӯв•ӘВәв•Әв”Ӯв”ҳГЁв•ӘвҢҗ в”ҳГјв”ҳГ©в•Әв•–.\r\n                  </div>\r\n                </div>\r\n                <button\r\n                  onClick={handleResetAllData}\r\n                  className=\"bg-red-600 hover:bg-red-700 text-white font-bold px-4 py-2 rounded-xl text-sm flex items-center gap-2\"\r\n                >\r\n                  <Trash2 size={16} /> в”ҳГ в•Әв”Ӯв•ӘВЎ в”ҳГўв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬\r\n                </button>\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n});\r\n\r\n/* ========================= */\r\n/*    Database View (NEW)    */\r\n/* ========================= */\r\n\r\n/* ========================= */\r\n/*    Database View (Consolidated) */\r\n/* ========================= */\r\n\r\nconst FRIENDLY_NAMES: Record<string, string> = {\r\n  db_people: 'в•ӘВәв”ҳГӨв•ӘГәв•Әв”Өв•ӘВ«в•ӘВәв•Әв•Ў (People)',\r\n  db_properties: 'в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ (Properties)',\r\n  db_contracts: 'в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ» (Contracts)',\r\n  db_installments: 'в•ӘВәв”ҳГӨв”ҳГўв”ҳГ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ / в•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Јв•ӘВәв•ӘВ¬ (Installments)',\r\n  db_operations: 'в•Әв”Ӯв•ӘВјв”ҳГӨ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬ (Logs)',\r\n  db_users: 'в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ (Users)',\r\n  db_roles: 'в•ӘВәв”ҳГӨв•ӘГәв•ӘВ»в”ҳГӘв•ӘВәв•Әв–’ (Roles)',\r\n  db_user_permissions: 'в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ (User Permissions)',\r\n  db_settings: 'в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  (Settings)',\r\n  db_blacklist: 'в•ӘВәв”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв”Ӯв”ҳГӘв•ӘВ»в•ӘВәв•ӘГӯ (Blacklist)',\r\n  db_sales_listings: 'в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј (Sales Listings)',\r\n  db_sales_offers: 'в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ (Sales Offers)',\r\n  db_sales_agreements: 'в•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј (Sales Agreements)',\r\n  db_external_commissions: 'в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ«в•ӘВәв•Әв–’в•ӘВјв”ҳГЁв•ӘвҢҗ (External Commissions)',\r\n  db_ownership_history: 'в•Әв”Ӯв•ӘВјв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӨв”ҳГўв”ҳГЁв•ӘвҢҗ (Ownership History)',\r\n  db_maintenance_tickets: 'в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗ (Maintenance Tickets)',\r\n  db_attachments: 'в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГјв”ҳГ©в•ӘВәв•ӘВ¬ (Attachments)',\r\n  db_notes: 'в•ӘВәв”ҳГӨв”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬ (Notes)',\r\n  db_activities: 'в•ӘВәв”ҳГӨв”ҳГҘв•Әв”Өв•ӘВәв•Әв•–в•ӘВәв•ӘВ¬ (Activities)',\r\n  db_lookups: 'в•ӘВәв”ҳГӨв”ҳГ©в”ҳГӘв•ӘВәв•ӘВӘв”ҳГ  (Lookups)',\r\n  db_lookup_categories: 'в•ӘВ¬в•Әв•Ўв”ҳГҘв”ҳГЁв”ҳГјв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ©в”ҳГӘв•ӘВәв•ӘВӘв”ҳГ  (Lookup Categories)',\r\n  db_dynamic_tables: 'в•ӘВәв”ҳГӨв•ӘВјв•ӘВ»в•ӘВәв”ҳГӘв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГЁв”ҳГҘв•ӘВәв”ҳГ в”ҳГЁв”ҳГўв”ҳГЁв•ӘвҢҗ (Dynamic Tables)',\r\n  db_dynamic_records: 'в•Әв”Ӯв•ӘВјв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘВ»в”ҳГЁв”ҳГҘв•ӘВәв”ҳГ в”ҳГЁв”ҳГўв”ҳГЁв•ӘвҢҗ (Dynamic Records)',\r\n  db_dynamic_form_fields: 'в•ӘВЎв”ҳГ©в”ҳГӘв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ в•ӘВәв•Әв–‘в•ӘВј (Dynamic Fields)',\r\n  db_dashboard_config: 'в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в”ҳГӨв”ҳГӘв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ  (Dashboard Config)',\r\n  db_dashboard_notes: 'в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬ в”ҳГӨв”ҳГӘв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ  (Dashboard Notes)',\r\n  db_reminders: 'в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–‘в”ҳГўв”ҳГЁв•Әв–’в•ӘВәв•ӘВ¬ (Reminders)',\r\n  db_client_interactions: 'в•ӘВ¬в”ҳГјв•ӘВәв•Әв•Јв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв•ӘВәв•ӘГӯ (Client Interactions)',\r\n  db_followups: 'в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘВәв•ӘВ¬ (Follow-ups)',\r\n  db_notification_send_logs: 'в•Әв”Ӯв•ӘВјв”ҳГӨ в•ӘГ‘в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГҘв•ӘВҝв”ҳГЁв”ҳГ§в•ӘВәв•ӘВ¬ (Notification Send Logs)',\r\n  db_clearance_records: 'в•ӘВҝв•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв–‘в”ҳГ в•ӘвҢҗ (Clearance Records)',\r\n  db_legal_templates: 'в”ҳГ©в”ҳГӘв•ӘВәв”ҳГӨв•ӘВҝ в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв”ҳГЁв•ӘвҢҗ (Legal Templates)',\r\n  db_legal_history: 'в•Әв”Ӯв•ӘВјв”ҳГӨ в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв”ҳГЁ (Legal History)',\r\n  db_smart_behavior: 'в•Әв”Ӯв”ҳГӨв”ҳГӘв”ҳГў в•Әв–‘в”ҳГўв”ҳГЁ (Smart Behavior)',\r\n  theme: 'в•ӘВәв”ҳГӨв•ӘВҪв”ҳГЁв”ҳГ  (Theme)',\r\n  khaberni_onboarding_completed: 'в•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв–’в•Әв”Өв•ӘВәв•ӘВ» (Onboarding)',\r\n  ui_sales_edit_agreement_id: 'в•Әв–’в•ӘВҝв•Әв•– в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ в•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘвҢҗ в•ӘВҝв”ҳГЁв•Әв•Ј (Sales Deep Link)',\r\n  app_update_feed_url: 'в•Әв–’в•ӘВәв•ӘВҝв•Әв•– в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪв•ӘВәв•ӘВ¬ (Update Feed URL)',\r\n  audioConfig: 'в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӘв•ӘВ¬ (Audio Config)',\r\n  daily_scheduler_last_run: 'в•ӘГів•ӘВ«в•Әв–’ в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в”ҳГӨв”ҳГӨв•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГЁв”ҳГӘв”ҳГ в”ҳГЁв•ӘвҢҗ',\r\n  notification_templates: 'в”ҳГ©в”ҳГӘв•ӘВәв”ҳГӨв•ӘВҝ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв”Өв•Әв•Јв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ (Notification Templates)',\r\n  notificationLogs: 'в•Әв”Ӯв•ӘВјв”ҳГӨ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв”Өв•Әв•Јв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ (Notification Logs)',\r\n  dashboard_tasks: 'в”ҳГ в”ҳГ§в•ӘВәв”ҳГ  в”ҳГӨв”ҳГӘв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ  (Dashboard Tasks)',\r\n};\r\n\r\nconst KNOWN_ORDER = [\r\n  'db_people',\r\n  'db_properties',\r\n  'db_contracts',\r\n  'db_installments',\r\n  'db_users',\r\n  'db_roles',\r\n  'db_user_permissions',\r\n  'db_operations',\r\n  'db_settings',\r\n  'db_blacklist',\r\n  'db_sales_listings',\r\n  'db_sales_offers',\r\n  'db_sales_agreements',\r\n  'db_external_commissions',\r\n  'db_ownership_history',\r\n  'db_maintenance_tickets',\r\n  'db_attachments',\r\n  'db_notes',\r\n  'db_activities',\r\n  'db_lookups',\r\n  'db_lookup_categories',\r\n  'db_dynamic_tables',\r\n  'db_dynamic_records',\r\n  'db_dynamic_form_fields',\r\n  'db_dashboard_config',\r\n  'db_dashboard_notes',\r\n  'db_reminders',\r\n  'db_client_interactions',\r\n  'db_followups',\r\n  'db_notification_send_logs',\r\n  'db_clearance_records',\r\n  'db_legal_templates',\r\n  'db_legal_history',\r\n  'db_smart_behavior',\r\n  'theme',\r\n  'app_update_feed_url',\r\n  'audioConfig',\r\n  'notification_templates',\r\n  'notificationLogs',\r\n  'dashboard_tasks',\r\n  'daily_scheduler_last_run',\r\n  'khaberni_onboarding_completed',\r\n  'ui_sales_edit_agreement_id',\r\n];\r\n\r\nconst HIDDEN_KEYS = new Set(['demo_data_loaded']);\r\n\r\nconst DatabaseView = memo(() => {\r\n  const toast = useToast();\r\n  const { openPanel } = useSmartModal();\r\n  const [dbPath, setDbPath] = useState<string>('');\r\n  const [appVersion, setAppVersion] = useState<string>('');\r\n  const [installingFromFile, setInstallingFromFile] = useState<boolean>(false);\r\n  const [rebuilding, setRebuilding] = useState(false);\r\n  const [cacheTick, setCacheTick] = useState(0);\r\n  const [tables, setTables] = useState<Array<{ key: string; name: string; icon: LucideIcon; kind: 'db' | 'system' }>>([]);\r\n  const [tablesPage, setTablesPage] = useState(1);\r\n  const [dbStats, setDbStats] = useState<Record<string, number>>({});\r\n  const [resetLoading, setResetLoading] = useState(false);\r\n  const tablesPageSize = 10;\r\n\r\n  useEffect(() => {\r\n    if (window.desktopDb?.getPath) {\r\n      window.desktopDb.getPath().then(setDbPath).catch(() => {});\r\n    }\r\n    if (window.desktopUpdater?.getVersion) {\r\n      window.desktopUpdater.getVersion().then(setAppVersion).catch(() => {});\r\n    }\r\n    getDatabaseStats().then(setDbStats).catch(() => {});\r\n  }, []);\r\n\r\n  const refreshLocalStorageList = useCallback(() => {\r\n    try {\r\n      const keys = Array.from(new Set(Object.keys(localStorage))).filter((k) => !HIDDEN_KEYS.has(k));\r\n      const orderIndex = new Map<string, number>();\r\n      KNOWN_ORDER.forEach((k, i) => orderIndex.set(k, i));\r\n\r\n      const sorted = keys.sort((a, b) => {\r\n        const ai = orderIndex.has(a) ? (orderIndex.get(a) as number) : Number.MAX_SAFE_INTEGER;\r\n        const bi = orderIndex.has(b) ? (orderIndex.get(b) as number) : Number.MAX_SAFE_INTEGER;\r\n        if (ai !== bi) return ai - bi;\r\n        return a.localeCompare(b);\r\n      });\r\n\r\n      setTables(\r\n        sorted.map((k) => {\r\n          const kind: 'db' | 'system' = k.startsWith('db_') ? 'db' : 'system';\r\n          const name = FRIENDLY_NAMES[k] ?? (kind === 'db' ? `в•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ: ${k}` : `в”ҳГ в”ҳГјв•ӘВ¬в•ӘВәв•ӘВЎ: ${k}`);\r\n          const icon = kind === 'db' ? Table : Key;\r\n          return { key: k, name, icon, kind };\r\n        })\r\n      );\r\n    } catch {\r\n      setTables([]);\r\n    }\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    refreshLocalStorageList();\r\n  }, [refreshLocalStorageList]);\r\n\r\n  const handleRebuildIndexes = () => {\r\n    setRebuilding(true);\r\n    setTimeout(() => {\r\n      buildCache();\r\n      setCacheTick((t) => t + 1);\r\n      setRebuilding(false);\r\n      toast.success('в•ӘВ¬в”ҳГ  в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВҝв”ҳГҘв•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГјв”ҳГ§в•ӘВәв•Әв–’в•Әв”Ӯ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ');\r\n    }, 1000);\r\n  };\r\n\r\n  const handleClearKey = async (key: string) => {\r\n    const ok = await toast.confirm({\r\n      title: 'в•ӘВ¬в•ӘВЎв•Әв–‘в”ҳГЁв•Әв–’',\r\n      message: `в”ҳГ§в”ҳГӨ в•ӘГәв”ҳГҘв•ӘВ¬ в”ҳГ в•ӘВ¬в•ӘГәв”ҳГўв•ӘВ» в”ҳГ в”ҳГҘ в”ҳГ в•Әв”Ӯв•ӘВЎ в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ (${key})в•ӘЖ’ в”ҳГӨв•ӘВә в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВәв•ӘВјв•Әв•Ј.`,\r\n      confirmText: 'в”ҳГ в•Әв”Ӯв•ӘВЎ',\r\n      cancelText: 'в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ',\r\n      isDangerous: true,\r\n    });\r\n    if (ok) {\r\n      if (key.startsWith('db_')) {\r\n        await storage.setItem(key, '[]');\r\n      } else {\r\n        localStorage.removeItem(key);\r\n      }\r\n      buildCache();\r\n      setCacheTick((t) => t + 1);\r\n      refreshLocalStorageList();\r\n      toast.success('в•ӘВ¬в”ҳГ  в”ҳГ в•Әв”Ӯв•ӘВЎ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ');\r\n    }\r\n  };\r\n\r\n  const getSize = (key: string) => {\r\n    const data = localStorage.getItem(key);\r\n    return data ? (data.length / 1024).toFixed(1) + ' KB' : '0 KB';\r\n  };\r\n\r\n  const getCount = (key: string) => {\r\n    const raw = localStorage.getItem(key);\r\n    if (!raw) return '0';\r\n    try {\r\n      const parsed = JSON.parse(raw);\r\n      return Array.isArray(parsed) ? String(parsed.length) : '1';\r\n    } catch {\r\n      return '1';\r\n    }\r\n  };\r\n\r\n  const doInstallFromFile = async () => {\r\n    if (!window.desktopUpdater?.installFromFile) {\r\n      toast.warning('в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎ в”ҳГјв”ҳГ©в•Әв•– в”ҳГјв”ҳГЁ в”ҳГӘв•Әв•ўв•Әв•Ј Desktop');\r\n      return;\r\n    }\r\n    setInstallingFromFile(true);\r\n    try {\r\n      await window.desktopUpdater.installFromFile();\r\n    } catch (e: unknown) {\r\n      toast.error(getErrorMessage(e) || 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬');\r\n    } finally {\r\n      setInstallingFromFile(false);\r\n    }\r\n  };\r\n  \r\n  const handleResetToFresh = async () => {\r\n    const ok = await toast.confirm({\r\n      title: 'в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВ¬в”ҳГ§в”ҳГЁв•ӘВӘв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ ',\r\n      message: 'в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВЎв•Әв–‘в”ҳГј в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВЎв•ӘВ¬в”ҳГјв•ӘВәв•Әв•• в•ӘВҝв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  admin в”ҳГјв”ҳГ©в•Әв•–. в”ҳГ§в”ҳГӨ в•ӘГәв”ҳГҘв•ӘВ¬ в”ҳГ в•ӘВ¬в•ӘГәв”ҳГўв•ӘВ»в•ӘЖ’ в•ӘВәв”ҳГўв•ӘВ¬в•ӘВҝ \"в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВ¬в”ҳГ§в”ҳГЁв•ӘВӘв•ӘвҢҗ\" в”ҳГӨв”ҳГӨв•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ».',\r\n      confirmText: 'в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј',\r\n      cancelText: 'в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ',\r\n      isDangerous: true,\r\n      requireTextInput: 'в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВ¬в”ҳГ§в”ҳГЁв•ӘВӘв•ӘвҢҗ'\r\n    });\r\n    \r\n    if (ok) {\r\n      setResetLoading(true);\r\n      try {\r\n        const res = await resetToFreshState();\r\n        if (res.success) {\r\n          toast.success(res.message);\r\n          setTimeout(() => window.location.reload(), 1500);\r\n        } else {\r\n          toast.error(res.message);\r\n        }\r\n      } finally {\r\n        setResetLoading(false);\r\n      }\r\n    }\r\n  };\r\n\r\n  const handleClearAll = async () => {\r\n    const ok = await toast.confirm({\r\n      title: 'в•ӘВЎв•Әв–‘в”ҳГј в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв”ҳГҜ',\r\n      message: 'О“ГңГЎвҲ©в••Г… в•ӘВ¬в•ӘВЎв•Әв–‘в”ҳГЁв•Әв–’: в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВЎв•Әв–‘в”ҳГј в”ҳГўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘВјв”ҳГӨв•ӘВәв•ӘВ¬ в”ҳГӘв•ӘВәв”ҳГӨв”ҳГ в”ҳГӨв”ҳГјв•ӘВәв•ӘВ¬ в”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв”ҳГҜ. в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в”ҳГўв•ӘВ¬в•ӘВәв•ӘВҝв•ӘвҢҗ \"в•ӘВЎв•Әв–‘в”ҳГј в”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ\" в”ҳГӨв”ҳГӨв•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ».',\r\n      confirmText: 'в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв”ҳГӨв”ҳГўв”ҳГӨ',\r\n      cancelText: 'в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ',\r\n      isDangerous: true,\r\n      requireTextInput: 'в•ӘВЎв•Әв–‘в”ҳГј в”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ'\r\n    });\r\n    \r\n    if (ok) {\r\n      setResetLoading(true);\r\n      try {\r\n        const res = await clearAllData();\r\n        if (res.success) {\r\n          toast.success(res.message);\r\n          setTimeout(() => window.location.reload(), 1500);\r\n        } else {\r\n          toast.error(res.message);\r\n        }\r\n      } finally {\r\n        setResetLoading(false);\r\n      }\r\n    }\r\n  };\r\n\r\n  const isDesktop = !!window.desktopDb;\r\n  const visibleTables = tables.slice((tablesPage - 1) * tablesPageSize, tablesPage * tablesPageSize);\r\n  const tablesPageCount = Math.ceil(tables.length / tablesPageSize);\r\n\r\n  return (\r\n    <div className=\"space-y-8 animate-fade-in pb-10\">\r\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\r\n        <div className=\"lg:col-span-2 space-y-6\">\r\n          <div className=\"app-card p-6 rounded-3xl space-y-6\">\r\n            <div className=\"flex items-center justify-between gap-4\">\r\n              <div className=\"flex items-start gap-3\">\r\n                <div className=\"p-3 bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 rounded-xl\">\r\n                  <Database size={24} />\r\n                </div>\r\n                <div>\r\n                  <h3 className=\"text-xl font-bold text-slate-800 dark:text-white\">в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в”ҳГўв•ӘВәв•Әв”Ө в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в”ҳГӘв•ӘВәв”ҳГӨв•ӘВјв•ӘВ»в•ӘВәв”ҳГӘв”ҳГӨ</h3>\r\n                  <p className=\"text-sm text-slate-500 dark:text-slate-400 mt-1\">в•Әв•Јв•Әв–’в•Әв•ў в•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв”ҳГӨв”ҳГЁв•ӘвҢҗ (LocalStorage) в”ҳГӘв•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГјв”ҳГ§в•ӘВәв•Әв–’в•Әв”Ӯ.</p>\r\n                </div>\r\n              </div>\r\n              <button\r\n                onClick={handleRebuildIndexes}\r\n                disabled={rebuilding}\r\n                className=\"flex items-center gap-2 bg-indigo-600 text-white px-4 py-2 rounded-xl text-sm font-bold hover:bg-indigo-700 disabled:opacity-50 transition\"\r\n              >\r\n                <RefreshCw size={16} className={rebuilding ? 'animate-spin' : ''} />\r\n                {rebuilding ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГҘв•ӘВәв•ӘГӯ...' : 'в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВҝв”ҳГҘв•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГјв”ҳГ§в•ӘВәв•Әв–’в•Әв”Ӯ'}\r\n              </button>\r\n            </div>\r\n\r\n            <div className=\"app-table-wrapper rounded-2xl border border-slate-100 dark:border-slate-800\">\r\n              <table className=\"app-table\">\r\n                <thead className=\"app-table-thead\">\r\n                  <tr>\r\n                    <th className=\"app-table-th\">в•ӘВәв”ҳГӨв•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ</th>\r\n                    <th className=\"app-table-th text-center\">в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘВјв”ҳГӨв•ӘВәв•ӘВ¬</th>\r\n                    <th className=\"app-table-th text-center\">в•ӘВәв”ҳГӨв•ӘВЎв•ӘВјв”ҳГ </th>\r\n                    <th className=\"app-table-th text-center\">в•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯ</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody className=\"divide-y divide-slate-100/50 dark:divide-slate-800/50\">\r\n                  {visibleTables.map((t) => (\r\n                    <tr key={t.key} className=\"app-table-row group\">\r\n                      <td className=\"app-table-td\">\r\n                        <div className=\"flex items-center gap-2\">\r\n                          <t.icon size={14} className=\"text-slate-400\" />\r\n                          <div className=\"flex flex-col\">\r\n                            <span className=\"text-sm font-bold text-slate-700 dark:text-slate-200\">{t.name}</span>\r\n                            <span className=\"text-[10px] text-slate-400 font-mono\">{t.key}</span>\r\n                          </div>\r\n                        </div>\r\n                      </td>\r\n                      <td className=\"app-table-td text-center font-mono text-xs\">{getCount(t.key)}</td>\r\n                      <td className=\"app-table-td text-center font-mono text-xs text-slate-400\">{getSize(t.key)}</td>\r\n                      <td className=\"app-table-td\">\r\n                        <div className=\"flex justify-center opacity-0 group-hover:opacity-100 transition-opacity\">\r\n                          <button onClick={() => handleClearKey(t.key)} className=\"p-1.5 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition\" title=\"в”ҳГ в•Әв”Ӯв•ӘВЎ\">\r\n                            <Trash2 size={14} />\r\n                          </button>\r\n                        </div>\r\n                      </td>\r\n                    </tr>\r\n                  ))}\r\n                </tbody>\r\n              </table>\r\n              <div className=\"p-3 border-t border-slate-100 dark:border-slate-800\">\r\n                <PaginationControls page={tablesPage} pageCount={tablesPageCount} onPageChange={setTablesPage} />\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"space-y-6\">\r\n          {/* Desktop Info */}\r\n          {isDesktop && (\r\n            <div className=\"app-card p-6 rounded-3xl space-y-4\">\r\n              <h4 className=\"font-bold text-slate-800 dark:text-white flex items-center gap-2\">\r\n                <HardDrive size={18} className=\"text-indigo-600\" />\r\n                в”ҳГ в•Әв•Јв”ҳГӨв”ҳГӘв”ҳГ в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВәв•Әв–’ в”ҳГӘв•ӘВәв”ҳГӨв”ҳГҘв•Әв”Ӯв•ӘВ«в•ӘвҢҗ\r\n              </h4>\r\n              <div className=\"space-y-3\">\r\n                <div>\r\n                  <p className=\"text-[10px] font-bold text-slate-400 uppercase\">в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в”ҳГ©в•ӘВәв•Әв•Јв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬</p>\r\n                  <p className=\"text-xs font-mono text-slate-600 dark:text-slate-300 bg-slate-50 dark:bg-slate-900/40 p-2 rounded-lg mt-1 break-all border border-slate-100 dark:border-slate-800\">\r\n                    {dbPath || 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВ¬в”ҳГӘв”ҳГјв•Әв–’'}\r\n                  </p>\r\n                </div>\r\n                <div>\r\n                  <p className=\"text-[10px] font-bold text-slate-400 uppercase\">в•ӘГ‘в•Әв•Ўв•ӘВ»в•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв•–в•ӘВҝв”ҳГЁв”ҳГ©</p>\r\n                  <p className=\"text-sm font-black text-indigo-600 mt-1\">{appVersion || 'О“ГҮГ¶'}</p>\r\n                </div>\r\n              </div>\r\n              <button\r\n                onClick={doInstallFromFile}\r\n                disabled={installingFromFile}\r\n                className=\"w-full bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-white py-3 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition disabled:opacity-50\"\r\n              >\r\n                <Upload size={16} />\r\n                в•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬ в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ в”ҳГ в”ҳГҘ в”ҳГ в”ҳГӨв”ҳГј\r\n              </button>\r\n            </div>\r\n          )}\r\n\r\n          <div className=\"app-card p-6 rounded-3xl space-y-4 border-2 border-red-100 dark:border-red-900/30\">\r\n            <h4 className=\"font-bold text-red-600 dark:text-red-400 flex items-center gap-2\">\r\n              <AlertTriangle size={18} />\r\n              в”ҳГ в”ҳГҘв•Әв•–в”ҳГ©в•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ«в•Әв•–в•Әв–’в•ӘвҢҗ\r\n            </h4>\r\n            <div className=\"space-y-3\">\r\n              <button\r\n                onClick={handleResetToFresh}\r\n                disabled={resetLoading}\r\n                className=\"w-full bg-emerald-50 dark:bg-emerald-900/20 hover:bg-emerald-100 dark:hover:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 py-3 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition disabled:opacity-50 border border-emerald-100 dark:border-emerald-900/30\"\r\n              >\r\n                <RefreshCw size={16} className={resetLoading ? 'animate-spin' : ''} />\r\n                в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВ¬в”ҳГ§в”ҳГЁв•ӘВӘв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  (Fresh)\r\n              </button>\r\n              <button\r\n                onClick={handleClearAll}\r\n                disabled={resetLoading}\r\n                className=\"w-full bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-900/40 text-red-700 dark:text-red-300 py-3 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition disabled:opacity-50 border border-red-100 dark:border-red-900/30\"\r\n              >\r\n                <Trash2 size={16} />\r\n                в•ӘВЎв•Әв–‘в”ҳГј в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬\r\n              </button>\r\n            </div>\r\n            <p className=\"text-[10px] text-slate-400 leading-relaxed text-center\">\r\n              * в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬ в•ӘГәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГ§ в•ӘВ¬в•Әв•‘в”ҳГЁв•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•ӘВҝв•Әв”Өв”ҳГўв”ҳГӨ в”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ в”ҳГӘв”ҳГӨв•ӘВә в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВәв•ӘВјв•Әв•Ј в•Әв•Јв”ҳГҘв”ҳГ§в•ӘВә.\r\n            </p>\r\n          </div>\r\n\r\n          <div className=\"app-card p-6 rounded-3xl bg-indigo-50 dark:bg-indigo-900/10 border border-indigo-100 dark:border-indigo-900/30\">\r\n            <div className=\"flex gap-3 text-indigo-800 dark:text-indigo-300\">\r\n              <Key size={20} className=\"shrink-0\" />\r\n              <div className=\"text-xs leading-relaxed\">\r\n                <p className=\"font-bold mb-1\">в•ӘВ¬в”ҳГӨв”ҳГ в”ҳГЁв•ӘВЎ (в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘВјв”ҳГӨв•ӘВәв•ӘВ¬: {Object.values(dbStats).reduce((a,b)=>a+b, 0)}):</p>\r\n                в”ҳГЁв•ӘВ¬в”ҳГ  в”ҳГ в•Әв–“в•ӘВәв”ҳГ в”ҳГҘв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘГәв•Әв”Ӯв•ӘВәв•Әв”Ӯв”ҳГЁв•ӘвҢҗ в”ҳГ в•Әв•Ј в•ӘВәв”ҳГӨв”ҳГ в•ӘВ«в•ӘВ»в”ҳГ  в•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв”ҳГҜ в•ӘГ‘в•Әв–‘в•ӘВә в”ҳГўв•ӘВәв”ҳГҘ в”ҳГ в”ҳГјв•Әв•Јв”ҳГӨ. в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ«в•ӘВ»в”ҳГ  в”ҳГ в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ»в•ӘвҢҗ в”ҳГјв”ҳГЁ \"в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв•Јв•ӘВәв”ҳГ в•ӘвҢҗ\".\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n});\r\n\r\n/* ========================= */\r\n/*     Main Component        */\r\n/* ========================= */\r\n\r\nexport const SystemMaintenance: React.FC = () => {\r\n  const isDesktopFast = typeof window !== 'undefined' && !!window.desktopDb;\r\n  const [health, setHealth] = useState<SystemHealth | null>(null);\r\n  const [predictiveInsight, setPredictiveInsight] = useState<PredictiveInsight | null>(null);\r\n  const [performanceReport, setPerformanceReport] = useState<PerformanceRow[] | null>(null);\r\n  const [loading, setLoading] = useState<boolean>(true);\r\n  const [optimizing, setOptimizing] = useState<boolean>(false);\r\n  const [activeTab, setActiveTab] = useState<TabKey>(() => {\r\n    const flag = (import.meta as unknown as ViteMeta)?.env?.VITE_AUTORUN_SYSTEM_TESTS;\r\n    const enabled = typeof flag === 'string' ? flag.toLowerCase() === 'true' : !!flag;\r\n    return enabled ? 'testing' : 'diagnostics';\r\n  });\r\n\r\n  const toast = useToast();\r\n\r\n  const dbSignal = useDbSignal();\r\n\r\n  const buildHealthFromValidation = useCallback((): SystemHealth => {\r\n    const validation = validateAllData();\r\n    const integrityWarnings = validation.warnings.length;\r\n    const logicErrors = validation.errors.length;\r\n\r\n    // Orphans isn't directly reported; approximate via FK errors count\r\n    const orphans = validation.errors.filter((e) => e.includes('в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ»')).length;\r\n\r\n    const score = Math.max(0, Math.min(100, 100 - (logicErrors * 10 + integrityWarnings * 3)));\r\n    const status: SystemHealth['status'] =\r\n      score >= 90 ? 'Excellent' : score >= 75 ? 'Good' : score >= 55 ? 'Warning' : 'Critical';\r\n\r\n    const categorize = (msg: string) => {\r\n      if (msg.startsWith('в•ӘВ¬в”ҳГўв•Әв–’в•ӘВәв•Әв–’')) return 'в”ҳГјв”ҳГ§в•Әв–’в•Әв”Ӯв•ӘвҢҗ/в•ӘВ¬в”ҳГўв•Әв–’в•ӘВәв•Әв–’';\r\n      if (msg.includes('в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ»')) return 'в•Әв•Јв”ҳГӨв•ӘВәв”ҳГ©в•ӘВәв•ӘВ¬/в•Әв–’в•ӘВҝв•Әв•–';\r\n      if (msg.includes('в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«')) return 'в•ӘВ¬в”ҳГӘв•ӘВәв•Әв–’в”ҳГЁв•ӘВ«';\r\n      if (msg.includes('в”ҳГ в•ӘВ»в•ӘвҢҗ')) return 'в”ҳГ в”ҳГҘв•Әв•–в”ҳГ©/в”ҳГ в•ӘВ»в•ӘвҢҗ';\r\n      return 'в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬';\r\n    };\r\n\r\n    const issues: SystemHealth['issues'] = [\r\n      ...validation.errors.map((e, idx) => ({\r\n        id: `E-${idx}`,\r\n        type: 'Critical' as const,\r\n        category: categorize(e),\r\n        description: e,\r\n      })),\r\n      ...validation.warnings.map((w, idx) => ({\r\n        id: `W-${idx}`,\r\n        type: 'Warning' as const,\r\n        category: categorize(w),\r\n        description: w,\r\n      })),\r\n    ];\r\n\r\n    return {\r\n      score,\r\n      status,\r\n      issues,\r\n      stats: {\r\n        integrityWarnings,\r\n        orphans,\r\n        logicErrors,\r\n      },\r\n    };\r\n  }, []);\r\n\r\n  const buildPredictiveFromData = useCallback((): PredictiveInsight => {\r\n    const today = new Date();\r\n    const contracts = DbService.getContracts() as в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ»_tbl[];\r\n    const installments = DbService.getInstallments() as в•ӘВәв”ҳГӨв”ҳГўв”ҳГ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬_tbl[];\r\n\r\n    const lateInstallments = installments.filter((inst) => {\r\n      const dueDate = new Date(inst.в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«_в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВЎв”ҳГ©в•ӘВәв”ҳГ©);\r\n      return inst.в•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГўв”ҳГ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГӨв•ӘвҢҗ !== 'в”ҳГ в•ӘВ»в”ҳГјв”ҳГӘв•Әв•Ј' && dueDate < today;\r\n    });\r\n\r\n    const expiringContracts = contracts.filter((c) => {\r\n      const endDate = new Date(c.в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв”ҳГЁв•ӘвҢҗ);\r\n      const daysUntil = Math.ceil((endDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));\r\n      return isTenancyRelevant(c) && daysUntil > 0 && daysUntil <= 30;\r\n    });\r\n\r\n    const riskFactors = [\r\n      { category: 'LatePayments', count: lateInstallments.length, percentage: 0 },\r\n      { category: 'ExpiringContracts', count: expiringContracts.length, percentage: 0 },\r\n    ].filter((r) => r.count > 0);\r\n\r\n    const totalRisk = riskFactors.reduce((s, r) => s + r.count, 0);\r\n    const normalized = riskFactors.map((r) => ({\r\n      ...r,\r\n      percentage: totalRisk > 0 ? Math.round((r.count / totalRisk) * 100) : 0,\r\n    }));\r\n\r\n    const score = Math.max(\r\n      0,\r\n      Math.min(100, 100 - (lateInstallments.length * 4 + expiringContracts.length * 2))\r\n    );\r\n    const status: PredictiveInsight['status'] = score >= 70 ? 'Safe' : 'Risk';\r\n    const trend: PredictiveInsight['trend'] =\r\n      totalRisk === 0 ? 'Improving' : score >= 70 ? 'Stable' : 'Declining';\r\n\r\n    const recommendations: string[] = [];\r\n    if (lateInstallments.length > 0)\r\n      recommendations.push(\r\n        `в”ҳГЁв”ҳГӘв•ӘВјв•ӘВ» ${lateInstallments.length} в•ӘВ»в”ҳГјв•Әв•Јв•ӘвҢҗ в”ҳГ в•ӘВ¬в•ӘГәв•ӘВ«в•Әв–’в•ӘвҢҗ. в•Әв–’в•ӘВәв•ӘВјв•Әв•Ј в•Әв•Ўв”ҳГјв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГўв”ҳГ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в”ҳГӘв•ӘВәв•ӘВ¬в•ӘВ«в•Әв–‘ в•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯ в”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗ.`\r\n      );\r\n    if (expiringContracts.length > 0)\r\n      recommendations.push(\r\n        `в”ҳГЁв”ҳГӘв•ӘВјв•ӘВ» ${expiringContracts.length} в•Әв•Јв”ҳГ©в•ӘВ» в•Әв”Ӯв”ҳГЁв”ҳГҘв•ӘВ¬в”ҳГ§в”ҳГЁ в•ӘВ«в”ҳГӨв•ӘВәв”ҳГӨ 30 в”ҳГЁв”ҳГӘв”ҳГ . в•ӘВәв•ӘВҝв•ӘВ»в•ӘГә в•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ» в”ҳГ в•ӘВҝв”ҳГўв•Әв–’в•ӘВәв”ҳГҜ.`\r\n      );\r\n    if (recommendations.length === 0)\r\n      recommendations.push('в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в”ҳГ в•ӘВ«в•ӘВәв•Әв•–в•Әв–’ в”ҳГӘв•ӘВәв•Әв•ўв•ӘВЎв•ӘвҢҗ в•ӘВЎв•ӘВәв”ҳГӨв”ҳГЁв•ӘВәв”ҳГҜ. в•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳГ в•Әв–’ в•ӘВҝв•ӘВәв”ҳГӨв”ҳГ в•Әв–’в•ӘВәв”ҳГ©в•ӘВҝв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’в”ҳГЁв•ӘвҢҗ.');\r\n\r\n    return {\r\n      score,\r\n      status,\r\n      trend,\r\n      riskFactors: normalized,\r\n      recommendations,\r\n    };\r\n  }, []);\r\n\r\n  const runCheck = useCallback(() => {\r\n    if (isDesktopFast) {\r\n      const ok = window.confirm(\r\n        'в•ӘВ¬в”ҳГҘв•ӘВҝв”ҳГЁв”ҳГ§: в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў в•ӘВәв”ҳГӨв•Әв”Өв•ӘВәв”ҳГ в”ҳГӨ в”ҳГ©в•ӘВ» в”ҳГЁв”ҳГўв”ҳГӘв”ҳГҘ в•ӘВҪв”ҳГ©в”ҳГЁв”ҳГӨв•ӘВәв”ҳГҜ в•ӘВјв•ӘВ»в•ӘВәв”ҳГҜ в•Әв•Јв”ҳГӨв”ҳГ« в”ҳГ©в”ҳГӘв•ӘВәв•Әв•Јв•ӘВ» в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГўв•ӘВҝв”ҳГЁв•Әв–’в•ӘвҢҗ (200k+).\\n\\nв”ҳГ§в”ҳГӨ в•ӘВ¬в•Әв–’в”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗв•ӘЖ’'\r\n      );\r\n      if (!ok) {\r\n        setHealth({\r\n          score: 75,\r\n          status: 'Warning',\r\n          issues: [\r\n            {\r\n              id: 'desktop-fast-skip',\r\n              type: 'Warning',\r\n              category: 'в•ӘВәв”ҳГӨв•ӘГәв•ӘВ»в•ӘВәв•ӘГӯ',\r\n              description:\r\n                'в•ӘВ¬в”ҳГ  в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў в•ӘВәв”ҳГӨв•Әв”Өв•ӘВәв”ҳГ в”ҳГӨ в”ҳГӨв•ӘВ¬в•ӘВјв”ҳГҘв•ӘВҝ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ/в•ӘВ¬в•ӘВјв”ҳГ в”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГўв•ӘВҝв”ҳГЁв•Әв–’в•ӘвҢҗ в”ҳГјв”ҳГЁ в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВ»в”ҳГЁв•Әв”Ӯв”ҳГўв•ӘВ¬в”ҳГӘв•ӘВҝ в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј.',\r\n            },\r\n          ],\r\n          stats: { integrityWarnings: 0, orphans: 0, logicErrors: 0 },\r\n        });\r\n        setPredictiveInsight({\r\n          score: 75,\r\n          status: 'Safe',\r\n          trend: 'Stable',\r\n          riskFactors: [],\r\n          recommendations: [\r\n            'в”ҳГ©в”ҳГ  в•ӘВҝв•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў в”ҳГЁв•ӘВ»в”ҳГӘв”ҳГЁв•ӘВәв”ҳГҜ в•Әв•Јв”ҳГҘв•ӘВ» в•ӘВәв”ҳГӨв•ӘВЎв•ӘВәв•ӘВјв•ӘвҢҗ (в”ҳГ©в•ӘВ» в”ҳГЁв•Әв”Ӯв•ӘВ¬в•Әв•‘в•Әв–’в”ҳГ© в”ҳГӘв”ҳГ©в•ӘВ¬в•ӘВәв”ҳГҜ в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГўв•ӘВҝв”ҳГЁв•Әв–’в•ӘвҢҗ).',\r\n          ],\r\n        });\r\n        setLoading(false);\r\n        return;\r\n      }\r\n    }\r\n    setActiveTab('diagnostics');\r\n    setLoading(true);\r\n\r\n    // Ensure loading screen is visible at least one frame\r\n    requestAnimationFrame(() => {\r\n      try {\r\n        const healthResult = buildHealthFromValidation();\r\n        const predictiveResult = buildPredictiveFromData();\r\n        setHealth(healthResult);\r\n        setPredictiveInsight(predictiveResult);\r\n      } catch (e: unknown) {\r\n        toast.error(getErrorMessage(e) || 'в•ӘВЎв•ӘВ»в•ӘВҪ в•ӘВ«в•Әв•–в•ӘГә в•ӘГәв•ӘВҪв”ҳГҘв•ӘВәв•ӘГӯ в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў');\r\n      } finally {\r\n        setLoading(false);\r\n      }\r\n    });\r\n  }, [buildHealthFromValidation, buildPredictiveFromData, isDesktopFast, toast]);\r\n\r\n  const runPerfTest = useCallback(() => {\r\n    if (isDesktopFast) {\r\n      const ok = window.confirm(\r\n        'в•ӘВ¬в”ҳГҘв•ӘВҝв”ҳГЁв”ҳГ§: в•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•ӘГәв•ӘВ»в•ӘВәв•ӘГӯ в”ҳГЁв”ҳГ©в”ҳГӘв”ҳГ  в•ӘВҝв”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘВәв•ӘВ¬ в”ҳГўв•ӘВәв”ҳГ в”ҳГӨв•ӘвҢҗ в”ҳГӨв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГӘв”ҳГ©в•ӘВ» в”ҳГЁв•Әв”Ӯв•ӘВҝв•ӘВҝ в•ӘВ¬в•ӘВјв”ҳГ в•ӘВ» в”ҳГ в•ӘГұв”ҳГ©в•ӘВ¬ в•Әв•Јв”ҳГӨв”ҳГ« в”ҳГ©в”ҳГӘв•ӘВәв•Әв•Јв•ӘВ» в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГўв•ӘВҝв”ҳГЁв•Әв–’в•ӘвҢҗ.\\n\\nв”ҳГ§в”ҳГӨ в•ӘВ¬в•Әв–’в”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗв•ӘЖ’'\r\n      );\r\n      if (!ok) return;\r\n    }\r\n    setLoading(true);\r\n    try {\r\n      // Measure a few representative reads to build a simple, real report\r\n      const measure = (name: string, fn: () => void): PerformanceRow => {\r\n        const t0 = performance.now();\r\n        fn();\r\n        const t1 = performance.now();\r\n        // \"after\" is a second run to capture cache effects\r\n        const t2 = performance.now();\r\n        fn();\r\n        const t3 = performance.now();\r\n        return { name, before: t1 - t0, after: t3 - t2 };\r\n      };\r\n\r\n      const report: PerformanceRow[] = [\r\n        measure('в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГәв•Әв”Өв•ӘВ«в•ӘВәв•Әв•Ў', () => {\r\n          DbService.getPeople();\r\n        }),\r\n        measure('в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’в•ӘВәв•ӘВ¬', () => {\r\n          DbService.getProperties();\r\n        }),\r\n        measure('в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ»', () => {\r\n          DbService.getContracts();\r\n        }),\r\n        measure('в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГўв”ҳГ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬', () => {\r\n          DbService.getInstallments();\r\n        }),\r\n        measure('в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГҘв•ӘВҝв”ҳГЁв”ҳГ§в•ӘВәв•ӘВ¬', () => {\r\n          DbService.getAlerts();\r\n        }),\r\n      ];\r\n\r\n      setPerformanceReport(report);\r\n      setActiveTab('performance');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [isDesktopFast]);\r\n\r\n  const handleAutoFix = useCallback(() => {\r\n    setOptimizing(true);\r\n    try {\r\n      const result = DbService.optimizeSystem();\r\n      toast.success(result.message);\r\n      runCheck();\r\n    } finally {\r\n      setOptimizing(false);\r\n    }\r\n  }, [runCheck, toast]);\r\n\r\n  useEffect(() => {\r\n    // Avoid auto-running heavy checks in Desktop fast mode.\r\n    if (!isDesktopFast) {\r\n      runCheck();\r\n      return;\r\n    }\r\n\r\n    setHealth({\r\n      score: 85,\r\n      status: 'Good',\r\n      issues: [\r\n        {\r\n          id: 'desktop-fast-note',\r\n          type: 'Warning',\r\n          category: 'в•ӘВәв”ҳГӨв•ӘГәв•ӘВ»в•ӘВәв•ӘГӯ',\r\n          description:\r\n            'в•ӘВ¬в”ҳГ  в•ӘВ¬в•Әв•Јв•Әв•–в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁ в”ҳГјв”ҳГЁ в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВ»в”ҳГЁв•Әв”Ӯв”ҳГўв•ӘВ¬в”ҳГӘв•ӘВҝ в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј в”ҳГӨв•ӘВ¬в•ӘВјв”ҳГҘв•ӘВҝ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•Әв•ўв•ӘВ«в”ҳГ в•ӘвҢҗ. в•ӘВәв•Әв•ўв•Әв•‘в•Әв•– \"в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў\" в”ҳГӨв•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў в•ӘВәв”ҳГӨв•Әв”Өв•ӘВәв”ҳГ в”ҳГӨ в•Әв•Јв”ҳГҘв•ӘВ» в•ӘВәв”ҳГӨв•ӘВЎв•ӘВәв•ӘВјв•ӘвҢҗ.',\r\n        },\r\n      ],\r\n      stats: { integrityWarnings: 0, orphans: 0, logicErrors: 0 },\r\n    });\r\n    setPredictiveInsight({\r\n      score: 85,\r\n      status: 'Safe',\r\n      trend: 'Stable',\r\n      riskFactors: [],\r\n      recommendations: ['в•ӘВәв”ҳГӨв•ӘВ¬в•Әв”Өв•ӘВ«в”ҳГЁв•Әв•Ў в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁ в”ҳГ в•Әв•Јв•Әв•–в”ҳГӨ в”ҳГјв”ҳГЁ в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВ»в”ҳГЁв•Әв”Ӯв”ҳГўв•ӘВ¬в”ҳГӘв•ӘВҝ в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј.'],\r\n    });\r\n    setLoading(false);\r\n  }, [runCheck, dbSignal, isDesktopFast]);\r\n\r\n  if (loading) {\r\n    return <LoadingScreen />;\r\n  }\r\n\r\n  return (\r\n    <div className=\"animate-fade-in space-y-8 pb-10\">\r\n      <MaintenanceHeader onRecheck={runCheck} loading={loading} activeTab={activeTab} />\r\n\r\n      <MaintenanceTabs\r\n        activeTab={activeTab}\r\n        setActiveTab={setActiveTab}\r\n        onRunPerfTest={runPerfTest}\r\n      />\r\n\r\n      {activeTab === 'diagnostics' && health && (\r\n        <DiagnosticsView health={health} optimizing={optimizing} onAutoFix={handleAutoFix} />\r\n      )}\r\n\r\n      {activeTab === 'predictive' && predictiveInsight && (\r\n        <PredictiveView predictiveInsight={predictiveInsight} />\r\n      )}\r\n\r\n      {activeTab === 'performance' && performanceReport && (\r\n        <PerformanceView performanceReport={performanceReport} />\r\n      )}\r\n\r\n      {activeTab === 'testing' && <SystemTestView />}\r\n\r\n      {activeTab === 'database' && <DatabaseView />}\r\n    </div>\r\n  );\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"g:\\pk\\pk\\azrar-mhamoud-qattoush-recovered\\src\\pages\\SystemSetup.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ArrowLeft' is defined but never used. Allowed unused vars must match /^_/u.","line":13,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":13,"endColumn":12,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ArrowLeft"},"fix":{"range":[202,215],"text":""},"desc":"Remove unused variable \"ArrowLeft\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect, useRef } from 'react';\nimport { \n  Server, \n  ShieldCheck, \n  ShieldAlert, \n  Loader2, \n  CheckCircle2, \n  XCircle, \n  Terminal, \n  ChevronRight,\n  Database,\n  Globe,\n  ArrowLeft,\n  Settings,\n  Sparkles,\n  Command,\n  Layout\n} from 'lucide-react';\nimport { ROUTE_PATHS } from '@/routes/paths';\n\ntype Step = 'welcome' | 'requirements' | 'install' | 'success';\n\nexport const SystemSetup: React.FC = () => {\n  const [currentStep, setCurrentStep] = useState<Step>('welcome');\n  const [isAdmin, setIsAdmin] = useState<boolean | null>(null);\n  const [logs, setLogs] = useState<string[]>([]);\n  const [isInstalling, setIsInstalling] = useState(false);\n  const [installResult, setInstallResult] = useState<{ ok: boolean; message: string } | null>(null);\n  const [detection, setDetection] = useState<{ installed: boolean; connected: boolean; message?: string } | null>(null);\n  const logEndRef = useRef<HTMLDivElement>(null);\n\n  // Detect existing installation\n  useEffect(() => {\n    if (currentStep === 'welcome') {\n      void (async () => {\n        try {\n          const res = await window.desktopDb.sqlIsAlreadyInstalled();\n          setDetection(res);\n        } catch (err) {\n          console.error('Failed to detect SQL installation:', err);\n        }\n      })();\n    }\n  }, [currentStep]);\n\n  // Auto-scroll logs\n\n  useEffect(() => {\n    logEndRef.current?.scrollIntoView({ behavior: 'smooth' });\n  }, [logs]);\n\n  // Check Admin on mount of requirements step\n  useEffect(() => {\n    if (currentStep === 'requirements') {\n      void (async () => {\n        try {\n          const res = await window.desktopDb.checkAdminStatus();\n          setIsAdmin(res.isAdmin);\n        } catch (err) {\n          console.error('Failed to check admin status:', err);\n          setIsAdmin(false);\n        }\n      })();\n    }\n  }, [currentStep]);\n\n  // Listen for logs\n  useEffect(() => {\n    const removeListener = window.desktopDb.onSqlSetupLog((line) => {\n      setLogs((prev) => [...prev, line]);\n    });\n    return () => removeListener();\n  }, []);\n\n  const handleStartInstallation = async () => {\n    const db = window.desktopDb;\n    if (!db) {\n      setInstallResult({ ok: false, message: 'в•ӘВ«в•Әв•–в•ӘГә: в•ӘВјв•Әв”Ӯв•Әв–’ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎ.' });\n      return;\n    }\n\n    setIsInstalling(true);\n    setLogs([]);\n    try {\n      const res = await db.startInstallation();\n      setInstallResult(res);\n      \n      if (res.ok) {\n        // Post-install: Auto-configure and connect\n        setLogs(prev => [...prev, '[SYSTEM] Installation successful! Finalizing connection...']);\n        \n        const bootstrap = await db.sqlApplyBootstrapCredentials();\n        if (bootstrap.ok) {\n          setLogs(prev => [...prev, '[SYSTEM] Local credentials applied successfully.']);\n          setLogs(prev => [...prev, '[SYSTEM] Connecting to local Database...']);\n          \n          const conn = await db.sqlConnect();\n          if (conn.ok) {\n            setLogs(prev => [...prev, '[SYSTEM] Database connection established. Registration complete!']);\n            setCurrentStep('success');\n          } else {\n            setLogs(prev => [...prev, `[ERROR] Connection failed: ${conn.message}`]);\n            setInstallResult({ ok: false, message: 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁ в•ӘВҝв”ҳГ©в•ӘВәв•Әв•Јв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬. в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГ©в”ҳГ© в”ҳГ в”ҳГҘ в”ҳГӨв”ҳГӘв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ .' });\n          }\n        } else {\n          const errorMessage = !bootstrap.ok ? bootstrap.message : 'Unknown error';\n          setLogs(prev => [...prev, `[ERROR] Failed to apply credentials: ${errorMessage}`]);\n          setCurrentStep('success');\n        }\n\n      }\n    } catch (err) {\n      setInstallResult({ ok: false, message: String(err) });\n    } finally {\n      setIsInstalling(false);\n    }\n  };\n\n  const handleFastLink = async () => {\n    const db = window.desktopDb;\n    if (!db) return;\n\n    setIsInstalling(true);\n    setLogs(['[SYSTEM] в•ӘВҝв•ӘВ»в•ӘГӯ в•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв–’в•ӘВҝв•Әв•– в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј в•ӘВҝв•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•Әв–’в”ҳГў в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•Әв”Өв”ҳГј...']);\n    setCurrentStep('install');\n\n    try {\n      setLogs(prev => [...prev, '[SYSTEM] в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВјв•ӘВәв•Әв•Ј в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•Әв–’в”ҳГў в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв”ҳГӨв”ҳГЁ...']);\n      const bootstrap = await db.sqlApplyBootstrapCredentials();\n      \n      if (bootstrap.ok) {\n        setLogs(prev => [...prev, '[SYSTEM] в•ӘВ¬в”ҳГ  в•ӘВ¬в•Әв•–в•ӘВҝв”ҳГЁв”ҳГ© в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ.']);\n        setLogs(prev => [...prev, '[SYSTEM] в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв•ӘВ«в•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ©в•ӘВәв•Әв•Јв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬...']);\n        \n        const conn = await db.sqlConnect();\n        if (conn.ok) {\n          setLogs(prev => [...prev, '[SYSTEM] в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ!']);\n          setTimeout(() => setCurrentStep('success'), 1000);\n        } else {\n          setLogs(prev => [...prev, `[ERROR] в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ: ${conn.message}`]);\n          setInstallResult({ ok: false, message: 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВәв”ҳГӨв•Әв–’в•ӘВҝв•Әв•– в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁ. в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•ӘВәв”ҳГӘв”ҳГӨв•ӘвҢҗ в”ҳГЁв•ӘВ»в”ҳГӘв”ҳГЁв•ӘВәв”ҳГҜ.' });\n        }\n      } else {\n        setLogs(prev => [...prev, `[ERROR] в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВ¬в•Әв•–в•ӘВҝв”ҳГЁв”ҳГ© в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬: ${bootstrap.message}`]);\n        setInstallResult({ ok: false, message: 'в”ҳГјв•Әв”Өв”ҳГӨ в”ҳГ©в•Әв–’в•ӘВәв•ӘГӯв•ӘвҢҗ в”ҳГ в”ҳГӨв”ҳГј в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ§в”ҳГЁв•ӘВӘв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВҝв”ҳГ©.' });\n      }\n    } catch (err) {\n      setLogs(prev => [...prev, `[ERROR] в•ӘВ«в•Әв•–в•ӘГә в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВ¬в”ҳГӘв”ҳГ©в•Әв•Ј: ${String(err)}`]);\n      setInstallResult({ ok: false, message: String(err) });\n    } finally {\n      setIsInstalling(false);\n    }\n  };\n\n\n\n  const renderContent = () => {\n    switch (currentStep) {\n      case 'welcome':\n        return (\n          <div className=\"flex flex-col items-center animate-in fade-in slide-in-from-bottom-6 duration-700\">\n            <div className=\"relative mb-10 group\">\n              <div className=\"absolute -inset-4 bg-indigo-500/20 rounded-[2.5rem] blur-2xl group-hover:bg-indigo-500/30 transition-all duration-500\" />\n              <div className=\"relative w-28 h-28 bg-gradient-to-br from-indigo-600 via-indigo-500 to-indigo-400 rounded-[2rem] flex items-center justify-center shadow-2xl shadow-indigo-500/40 transform group-hover:rotate-6 transition-transform duration-500\">\n                <Server size={52} className=\"text-white drop-shadow-lg\" />\n              </div>\n              <div className=\"absolute -bottom-2 -right-2 w-10 h-10 bg-white dark:bg-slate-800 rounded-2xl flex items-center justify-center shadow-xl border border-slate-100 dark:border-slate-700\">\n                <Sparkles size={20} className=\"text-amber-500\" />\n              </div>\n            </div>\n\n            <div className=\"text-center max-w-xl mx-auto space-y-4\">\n              <h1 className=\"text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight leading-tight\">\n                в”ҳГ в•Әв–’в•ӘВЎв•ӘВҝв•ӘВәв”ҳГҜ в•ӘВҝв”ҳГў в”ҳГјв”ҳГЁ <span className=\"text-indigo-600 dark:text-indigo-400\">в”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•ӘГәв•Әв–“в•Әв–’в•ӘВәв•Әв–’</span>\n              </h1>\n              <p className=\"text-lg md:text-xl text-slate-600 dark:text-slate-400 leading-relaxed font-bold\">\n                в•Әв”Ӯв”ҳГҘв”ҳГ©в”ҳГӘв”ҳГ  в•ӘВәв”ҳГӨв•ӘГів”ҳГҘ в•ӘВҝв•ӘВ¬в”ҳГ§в”ҳГЁв•ӘВӘв•ӘвҢҗ в•ӘВҝв”ҳГЁв•ӘВӘв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в”ҳГӘв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬ в”ҳГ в•ӘВЎв•Әв–’в”ҳГў в”ҳГ©в”ҳГӘв•ӘВәв•Әв•Јв•ӘВ» в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГӨв•Әв•ўв”ҳГ в•ӘВәв”ҳГҘ в•Әв•Јв”ҳГ в”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв•–в•ӘВҝв”ҳГЁв”ҳГ© в•ӘВҝв•ӘГәв”ҳГ©в•Әв•Ўв”ҳГ« в•Әв”Ӯв•Әв–’в•Әв•Јв•ӘвҢҗ в”ҳГ в”ҳГ в”ҳГўв”ҳГҘв•ӘвҢҗ в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВјв”ҳГ§в•ӘВәв•Әв–“в”ҳГў.\n              </p>\n              \n              {detection?.installed && (\n                <div className=\"mt-4 flex items-center justify-center gap-3 py-2 px-6 bg-emerald-500/10 border border-emerald-500/20 rounded-full animate-in zoom-in duration-500\">\n                  <div className=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" />\n                  <span className=\"text-sm font-black text-emerald-600 dark:text-emerald-400\">в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГўв•ӘВ¬в•Әв”Өв•ӘВәв”ҳГј в”ҳГ в•ӘВЎв•Әв–’в”ҳГў SQL в”ҳГ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВҝв•ӘВәв”ҳГӨв”ҳГјв•Әв•Јв”ҳГӨ в•Әв•Јв”ҳГӨв”ҳГ« в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•ӘВјв”ҳГ§в•ӘВәв•Әв–“</span>\n                </div>\n              )}\n            </div>\n\n            <div className=\"mt-12 flex flex-col items-center gap-6 w-full\">\n              <div className=\"flex flex-col md:flex-row gap-4 w-full max-w-lg\">\n                {detection?.installed ? (\n                  <>\n                    <button\n                      onClick={handleFastLink}\n                      className=\"flex-[2] group relative bg-emerald-600 text-white px-8 py-5 rounded-[3xl] font-black text-xl transition-all shadow-2xl shadow-emerald-600/30 hover:bg-emerald-700 hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-2\"\n                    >\n                      <Database size={24} className=\"group-hover:scale-110 transition-transform\" />\n                      в•Әв–’в•ӘВҝв•Әв•– в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•Әв–’в”ҳГў в”ҳГӘв•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗ\n                      <ChevronRight size={24} className=\"group-hover:translate-x-1 transition-transform\" />\n                    </button>\n                    <button\n                      onClick={() => setCurrentStep('requirements')}\n                      className=\"flex-1 group relative bg-slate-100 dark:bg-slate-800 text-slate-500 px-6 py-5 rounded-[3xl] font-bold text-sm transition-all border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-2\"\n                    >\n                      в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»\n                    </button>\n                  </>\n                ) : (\n                  <button\n                    onClick={() => setCurrentStep('requirements')}\n                    className=\"flex-1 group relative bg-indigo-600 text-white px-8 py-5 rounded-[3xl] font-black text-xl transition-all shadow-2xl shadow-indigo-600/30 hover:bg-indigo-700 hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-2\"\n                  >\n                    в•ӘВҝв•ӘВ»в•ӘГӯ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»\n                    <ChevronRight size={24} className=\"group-hover:translate-x-1 transition-transform\" />\n                  </button>\n                )}\n\n                <button\n                  onClick={() => window.location.hash = ROUTE_PATHS.LOGIN}\n                  className=\"flex-1 group relative bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 px-8 py-5 rounded-[3xl] font-bold text-lg transition-all border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-2\"\n                >\n                  в•ӘВ¬в•ӘВ«в•Әв•–в”ҳГЁ в”ҳГӨв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ\n                  <Layout size={20} className=\"opacity-60 group-hover:rotate-12 transition-transform\" />\n                </button>\n              </div>\n              \n              <div className=\"flex flex-row gap-4\">\n                <button\n                  onClick={async () => {\n                    try {\n                      await window.desktopDb?.quitApp?.();\n                    } catch {\n                      window.close();\n                    }\n                  }}\n                  className=\"md:w-auto bg-rose-500/10 hover:bg-rose-500 text-rose-600 hover:text-white px-6 py-3 rounded-2xl font-black text-sm transition-all border border-rose-500/20 flex items-center justify-center gap-2 group\"\n                  title=\"в•ӘГ‘в•Әв•‘в”ҳГӨв•ӘВәв”ҳГ© в•ӘВәв”ҳГӨв•ӘВҝв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в•ӘВј\"\n                >\n                  <XCircle size={18} className=\"group-hover:scale-110 transition-transform\" />\n                  в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј в”ҳГ в”ҳГҘ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ \n                </button>\n              </div>\n              \n              <div className=\"flex items-center gap-2 text-slate-400 dark:text-slate-600 font-bold text-xs uppercase tracking-widest\">\n                <Layout size={14} />\n                <span>в•ӘВҝв•Әв–’в”ҳГӘв”ҳГјв”ҳГЁв•Әв”Өв”ҳГҘв•ӘВәв”ҳГӨ в•ӘГ‘в”ҳГЁв•ӘВ»в”ҳГЁв•Әв”Өв”ҳГҘ 2025</span>\n              </div>\n            </div>\n\n          </div>\n        );\n\n      case 'requirements':\n        return (\n          <div className=\"flex flex-col items-center w-full animate-in fade-in slide-in-from-left-6 duration-700\">\n            <div className=\"text-center mb-10\">\n              <div className=\"inline-flex items-center gap-2 px-4 py-1.5 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-full text-xs font-black uppercase tracking-widest mb-4\">\n                <Settings size={14} className=\"animate-spin-slow\" />\n                <span>в”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв”ҳГјв•ӘВЎв•Әв•Ў в•ӘВәв”ҳГӨв•Әв–‘в”ҳГўв”ҳГЁ</span>\n              </div>\n              <h2 className=\"text-3xl font-black text-slate-900 dark:text-white mb-2\">в”ҳГјв•ӘВЎв•Әв•Ў в”ҳГ в•ӘВ¬в•Әв•–в”ҳГӨв•ӘВҝв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ </h2>\n              <p className=\"text-slate-500 dark:text-slate-500 font-bold\">в”ҳГҘв•ӘВ¬в•ӘГәв”ҳГўв•ӘВ» в”ҳГ в”ҳГҘ в•ӘВјв•ӘВәв”ҳГ§в•Әв–“в”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВӘв•ӘвҢҗ в”ҳГӨв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬ SQL Server Express.</p>\n            </div>\n\n            <div className=\"w-full max-w-lg space-y-4\">\n              <div className=\"group bg-white/50 dark:bg-slate-950/40 border border-slate-200/50 dark:border-slate-800/50 rounded-3xl p-6 transition-all hover:bg-white dark:hover:bg-slate-900/60 hover:shadow-xl hover:shadow-indigo-500/5\">\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-4\">\n                    <div className={`w-12 h-12 rounded-2xl flex items-center justify-center transition-colors ${isAdmin === true ? 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : 'bg-slate-100 dark:bg-slate-800 text-slate-400'}`}>\n                      <ShieldCheck size={24} />\n                    </div>\n                    <div>\n                      <h3 className=\"font-black text-slate-800 dark:text-slate-200\">в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘГұв”ҳГӘв”ҳГӨ</h3>\n                      <p className=\"text-xs text-slate-500 dark:text-slate-500 font-bold\">в”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝв•ӘвҢҗ в”ҳГӨв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬ в•ӘВ«в•ӘВ»в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГӘв”ҳГЁв”ҳГҘв•ӘВ»в”ҳГӘв•Әв–“</p>\n                    </div>\n                  </div>\n                  {isAdmin === null ? (\n                    <Loader2 className=\"animate-spin text-indigo-500\" size={24} />\n                  ) : isAdmin ? (\n                    <div className=\"flex items-center gap-2 text-emerald-500 font-black text-sm\">\n                      <CheckCircle2 size={18} />\n                      <span>в”ҳГ в•ӘВ¬в”ҳГӘв”ҳГјв•Әв–’</span>\n                    </div>\n                  ) : (\n                    <div className=\"flex items-center gap-2 text-amber-500 font-black text-sm\">\n                      <ShieldAlert size={18} />\n                      <span>в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВ¬в”ҳГӘв”ҳГјв•Әв–’</span>\n                    </div>\n                  )}\n                </div>\n              </div>\n\n              <div className=\"group bg-white/50 dark:bg-slate-950/40 border border-slate-200/50 dark:border-slate-800/50 rounded-3xl p-6 transition-all hover:bg-white dark:hover:bg-slate-900/60 hover:shadow-xl hover:shadow-indigo-500/5\">\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-4\">\n                    <div className=\"w-12 h-12 bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-2xl flex items-center justify-center\">\n                      <Database size={24} />\n                    </div>\n                    <div>\n                      <h3 className=\"font-black text-slate-800 dark:text-slate-200\">в”ҳГ в•Әв”Ӯв•ӘВәв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВ«в•Әв–“в”ҳГЁв”ҳГҘ</h3>\n                      <p className=\"text-xs text-slate-500 dark:text-slate-500 font-bold\">2.5 в•ӘВјв”ҳГЁв•ӘВјв•ӘВәв•ӘВҝв•ӘВәв”ҳГЁв•ӘВ¬ в”ҳГўв•ӘВЎв•ӘВ» в•ӘГәв•ӘВ»в”ҳГҘв”ҳГ«</p>\n                    </div>\n                  </div>\n                  <div className=\"flex items-center gap-2 text-emerald-500 font-black text-sm\">\n                    <CheckCircle2 size={18} />\n                    <span>в•ӘВјв•ӘВәв”ҳГ§в•Әв–“</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            {!isAdmin && isAdmin !== null && (\n              <div className=\"mt-8 bg-amber-500/10 border border-amber-500/20 rounded-2xl p-4 flex items-start gap-4 max-w-lg animate-pulse\">\n                <ShieldAlert className=\"text-amber-500 shrink-0 mt-0.5\" size={20} />\n                <p className=\"text-sm text-amber-700 dark:text-amber-400 leading-relaxed font-bold\">\n                  в•ӘВ¬в”ҳГҘв•ӘВҝв”ҳГЁв”ҳГ§: в”ҳГЁв•ӘВјв•ӘВҝ в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•ӘВҝв”ҳГӘв•Әв•ўв•Әв•Ј \"в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘГұв”ҳГӘв”ҳГӨ\" (Administrator) в”ҳГӨв•ӘВ¬в•ӘВ¬в”ҳГ в”ҳГўв”ҳГҘ в”ҳГ в”ҳГҘ в•ӘГ‘в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬ в”ҳГӘв•Әв•ўв•ӘВҝв•Әв•– в•ӘВјв•ӘВ»в•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГ в•ӘВәв”ҳГЁв•ӘвҢҗ.\n                </p>\n              </div>\n            )}\n\n            <div className=\"mt-12 flex gap-4 w-full max-w-lg\">\n              <button\n                onClick={() => setCurrentStep('welcome')}\n                className=\"flex-1 flex items-center justify-center gap-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 px-6 py-4 rounded-2xl font-black transition-all\"\n              >\n                в•ӘВ¬в•Әв–’в•ӘВәв•ӘВјв•Әв•Ј\n              </button>\n              <button\n                disabled={!isAdmin}\n                onClick={() => setCurrentStep('install')}\n                className={`flex-[2] flex items-center justify-center gap-2 px-8 py-4 rounded-2xl font-black transition-all shadow-xl ${\n                  isAdmin \n                    ? \"bg-indigo-600 hover:bg-indigo-700 text-white shadow-indigo-600/20 hover:-translate-y-1 active:scale-95\" \n                    : \"bg-slate-200 dark:bg-slate-800/50 text-slate-400 cursor-not-allowed shadow-none\"\n                }`}\n              >\n                в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗ в”ҳГӨв”ҳГӨв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬\n                <ChevronRight size={20} />\n              </button>\n            </div>\n          </div>\n        );\n\n      case 'install':\n        return (\n          <div className=\"flex flex-col h-full w-full animate-in fade-in zoom-in-95 duration-700\">\n            <div className=\"text-center mb-8\">\n              <h2 className=\"text-3xl font-black text-slate-900 dark:text-white mb-2\">в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВ¬в”ҳГ§в”ҳГЁв•ӘВӘв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»</h2>\n              <p className=\"text-slate-500 dark:text-slate-500 font-bold\">в”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘГів”ҳГҘ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в”ҳГ в•ӘВЎв•Әв–’в”ҳГў в”ҳГ©в•ӘВәв•Әв•Јв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГӘв•Әв•ўв•ӘВҝв•Әв•– в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв”Өв•ӘВҝв”ҳГўв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв”ҳГӨв”ҳГЁв•ӘвҢҗ.</p>\n            </div>\n\n            <div className=\"relative flex-1 bg-slate-950 rounded-[2.5rem] p-4 md:p-6 font-mono text-sm overflow-hidden flex flex-col shadow-2xl border border-white/5 min-h-[350px] md:min-h-[450px]\">\n              <div className=\"flex items-center justify-between mb-6 border-b border-white/5 pb-4\">\n                <div className=\"flex items-center gap-3\">\n                  <div className=\"w-8 h-8 bg-indigo-500/20 rounded-lg flex items-center justify-center\">\n                    <Terminal size={16} className=\"text-indigo-400\" />\n                  </div>\n                  <span className=\"text-slate-400 text-[10px] font-black tracking-[0.2em] uppercase\">system_setup_logs_v3</span>\n                </div>\n                <div className=\"flex gap-2\">\n                  <div className=\"w-3 h-3 rounded-full bg-slate-800\" />\n                  <div className=\"w-3 h-3 rounded-full bg-slate-800\" />\n                  <div className=\"w-3 h-3 rounded-full bg-indigo-500/50 animate-pulse\" />\n                </div>\n              </div>\n\n              <div className=\"flex-1 overflow-y-auto space-y-2.5 custom-scrollbar pr-2 scroll-smooth\">\n                {logs.length === 0 && !isInstalling && (\n                  <div className=\"flex flex-col items-center justify-center h-full text-slate-600 space-y-4 opacity-40\">\n                    <Command size={48} className=\"animate-pulse\" />\n                    <p className=\"italic font-bold text-center px-6\">в•ӘВјв•ӘВәв”ҳГ§в•Әв–“ в”ҳГӨв•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳГ©в•ӘВҝв•ӘВәв”ҳГӨ в•ӘВәв”ҳГӨв•ӘГәв”ҳГӘв•ӘВәв”ҳГ в•Әв–’... в•ӘВәв•Әв•ўв•Әв•‘в•Әв•– в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв•Әв–“в•Әв–’ в•ӘГәв•ӘВ»в”ҳГҘв•ӘВәв”ҳГ§ в”ҳГӨв•ӘВҝв•ӘВ»в•ӘГӯ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬</p>\n                  </div>\n                )}\n                {logs.map((log, i) => (\n                  <div key={i} className=\"flex gap-4 text-rtl animate-in fade-in slide-in-from-right-1 duration-200\">\n                    <span className=\"text-slate-700 shrink-0 text-[9px] tabular-nums font-black mt-1.5 opacity-50\">\n                      {String(i + 1).padStart(3, '0')}\n                    </span>\n                    <span className={`leading-relaxed break-words font-medium text-xs md:text-sm ${\n                      log.toLowerCase().includes('error') || log.toLowerCase().includes('failed') ? 'text-rose-400 font-black' : \n                      log.startsWith('[SYSTEM]') ? 'text-indigo-400' : \n                      log.toLowerCase().includes('success') || log.includes('Done') ? 'text-emerald-400 font-bold' :\n                      'text-slate-300'\n                    }`}>\n                      {log}\n                    </span>\n                  </div>\n                ))}\n                <div ref={logEndRef} />\n              </div>\n\n              {isInstalling && (\n                <div className=\"mt-6 flex items-center gap-4 bg-white/5 border border-white/5 px-6 py-4 rounded-2xl\">\n                  <Loader2 className=\"animate-spin text-indigo-400\" size={24} />\n                  <div className=\"flex-1\">\n                    <p className=\"text-white font-black text-sm\">в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬ в•ӘВЎв•ӘВәв”ҳГӨв”ҳГЁв•ӘВәв”ҳГҜ...</p>\n                    <p className=\"text-slate-500 text-[10px] font-bold\">в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•Әв•Јв•ӘВ»в”ҳГ  в•ӘГ‘в•Әв•‘в”ҳГӨв•ӘВәв”ҳГ© в•ӘВәв”ҳГӨв•ӘВҝв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в•ӘВј</p>\n                  </div>\n                </div>\n              )}\n            </div>\n\n            <div className=\"mt-10 flex justify-center\">\n              {!isInstalling && !installResult && (\n                <div className=\"flex flex-col md:flex-row gap-4\">\n                  <button\n                    onClick={handleStartInstallation}\n                    className=\"group bg-indigo-600 hover:bg-indigo-700 text-white px-12 py-5 rounded-[2rem] font-black transition-all shadow-xl shadow-indigo-600/20 flex items-center gap-4 hover:-translate-y-1 active:scale-95\"\n                  >\n                    <Globe size={24} className=\"group-hover:rotate-12 transition-transform\" />\n                    в•ӘВҝв•ӘВ»в•ӘГӯ в•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв”Өв•ӘВәв”ҳГ в”ҳГӨв•ӘвҢҗ\n                  </button>\n                  <button\n                    onClick={() => setCurrentStep('welcome')}\n                    className=\"bg-white dark:bg-slate-800 text-slate-500 hover:text-slate-700 dark:hover:text-slate-200 px-8 py-5 rounded-[2rem] font-bold transition-all border border-slate-200 dark:border-slate-700 hover:shadow-lg\"\n                  >\n                    в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ в”ҳГӘв•ӘВәв”ҳГӨв•Әв•Јв”ҳГӘв•ӘВ»в•ӘвҢҗ\n                  </button>\n                </div>\n              )}\n              {installResult && !installResult.ok && (\n                <div className=\"flex flex-col md:flex-row gap-4\">\n                  <button\n                    onClick={handleStartInstallation}\n                    className=\"bg-rose-600 hover:bg-rose-700 text-white px-10 py-4 rounded-2xl font-black transition-all shadow-xl shadow-rose-600/20 flex items-center gap-3 animate-bounce\"\n                  >\n                     в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•ӘВәв”ҳГӘв”ҳГӨв•ӘвҢҗ\n                  </button>\n                  <button\n                    onClick={() => setCurrentStep('welcome')}\n                    className=\"bg-white dark:bg-slate-800 text-slate-500 px-8 py-4 rounded-2xl font-bold transition-all border border-slate-200 dark:border-slate-700\"\n                  >\n                    в•ӘВ¬в•Әв–’в•ӘВәв•ӘВјв•Әв•Ј в”ҳГӨв”ҳГӨв•ӘВҝв•ӘВ»в•ӘВәв”ҳГЁв•ӘвҢҗ\n                  </button>\n                </div>\n              )}\n              {isInstalling && (\n                 <button\n                    onClick={() => setCurrentStep('welcome')}\n                    className=\"text-slate-400 hover:text-slate-600 underline text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\"\n                  >\n                    в•ӘГ‘в”ҳГЁв”ҳГ©в•ӘВәв”ҳГј в”ҳГӘв•ӘВәв”ҳГӨв•Әв•Јв”ҳГӘв•ӘВ»в•ӘвҢҗ в”ҳГӨв”ҳГӨв•ӘВҝв•ӘВ»в•ӘВәв”ҳГЁв•ӘвҢҗ (в•Әв”Ӯв”ҳГЁв•Әв”Ӯв•ӘВ¬в”ҳГ в•Әв–’ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬ в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ)\n                  </button>\n              )}\n            </div>\n          </div>\n        );\n\n      case 'success':\n        return (\n          <div className=\"flex flex-col items-center animate-in fade-in zoom-in-95 duration-1000\">\n            <div className=\"relative mb-10\">\n              <div className=\"absolute inset-0 bg-emerald-500/20 rounded-full blur-3xl animate-pulse\" />\n              <div className=\"w-32 h-32 bg-gradient-to-br from-emerald-500 to-emerald-400 rounded-full flex items-center justify-center relative z-10 shadow-2xl shadow-emerald-500/40 border-4 border-white dark:border-slate-800\">\n                <CheckCircle2 size={72} className=\"text-white drop-shadow-lg\" />\n              </div>\n              <div className=\"absolute -top-4 -right-4 w-12 h-12 bg-indigo-500 rounded-2xl flex items-center justify-center animate-bounce shadow-xl\">\n                <Sparkles size={24} className=\"text-white\" />\n              </div>\n            </div>\n\n            <div className=\"text-center space-y-4 mb-12\">\n              <h1 className=\"text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight\">в•ӘВәв”ҳГўв•ӘВ¬в”ҳГ в”ҳГӨ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ!</h1>\n              <p className=\"text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-md mx-auto leading-relaxed font-bold\">\n                в”ҳГӨв”ҳГ©в•ӘВ» в•ӘВ¬в”ҳГ  в•ӘВ¬в•ӘВҪв•ӘВҝв”ҳГЁв•ӘВ¬ в”ҳГ в•ӘВЎв•Әв–’в”ҳГў в”ҳГ©в•ӘВәв•Әв•Јв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ в”ҳГӘв•Әв•ўв•ӘВҝв•Әв•– в”ҳГўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГЁв”ҳГӘв”ҳГЁв•ӘвҢҗ. в”ҳГҘв•Әв••в•ӘВәв”ҳГ  в•ӘГәв•Әв–“в•Әв–’в•ӘВәв•Әв–’ в•ӘВјв•ӘВәв”ҳГ§в•Әв–“ в•ӘВәв”ҳГӨв•ӘГів”ҳГҘ в”ҳГӨв”ҳГӨв•ӘВ«в•ӘВ»в”ҳГ в•ӘвҢҗ в•ӘВҝв•Әв–‘в”ҳГўв•ӘВәв•ӘГӯ.\n              </p>\n            </div>\n\n            <button\n              onClick={() => window.location.hash = ROUTE_PATHS.LOGIN}\n              className=\"group relative bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-16 py-5 rounded-[2rem] font-black text-xl transition-all shadow-2xl hover:bg-indigo-600 dark:hover:bg-indigo-500 hover:text-white hover:-translate-y-1 active:scale-95\"\n            >\n              в•ӘВәв”ҳГӨв•ӘВәв”ҳГҘв•ӘВ¬в”ҳГ©в•ӘВәв”ҳГӨ в”ҳГӨв•ӘВ¬в•Әв”Ӯв•ӘВјв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ\n              <ChevronRight size={24} className=\"inline-block mr-3 group-hover:translate-x-2 transition-transform\" />\n            </button>\n          </div>\n        );\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen w-full bg-gradient-to-br from-slate-100 via-white to-indigo-50/40 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 flex items-center justify-center p-4 md:p-8 font-tajawal rtl transition-colors duration-500 overflow-x-hidden overflow-y-auto\" dir=\"rtl\">\n      \n      {/* Dynamic Background Elements */}\n      <div className=\"fixed inset-0 overflow-hidden pointer-events-none z-0\">\n        <div className=\"absolute top-1/4 left-1/4 w-[40rem] h-[40rem] bg-indigo-500/5 dark:bg-indigo-500/10 rounded-full blur-[120px] animate-pulse\" />\n        