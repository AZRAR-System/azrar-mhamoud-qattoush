('');\r\n    setInfo('');\r\n    setBusy(true);\r\n    try {\r\n      const patch = {\r\n        customer: {\r\n          name: customerName.trim() || undefined,\r\n          company: customerCompany.trim() || undefined,\r\n          phone: customerPhone.trim() || undefined,\r\n          city: customerCity.trim() || undefined,\r\n        },\r\n        note: afterSalesNote,\r\n        followUp: {\r\n          status: followUpStatus || undefined,\r\n          lastContactAt: followUpLastContactAt.trim() || undefined,\r\n          nextAt: followUpNextAt.trim() || undefined,\r\n        },\r\n        logNote: afterSalesLogNote.trim() || undefined,\r\n      };\r\n\r\n      if (!window.desktopLicenseAdmin) throw new Error('Desktop bridge not available');\r\n      const res = await window.desktopLicenseAdmin.updateAfterSales({\r\n        serverUrl,\r\n        licenseKey,\r\n        patch,\r\n      });\r\n      const rec = res && typeof res === 'object' ? (res as Record<string, unknown>) : {};\r\n      if (rec.ok !== true) throw new Error(String(rec.error || 'Failed'));\r\n      await refreshList();\r\n      await loadRecord(licenseKey);\r\n      setAfterSalesLogNote('');\r\n      setInfo('в•ӘВ¬в”ҳГ  в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГ в•ӘВә в•ӘВҝв•Әв•Јв•ӘВ» в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј');\r\n    } catch (e: unknown) {\r\n      setError(getErrorMessage(e) || 'Failed to update');\r\n    } finally {\r\n      setBusy(false);\r\n    }\r\n  };\r\n\r\n  const _doCheckDeviceStatus = async () => {\r\n    if (!canUseBridge) return;\r\n    const licenseKey = selectedKey.trim();\r\n    const deviceId = statusCheckDeviceId.trim();\r\n    if (!licenseKey) {\r\n      setError('в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’ в•ӘВ¬в•Әв–’в•ӘВ«в”ҳГЁв•Әв•Ў в•ӘГәв”ҳГӘв”ҳГӨв•ӘВәв”ҳГҜ');\r\n      return;\r\n    }\r\n    if (!deviceId) {\r\n      setError('в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ в•ӘВҝв•Әв•Ўв”ҳГ в•ӘвҢҗ в•ӘВјв”ҳГ§в•ӘВәв•Әв–“ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГЁв”ҳГӨ (fingerprint)');\r\n      return;\r\n    }\r\n\r\n    setError('');\r\n    setInfo('');\r\n    setBusy(true);\r\n    setStatusCheckResult('');\r\n    try {\r\n      if (!window.desktopLicenseAdmin) throw new Error('Desktop bridge not available');\r\n      const res = await window.desktopLicenseAdmin.checkStatus({ serverUrl, licenseKey, deviceId });\r\n      const rec = res && typeof res === 'object' ? (res as Record<string, unknown>) : {};\r\n      if (rec.ok !== true) throw new Error(String(rec.error || 'Failed'));\r\n      const result =\r\n        rec.result && typeof rec.result === 'object' ? (rec.result as Record<string, unknown>) : {};\r\n      setStatusCheckResult(JSON.stringify(result, null, 2));\r\n      setInfo('в•ӘВ¬в”ҳГ  в•ӘВјв”ҳГӨв•ӘВҝ в•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВјв”ҳГ§в•ӘВәв•Әв–“');\r\n    } catch (e: unknown) {\r\n      setError(getErrorMessage(e) || 'Failed to check status');\r\n    } finally {\r\n      setBusy(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    setSelectedRecord(null);\r\n    setActivateResultJson('');\r\n    setActivateMeta('');\r\n    setSavePath('');\r\n    setStatusCheckResult('');\r\n    if (loggedIn && selectedKey) {\r\n      void loadRecord(selectedKey);\r\n    }\r\n    // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  }, [selectedKey]);\r\n\r\n  const applyIssueDuration = (duration: IssueDuration) => {\r\n    setIssueDuration(duration);\r\n    if (duration === 'custom') return;\r\n    setIssueExpiresAt(computeExpiresAtFromDuration(duration));\r\n  };\r\n  \r\n  // --- Customers Logic ---\r\n  const customerGroups = useMemo(() => {\r\n    const byKey = new Map<string, { label: string; company?: string; name?: string; phone?: string; city?: string; items: AdminListItem[] }>();\r\n    const norm = (v: unknown) => String(v ?? '').trim();\r\n    \r\n    for (const it of items) {\r\n      const company = norm(it.customerCompany);\r\n      const name = norm(it.customerName);\r\n      const phone = norm(it.customerPhone);\r\n      const city = norm(it.customerCity);\r\n      const k = [company, name, phone, city].filter(Boolean).join(' | ') || 'в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬';\r\n      \r\n      if (!byKey.has(k)) {\r\n        byKey.set(k, {\r\n          label: company || name || 'в•Әв•Јв”ҳГ в”ҳГЁв”ҳГӨ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв•ӘВјв”ҳГӨ',\r\n          company: company || undefined,\r\n          name: name || undefined,\r\n          phone: phone || undefined,\r\n          city: city || undefined,\r\n          items: [it]\r\n        });\r\n      } else {\r\n        byKey.get(k)?.items.push(it);\r\n      }\r\n    }\r\n    \r\n    const out = Array.from(byKey.values());\r\n    out.sort((a,b) => b.items.length - a.items.length || a.label.localeCompare(b.label, 'ar'));\r\n    return out;\r\n  }, [items]);\r\n\r\n  const filteredCustomerGroups = useMemo(() => {\r\n    const q = customerSearch.trim().toLowerCase();\r\n    if (!q) return customerGroups;\r\n    return customerGroups.filter(g => \r\n      g.label.toLowerCase().includes(q) || \r\n      g.company?.toLowerCase().includes(q) || \r\n      g.phone?.includes(q)\r\n    );\r\n  }, [customerGroups, customerSearch]);\r\n\r\n  // --- Server User Settings Logic ---\r\n  const [newUsername, setNewUsername] = useState('');\r\n  const [newPassword, setNewPassword] = useState('');\r\n  const [confirmPassword, setConfirmPassword] = useState('');\r\n\r\n  const doUpdateServerUser = async () => {\r\n    if (!canUseBridge) return;\r\n    const u = newUsername.trim();\r\n    if (!u) {\r\n      toast.error('в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ');\r\n      return;\r\n    }\r\n    if (newPassword && newPassword !== confirmPassword) {\r\n      toast.error('в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВ¬в•Әв•–в•ӘВәв•ӘВҝв”ҳГ©в•ӘвҢҗ');\r\n      return;\r\n    }\r\n\r\n    setBusy(true);\r\n    try {\r\n      const res = await window.desktopLicenseAdmin?.updateUser({\r\n        username: u,\r\n        newPassword: newPassword || undefined\r\n      });\r\n      const rec = res && typeof res === 'object' ? (res as Record<string, unknown>) : {};\r\n      if (rec.ok !== true) throw new Error(String(rec.error || 'Failed'));\r\n      toast.success('в•ӘВ¬в”ҳГ  в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ в”ҳГӨв”ҳГӨв•Әв”Ӯв”ҳГЁв•Әв–’в”ҳГјв•Әв–’');\r\n      setNewPassword('');\r\n      setConfirmPassword('');\r\n    } catch (e: unknown) {\r\n      toast.error(getErrorMessage(e) || 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ');\r\n    } finally {\r\n      setBusy(false);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"h-screen overflow-y-auto bg-slate-50 dark:bg-slate-950 p-4 md:p-6\" dir=\"rtl\">\r\n      <div className=\"max-w-7xl mx-auto space-y-6\">\r\n        {/* Header */}\r\n        <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\r\n          <div>\r\n            <h1 className=\"text-2xl font-black text-slate-900 dark:text-white flex items-center gap-3\">\r\n              <Globe className=\"text-indigo-600\" size={28} />\r\n              в”ҳГ в•Әв–’в”ҳГўв•Әв–“ в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВәв•ӘВ«в”ҳГЁв•Әв•Ў (Hub)\r\n            </h1>\r\n            <p className=\"text-sm text-slate-500 dark:text-slate-400 mt-1\">\r\n              в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘГәв”ҳГҘв•Әв••в”ҳГ в•ӘвҢҗв•ӘГ® в”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв•ӘВәв•ӘГӯв•ӘГ® в”ҳГӘв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВ«в•ӘВәв•ӘВ»в”ҳГ  в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВ«в”ҳГЁв•Әв•Ў в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГўв•Әв–“в”ҳГЁ.\r\n            </p>\r\n          </div>\r\n          <div className=\"flex items-center gap-2\">\r\n            <Button variant=\"secondary\" onClick={() => void refreshList()} disabled={busy || !loggedIn}>\r\n              <Activity size={16} className={busy ? 'animate-spin' : ''} />\r\n              в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬\r\n            </Button>\r\n            {loggedIn && (\r\n              <Button variant=\"danger\" onClick={() => void doLogout()}>\r\n                <LogOut size={16} />\r\n                в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј\r\n              </Button>\r\n            )}\r\n          </div>\r\n        </div>\r\n\r\n        {/* Tabs Switcher */}\r\n        <div className=\"flex flex-wrap gap-2 bg-white dark:bg-slate-900 p-1.5 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800\">\r\n          {[\r\n            { id: 'dashboard', label: 'в”ҳГӨв”ҳГӘв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ ', icon: LayoutDashboard },\r\n            { id: 'licenses', label: 'в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВәв•ӘВ«в”ҳГЁв•Әв•Ў', icon: Key },\r\n            { id: 'customers', label: 'в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв•ӘВәв•ӘГӯ в”ҳГӘв•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗ', icon: CustomersIcon },\r\n            { id: 'settings', label: 'в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ', icon: SettingsIcon },\r\n          ].map((tab) => (\r\n            <button\r\n              key={tab.id}\r\n              onClick={() => setActiveTab(tab.id as TabKey)}\r\n              className={`flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold transition-all ${\r\n                activeTab === tab.id\r\n                  ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20'\r\n                  : 'text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800'\r\n              }`}\r\n            >\r\n              <tab.icon size={18} />\r\n              {tab.label}\r\n            </button>\r\n          ))}\r\n        </div>\r\n\r\n        {/* Error/Info Banner */}\r\n        {error && (\r\n          <div className=\"p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-900/30 rounded-2xl text-red-600 dark:text-red-400 text-sm font-bold flex items-center gap-3 transition-all animate-shake\">\r\n            <ShieldCheck size={20} />\r\n            {error}\r\n          </div>\r\n        )}\r\n\r\n        {/* Content Area */}\r\n        <div className=\"animate-fade-in\">\r\n          {activeTab === 'dashboard' && (\r\n            <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6\">\r\n              <div className=\"lg:col-span-8 space-y-6\">\r\n                {/* Server Selection */}\r\n                <Card className=\"p-6 rounded-3xl space-y-4\">\r\n                  <h3 className=\"font-bold text-slate-800 dark:text-white flex items-center gap-2\">\r\n                    <Globe size={20} className=\"text-indigo-600\" />\r\n                    в•ӘВ«в”ҳГӘв•ӘВәв•ӘВ»в”ҳГ  в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВ«в”ҳГЁв•Әв•Ў в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎв•ӘвҢҗ\r\n                  </h3>\r\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n                    <div className=\"space-y-4\">\r\n                      {servers.map((s) => (\r\n                        <div\r\n                          key={s}\r\n                          onClick={() => setServerUrl(s)}\r\n                          className={`p-4 rounded-2xl border transition-all cursor-pointer flex items-center justify-between group ${\r\n                            serverUrl === s\r\n                              ? 'bg-indigo-50 dark:bg-indigo-900/20 border-indigo-600'\r\n                              : 'bg-slate-50 dark:bg-slate-800/40 border-slate-100 dark:border-slate-800'\r\n                          }`}\r\n                        >\r\n                          <div className=\"flex items-center gap-3 overflow-hidden\">\r\n                            <div className={`p-2 rounded-xl ${serverUrl === s ? 'bg-indigo-600 text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-500'}`}>\r\n                              <Globe size={16} />\r\n                            </div>\r\n                            <span className=\"text-sm font-bold truncate\">{s}</span>\r\n                          </div>\r\n                          <button\r\n                            onClick={(e) => { e.stopPropagation(); doRemoveServer(s); }}\r\n                            className=\"p-2 text-red-500 opacity-0 group-hover:opacity-100 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition\"\r\n                          >\r\n                            <Trash2 size={16} />\r\n                          </button>\r\n                        </div>\r\n                      ))}\r\n                    </div>\r\n                    <div className=\"p-6 bg-slate-50 dark:bg-slate-800/40 rounded-3xl border border-dashed border-slate-200 dark:border-slate-700 flex flex-col items-center justify-center text-center space-y-4\">\r\n                      <div className=\"p-4 bg-white dark:bg-slate-900 rounded-full text-slate-400\">\r\n                        <Plus size={32} />\r\n                      </div>\r\n                      <div className=\"space-y-1\">\r\n                        <p className=\"text-sm font-bold\">в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВ«в•ӘВәв•ӘВ»в”ҳГ  в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»</p>\r\n                        <p className=\"text-[10px] text-slate-400\">в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘв”ҳГў в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в•Әв–’в”ҳГӘв•ӘВәв•ӘВҝв•Әв•– в•ӘВ«в”ҳГӘв•ӘВәв•ӘВ»в”ҳГ  в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘГәв•ӘВ«в•Әв–’в”ҳГ«</p>\r\n                      </div>\r\n                      <div className=\"w-full space-y-2\">\r\n                        <Input\r\n                          value={newServer}\r\n                          onChange={(e) => setNewServer(e.target.value)}\r\n                          placeholder=\"https://license.yoursite.com\"\r\n                        />\r\n                        <Button onClick={doAddServer} className=\"w-full\">в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в”ҳГӨв”ҳГӨв•Әв”Ӯв•ӘВјв”ҳГӨ</Button>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </Card>\r\n              </div>\r\n\r\n              <div className=\"lg:col-span-4 space-y-6\">\r\n                {/* Login Status */}\r\n                <Card className=\"p-6 rounded-3xl space-y-6 relative overflow-hidden\">\r\n                  <div className=\"relative z-10 space-y-6\">\r\n                    <div className=\"flex items-center justify-between\">\r\n                      <h3 className=\"font-bold text-slate-800 dark:text-white flex items-center gap-2\">\r\n                        <Key size={20} className=\"text-indigo-600\" />\r\n                        в•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ\r\n                      </h3>\r\n                      <StatusBadge status={loggedIn ? 'в”ҳГ в•ӘВ¬в•Әв•Ўв”ҳГӨ' : 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВ¬в•Әв•Ўв”ҳГӨ'} />\r\n                    </div>\r\n\r\n                    {!loggedIn ? (\r\n                      <div className=\"space-y-4\">\r\n                        <div className=\"space-y-1\">\r\n                          <label className=\"text-xs font-bold text-slate-500 px-1\">в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  (Admin)</label>\r\n                          <Input value={username} onChange={(e) => setUsername(e.target.value)} placeholder=\"admin\" />\r\n                        </div>\r\n                        <div className=\"space-y-1\">\r\n                          <label className=\"text-xs font-bold text-slate-500 px-1\">в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’</label>\r\n                          <Input type=\"password\" value={password} onChange={(e) => setPassword(e.target.value)} placeholder=\"О“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГі\" />\r\n                        </div>\r\n                        <Button onClick={() => void doLogin()} isLoading={busy} className=\"w-full py-6 text-lg\">\r\n                          в•ӘВ¬в•Әв”Ӯв•ӘВјв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ в”ҳГӨв”ҳГӨв•Әв”Ӯв”ҳГЁв•Әв–’в”ҳГјв•Әв–’\r\n                        </Button>\r\n                      </div>\r\n                    ) : (\r\n                      <div className=\"p-6 bg-emerald-50 dark:bg-emerald-900/20 rounded-2xl border border-emerald-100 dark:border-emerald-900/30 text-center space-y-4\">\r\n                        <div className=\"w-16 h-16 bg-emerald-600 text-white rounded-full flex items-center justify-center mx-auto shadow-lg shadow-emerald-600/20\">\r\n                          <ShieldCheck size={32} />\r\n                        </div>\r\n                        <div>\r\n                          <p className=\"font-bold text-emerald-800 dark:text-emerald-300\">в•ӘГәв”ҳГҘв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘГів”ҳГҘ в”ҳГјв”ҳГЁ в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ </p>\r\n                          <p className=\"text-[10px] text-emerald-600/70 mt-1\">в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘв”ҳГў в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВәв•ӘВ«в”ҳГЁв•Әв•Ў в”ҳГӘв•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв•ӘВәв•ӘГӯ в•Әв•Јв•ӘВҝв•Әв–’ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВҝв”ҳГӘв”ҳГЁв•ӘВҝв•ӘВәв•ӘВ¬ в•ӘГәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГ§.</p>\r\n                        </div>\r\n                      </div>\r\n                    )}\r\n                  </div>\r\n                </Card>\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {activeTab === 'licenses' && (\r\n            <div className=\"space-y-6\">\r\n              {!loggedIn ? (\r\n                <div className=\"p-12 text-center space-y-4 bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800\">\r\n                  <Key size={48} className=\"mx-auto text-slate-300\" />\r\n                  <p className=\"text-slate-500\">в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•ӘВ¬в•Әв”Ӯв•ӘВјв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ в•ӘГәв”ҳГӘв”ҳГӨв•ӘВәв”ҳГҜ в”ҳГ в”ҳГҘ в”ҳГӨв”ҳГӘв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ  в”ҳГӨв”ҳГӨв”ҳГӘв•Әв•Ўв”ҳГӘв”ҳГӨ в”ҳГӨв•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВәв•ӘВ«в”ҳГЁв•Әв•Ў.</p>\r\n                </div>\r\n              ) : (\r\n                <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6\">\r\n                  {/* Left Column: Management */}\r\n                  <div className=\"lg:col-span-8 flex flex-col gap-6\">\r\n                    <Card className=\"p-6 rounded-3xl space-y-6\">\r\n                      <div className=\"flex items-center justify-between gap-4 flex-wrap\">\r\n                        <h3 className=\"font-bold text-slate-800 dark:text-white flex items-center gap-2\">\r\n                          <Activity size={20} className=\"text-indigo-600\" />\r\n                          в”ҳГ©в•ӘВәв•ӘВӘв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в”ҳГјв•ӘВәв•ӘВ¬в”ҳГЁв•ӘВЎ в•ӘВәв”ҳГӨв”ҳГ в•Әв•Ўв•ӘВ»в•Әв–’в•ӘвҢҗ\r\n                        </h3>\r\n                        <div className=\"flex items-center gap-2 flex-1 max-w-md\">\r\n                          <div className=\"relative flex-1\">\r\n                            <Search className=\"absolute right-3 top-1/2 -translate-y-1/2 text-slate-400\" size={16} />\r\n                            <Input\r\n                              value={q}\r\n                              onChange={(e) => setQ(e.target.value)}\r\n                              onKeyDown={(e) => e.key === 'Enter' && refreshList()}\r\n                              placeholder=\"в•ӘВҝв•ӘВЎв•ӘВҪ в•ӘВҝв•Әв–’в”ҳГ©в”ҳГ  в•ӘВәв”ҳГӨв”ҳГўв”ҳГӘв•ӘВ» в•ӘГәв”ҳГӘ в•ӘВәв”ҳГӨв•ӘВәв•Әв”Ӯв”ҳГ ...\"\r\n                              className=\"pr-10\"\r\n                            />\r\n                          </div>\r\n                          <Button onClick={() => void refreshList()} disabled={busy}>в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ</Button>\r\n                        </div>\r\n                      </div>\r\n\r\n                      <div className=\"app-table-wrapper rounded-2xl border border-slate-100 dark:border-slate-800\">\r\n                        <table className=\"app-table\">\r\n                          <thead className=\"app-table-thead\">\r\n                            <tr>\r\n                              <th className=\"app-table-th\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГјв•ӘВ¬в•ӘВәв•ӘВЎ</th>\r\n                              <th className=\"app-table-th\">в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГЁв”ҳГӨ</th>\r\n                              <th className=\"app-table-th text-center\">в•ӘВәв”ҳГӨв•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ</th>\r\n                              <th className=\"app-table-th text-center\">в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ</th>\r\n                              <th className=\"app-table-th text-center\">в•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯ</th>\r\n                            </tr>\r\n                          </thead>\r\n                          <tbody className=\"divide-y divide-slate-100/50 dark:divide-slate-800/50\">\r\n                            {items.slice(0, 50).map((it) => (\r\n                              <tr\r\n                                key={it.licenseKey}\r\n                                onClick={() => setSelectedKey(it.licenseKey)}\r\n                                className={`app-table-row group transition-all cursor-pointer ${\r\n                                  selectedKey === it.licenseKey ? 'bg-indigo-50/50 dark:bg-indigo-900/10' : ''\r\n                                }`}\r\n                              >\r\n                                <td className=\"app-table-td\">\r\n                                  <div className=\"flex items-center gap-2\">\r\n                                    <div className=\"p-1.5 bg-slate-100 dark:bg-slate-800 text-slate-400 rounded\">\r\n                                      <Key size={12} />\r\n                                    </div>\r\n                                    <span className=\"font-mono text-xs font-black\" dir=\"ltr\">{it.licenseKey}</span>\r\n                                  </div>\r\n                                </td>\r\n                                <td className=\"app-table-td\">\r\n                                  <div className=\"flex flex-col\">\r\n                                    <span className=\"text-sm font-bold\">{it.customerName || 'О“ГҮГ¶'}</span>\r\n                                    <span className=\"text-[10px] text-slate-400\">{it.customerCompany || 'в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в•Әв”Өв•Әв–’в”ҳГўв•ӘвҢҗ'}</span>\r\n                                  </div>\r\n                                </td>\r\n                                <td className=\"app-table-td text-center\">\r\n                                  <StatusBadge status={licenseStatusToArabic(it.status || '')} className=\"!text-[10px] !px-2 !py-0.5\" />\r\n                                </td>\r\n                                <td className=\"app-table-td text-center\">\r\n                                  <span className=\"text-xs font-black bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded-lg\">\r\n                                    {it.activationsCount || 0} / {it.maxActivations || 'О“ГҮГ¶'}\r\n                                  </span>\r\n                                </td>\r\n                                <td className=\"app-table-td\">\r\n                                  <div className=\"flex justify-center opacity-0 group-hover:opacity-100 transition-opacity\">\r\n                                    <button className=\"p-2 text-indigo-500 hover:bg-white dark:hover:bg-slate-800 rounded-xl shadow-sm border border-slate-100 dark:border-slate-700\">\r\n                                      <Info size={14} />\r\n                                    </button>\r\n                                  </div>\r\n                                </td>\r\n                              </tr>\r\n                            ))}\r\n                          </tbody>\r\n                        </table>\r\n                      </div>\r\n                    </Card>\r\n                  </div>\r\n\r\n                  {/* Right Column: Actions & Details */}\r\n                  <div className=\"lg:col-span-4 space-y-6\">\r\n                    {/* Issue New */}\r\n                    <Card className=\"p-6 rounded-3xl space-y-4 border-2 border-indigo-100 dark:border-indigo-900/30\">\r\n                      <h4 className=\"font-bold text-slate-800 dark:text-white flex items-center gap-2\">\r\n                        <Plus size={18} className=\"text-indigo-600\" />\r\n                        в•ӘГ‘в•Әв•Ўв•ӘВ»в•ӘВәв•Әв–’ в”ҳГ в”ҳГјв•ӘВ¬в•ӘВәв•ӘВЎ в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»\r\n                      </h4>\r\n                      <div className=\"space-y-4\">\r\n                        <div className=\"grid grid-cols-2 gap-3\">\r\n                          <div className=\"space-y-1\">\r\n                            <label className=\"text-[10px] font-black text-slate-400 uppercase\">в•ӘВәв”ҳГӨв•ӘГәв•ӘВјв”ҳГ§в•Әв–“в•ӘвҢҗ (Max)</label>\r\n                            <Input type=\"number\" value={issueMaxActivations} onChange={(e) => setIssueMaxActivations(e.target.value)} />\r\n                          </div>\r\n                          <div className=\"space-y-1\">\r\n                            <label className=\"text-[10px] font-black text-slate-400 uppercase\">в•ӘВәв”ҳГӨв”ҳГ в•ӘВ»в•ӘвҢҗ</label>\r\n                            <Select\r\n                              value={issueDuration}\r\n                              onChange={(e) => applyIssueDuration(e.target.value as IssueDuration)}\r\n                              options={[\r\n                                { value: 'trial14d', label: 'в•ӘВ¬в•ӘВјв•Әв–’в”ҳГЁв•ӘВҝв”ҳГЁ 14 в”ҳГЁв”ҳГӘв”ҳГ ' },\r\n                                { value: '1m', label: 'в•Әв”Өв”ҳГ§в•Әв–’ в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ»' },\r\n                                { value: '3m', label: '3 в•ӘГәв•Әв”Өв”ҳГ§в•Әв–’' },\r\n                                { value: '6m', label: '6 в•ӘГәв•Әв”Өв”ҳГ§в•Әв–’' },\r\n                                { value: '1y', label: 'в•Әв”Ӯв”ҳГҘв•ӘвҢҗ в”ҳГўв•ӘВәв”ҳГ в”ҳГӨв•ӘвҢҗ' },\r\n                                { value: 'custom', label: 'в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ў' },\r\n                              ]}\r\n                            />\r\n                          </div>\r\n                        </div>\r\n                        <div className=\"space-y-1\">\r\n                          <label className=\"text-[10px] font-black text-slate-400 uppercase\">в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ« в•ӘВәв”ҳГӨв•ӘВәв”ҳГҘв•ӘВ¬в”ҳГ§в•ӘВәв•ӘГӯ</label>\r\n                          <Input type=\"date\" value={issueExpiresAt} onChange={(e) => setIssueExpiresAt(e.target.value)} />\r\n                        </div>\r\n                        <Button onClick={() => void doIssue()} isLoading={busy} className=\"w-full\">в•ӘГ‘в•Әв•Ўв•ӘВ»в•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•ӘГів”ҳГҘ</Button>\r\n                      </div>\r\n                    </Card>\r\n\r\n                    {/* Selected Item Details (Drawer alternative) */}\r\n                    {selectedRecord && (\r\n                      <Card className=\"p-6 rounded-3xl space-y-6 border-l-4 border-l-indigo-600 animate-slide-left\">\r\n                        <div className=\"flex items-center justify-between\">\r\n                          <h4 className=\"font-black text-slate-800 dark:text-white\">в•ӘВ¬в”ҳГјв•ӘВәв•Әв•Ўв”ҳГЁв”ҳГӨ: {selectedKey.slice(0, 8)}...</h4>\r\n                          <button onClick={() => void doDelete()} className=\"p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-xl transition\">\r\n                            <Trash2 size={16} />\r\n                          </button>\r\n                        </div>\r\n                        \r\n                        <div className=\"space-y-4\">\r\n                          <div className=\"flex items-center justify-between p-3 bg-slate-50 dark:bg-slate-800/40 rounded-2xl\">\r\n                            <span className=\"text-xs text-slate-500\">в•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГўв”ҳГӘв•ӘВ»</span>\r\n                            <Select\r\n                              className=\"w-32 !py-1 !px-2 !text-xs\"\r\n                              value={setStatusValue}\r\n                          onChange={(e) => setSetStatusValue(e.target.value as 'active' | 'suspended' | 'revoked')}\r\n                              options={[\r\n                                { value: 'active', label: 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ' },\r\n                                { value: 'suspended', label: 'в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©' },\r\n                                { value: 'revoked', label: 'в”ҳГ в”ҳГӨв•Әв•‘в”ҳГЁ' },\r\n                              ]}\r\n                            />\r\n                          </div>\r\n                          \r\n                          <div className=\"space-y-1\">\r\n                            <label className=\"text-[10px] font-black text-slate-400 uppercase px-1\">в•ӘВҝв•Әв•Ўв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГЁв”ҳГӨ (в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ)</label>\r\n                            <div className=\"flex gap-2\">\r\n                              <Input\r\n                                value={activateDeviceId}\r\n                                onChange={(e) => setActivateDeviceId(e.target.value)}\r\n                                placeholder=\"Fingerprint...\"\r\n                                className=\"font-mono text-xs\"\r\n                              />\r\n                              <Button variant=\"secondary\" onClick={() => void doActivate()} disabled={busy}><Smartphone size={16} /></Button>\r\n                            </div>\r\n                          </div>\r\n\r\n                          <div className=\"space-y-1\">\r\n                            <label className=\"text-[10px] font-black text-slate-400 uppercase px-1\">в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГЁв”ҳГӨ (в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј)</label>\r\n                            <Input value={customerName} onChange={(e) => setCustomerName(e.target.value)} placeholder=\"в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГЁв”ҳГӨ\" className=\"text-xs\" />\r\n                            <Input value={customerCompany} onChange={(e) => setCustomerCompany(e.target.value)} placeholder=\"в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•ӘВҝ/в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в”ҳГўв•ӘвҢҗ\" className=\"text-xs\" />\r\n                          </div>\r\n\r\n                          <Button onClick={() => void doUpdateAfterSales()} isLoading={busy} className=\"w-full\" variant=\"secondary\">в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨв•ӘВәв•ӘВ¬</Button>\r\n                        </div>\r\n                      </Card>\r\n                    )}\r\n                  </div>\r\n                </div>\r\n              )}\r\n            </div>\r\n          )}\r\n\r\n          {activeTab === 'customers' && (\r\n            <div className=\"space-y-6\">\r\n              <Card className=\"p-6 rounded-3xl space-y-6\">\r\n                <div className=\"flex items-center justify-between gap-4 flex-wrap\">\r\n                  <div className=\"flex items-center gap-3\">\r\n                    <div className=\"p-3 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 rounded-xl\">\r\n                      <CustomersIcon size={24} />\r\n                    </div>\r\n                    <div>\r\n                      <h3 className=\"text-xl font-bold text-slate-800 dark:text-white\">в”ҳГ©в•ӘВәв•ӘВӘв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГҘв•Әв”Өв•Әв•–в”ҳГЁв”ҳГҘ</h3>\r\n                      <p className=\"text-sm text-slate-500 dark:text-slate-400 mt-1\">в•ӘВ¬в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв”ҳГ в”ҳГјв•ӘВәв•ӘВ¬в”ҳГЁв•ӘВЎ в•ӘВәв”ҳГӨв•Әв•Ўв•ӘВәв•ӘВ»в•Әв–’в•ӘвҢҗ в•ӘВЎв•Әв”Ӯв•ӘВҝ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГўв”ҳГӨ в•Әв•Јв”ҳГ в”ҳГЁв”ҳГӨ.</p>\r\n                    </div>\r\n                  </div>\r\n                  <div className=\"relative w-full md:w-80\">\r\n                    <Search className=\"absolute right-3 top-1/2 -translate-y-1/2 text-slate-400\" size={16} />\r\n                    <Input\r\n                      value={customerSearch}\r\n                      onChange={(e) => setCustomerSearch(e.target.value)}\r\n                      placeholder=\"в•ӘВҝв•ӘВЎв•ӘВҪ в•ӘВҝв•ӘВәв”ҳГӨв•ӘВәв•Әв”Ӯв”ҳГ  в•ӘГәв”ҳГӘ в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в”ҳГўв•ӘвҢҗ...\"\r\n                      className=\"pr-10\"\r\n                    />\r\n                  </div>\r\n                </div>\r\n\r\n                <div className=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4\">\r\n                  {filteredCustomerGroups.map((g, idx) => (\r\n                    <div\r\n                      key={idx}\r\n                      className=\"app-card p-5 rounded-3xl space-y-4 hover:shadow-lg transition-all border border-slate-100 dark:border-slate-800 group\"\r\n                    >\r\n                      <div className=\"flex items-start justify-between\">\r\n                        <div className=\"min-w-0\">\r\n                          <h4 className=\"font-bold text-slate-800 dark:text-white truncate\" title={g.label}>{g.label}</h4>\r\n                          <p className=\"text-xs text-slate-400 mt-1 truncate\">{g.company || 'в”ҳГјв•Әв–’в•ӘВ»в”ҳГЁ'}</p>\r\n                        </div>\r\n                        <div className=\"bg-indigo-50 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-400 px-3 py-1 rounded-full text-xs font-black\">\r\n                          {g.items.length} в”ҳГўв”ҳГӘв•ӘВ»\r\n                        </div>\r\n                      </div>\r\n                      \r\n                      <div className=\"space-y-2\">\r\n                        {g.items.slice(0, 3).map(it => (\r\n                          <div key={it.licenseKey} className=\"flex items-center justify-between text-[11px] bg-slate-50 dark:bg-slate-800/40 p-2 rounded-xl border border-slate-100 dark:border-slate-800\">\r\n                            <span className=\"font-mono\" dir=\"ltr\">{it.licenseKey.slice(0, 8)}...</span>\r\n                            <StatusBadge status={licenseStatusToArabic(it.status || '')} className=\"!text-[9px] !px-1.5 !py-0\" />\r\n                          </div>\r\n                        ))}\r\n                        {g.items.length > 3 && (\r\n                          <p className=\"text-[10px] text-slate-400 text-center\">+ {g.items.length - 3} в•Әв–’в”ҳГ в”ҳГӘв•Әв–“ в•ӘГәв•ӘВ«в•Әв–’в”ҳГ«</p>\r\n                        )}\r\n                      </div>\r\n\r\n                      <button\r\n                        onClick={() => { setActiveTab('licenses'); setQ(g.label); refreshList(); }}\r\n                        className=\"w-full py-2 rounded-xl text-xs font-bold text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-all border border-indigo-100 dark:border-indigo-900/30\"\r\n                      >\r\n                        в•Әв•Јв•Әв–’в•Әв•ў в”ҳГўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГјв•ӘВәв•Әв•Ўв”ҳГЁв”ҳГӨ\r\n                      </button>\r\n                    </div>\r\n                  ))}\r\n                </div>\r\n              </Card>\r\n            </div>\r\n          )}\r\n\r\n          {activeTab === 'settings' && (\r\n            <div className=\"max-w-2xl mx-auto space-y-6\">\r\n              <Card className=\"p-8 rounded-3xl space-y-8\">\r\n                <div className=\"text-center space-y-3\">\r\n                  <div className=\"w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-full flex items-center justify-center mx-auto text-slate-400\">\r\n                    <SettingsIcon size={40} />\r\n                  </div>\r\n                  <h3 className=\"text-xl font-bold text-slate-800 dark:text-white\">в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в”ҳГ в”ҳГӨв”ҳГј в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•Әв•‘в”ҳГӨ (Server Admin)</h3>\r\n                  <p className=\"text-sm text-slate-500\">в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ«в•ӘВәв•Әв•Ўв•ӘвҢҗ в•ӘВҝв”ҳГў в”ҳГӨв”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•ӘВ«в•ӘВәв•ӘВ»в”ҳГ  в”ҳГјв”ҳГ©в•Әв•–.</p>\r\n                </div>\r\n\r\n                <div className=\"space-y-6\">\r\n                  <div className=\"space-y-2\">\r\n                    <label className=\"text-sm font-bold text-slate-700 dark:text-slate-200\">в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в•ӘВәв”ҳГӨв•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»</label>\r\n                    <Input\r\n                      value={newUsername}\r\n                      onChange={(e) => setNewUsername(e.target.value)}\r\n                      placeholder=\"admin_new\"\r\n                    />\r\n                  </div>\r\n                  \r\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n                    <div className=\"space-y-2\">\r\n                      <label className=\"text-sm font-bold text-slate-700 dark:text-slate-200\">в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘВәв”ҳГӨв•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»в•ӘвҢҗ</label>\r\n                      <Input\r\n                        type=\"password\"\r\n                        value={newPassword}\r\n                        onChange={(e) => setNewPassword(e.target.value)}\r\n                        placeholder=\"О“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГі\"\r\n                      />\r\n                    </div>\r\n                    <div className=\"space-y-2\">\r\n                      <label className=\"text-sm font-bold text-slate-700 dark:text-slate-200\">в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’</label>\r\n                      <Input\r\n                        type=\"password\"\r\n                        value={confirmPassword}\r\n                        onChange={(e) => setConfirmPassword(e.target.value)}\r\n                        placeholder=\"О“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГі\"\r\n                      />\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"p-4 bg-amber-50 dark:bg-amber-900/10 rounded-2xl border border-amber-100 dark:border-amber-900/30\">\r\n                    <div className=\"flex gap-3 text-amber-700 dark:text-amber-400\">\r\n                      <History size={20} className=\"shrink-0\" />\r\n                      <p className=\"text-xs leading-relaxed\">\r\n                        О“ГңГЎвҲ©в••Г… в•ӘВ¬в”ҳГҘв•ӘВҝв”ҳГЁв”ҳГ§: в•ӘВ¬в•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•Әв”Ӯв”ҳГЁв•ӘГұв•ӘВ»в”ҳГЁ в•ӘГ‘в”ҳГӨв”ҳГ« в•ӘГ‘в”ҳГҘв”ҳГ§в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв•ӘВјв”ҳГӨв•Әв”Ӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВЎв•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ. в•Әв”Ӯв”ҳГЁв•ӘВ¬в•Әв•Јв”ҳГЁв”ҳГҘ в•Әв•Јв”ҳГӨв”ҳГЁв”ҳГў в•ӘВ¬в•Әв”Ӯв•ӘВјв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ в”ҳГ в•Әв–’в•ӘвҢҗ в•ӘГәв•ӘВ«в•Әв–’в”ҳГ« в•ӘВҝв•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»в•ӘвҢҗ.\r\n                      </p>\r\n                    </div>\r\n                  </div>\r\n\r\n                  <Button onClick={() => void doUpdateServerUser()} isLoading={busy} className=\"w-full py-6 text-lg\">\r\n                    <Save size={18} className=\"ml-2\" />\r\n                    в•ӘВЎв”ҳГјв•Әв•• в”ҳГӘв•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ\r\n                  </Button>\r\n                </div>\r\n              </Card>\r\n\r\n              {/* Server Info / Token Area */}\r\n              <Card className=\"p-6 rounded-3xl space-y-4\">\r\n                <h4 className=\"font-bold text-slate-800 dark:text-white flex items-center gap-2\">\r\n                  <Key size={18} className=\"text-indigo-600\" />\r\n                  в•ӘВ¬в”ҳГӘв”ҳГўв”ҳГҘ в•ӘВәв”ҳГӨв•ӘГәв”ҳГ в•ӘВәв”ҳГҘ в”ҳГӨв”ҳГӨв•Әв”Ӯв”ҳГЁв•Әв–’в”ҳГјв•Әв–’ (Admin Token)\r\n                </h4>\r\n                <div className=\"flex gap-2\">\r\n                  <Input\r\n                    type=\"password\"\r\n                    value={serverAdminToken}\r\n                    onChange={(e) => setServerAdminToken(e.target.value)}\r\n                    placeholder=\"в•Ә