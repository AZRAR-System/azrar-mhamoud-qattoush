from '@/components/ui/Input';\r\nimport { useDbSignal } from '@/hooks/useDbSignal';\r\nimport { runReportSmart } from '@/services/reporting';\r\nimport { PaginationControls } from '@/components/shared/PaginationControls';\r\nimport { getErrorMessage } from '@/utils/errors';\r\nimport { Button } from '@/components/ui/Button';\r\nimport {\r\n  FinancialReportPrintPreview,\r\n  type FinancialReportTemplateData,\r\n} from '@/components/printing/templates/FinancialReportTemplate';\r\n\r\nconst CATEGORIES: { id: ReportCategory; label: string; icon: LucideIcon; color: string }[] = [\r\n  { id: 'Financial', label: 'в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ', icon: Wallet, color: 'bg-emerald-500' },\r\n  { id: 'Contracts', label: 'в•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ»', icon: FileText, color: 'bg-indigo-500' },\r\n  { id: 'Properties', label: 'в•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’в•ӘВәв•ӘВ¬', icon: Building2, color: 'bg-purple-500' },\r\n  { id: 'Tenants', label: 'в•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘГәв•ӘВјв•Әв–’в”ҳГЁв”ҳГҘ', icon: Users, color: 'bg-orange-500' },\r\n  { id: 'Maintenance', label: 'в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗ в”ҳГӘв•ӘВәв”ҳГӨв•ӘВ»в•Әв•Јв”ҳГ ', icon: Wrench, color: 'bg-slate-500' },\r\n];\r\n\r\nconst CategorySection: React.FC<{\r\n  cat: { id: ReportCategory; label: string; icon: LucideIcon; color: string };\r\n  catReports: ReportDefinition[];\r\n  openPanel: (type: string, id: string) => void;\r\n  resetKey: string;\r\n}> = ({ cat, catReports, openPanel, resetKey }) => {\r\n  const [page, setPage] = useState(1);\r\n  const [pageSize, setPageSize] = useState(6);\r\n\r\n  useEffect(() => {\r\n    const compute = () => {\r\n      if (typeof window === 'undefined') return;\r\n      const w = window.innerWidth;\r\n      if (w < 640) setPageSize(4);\r\n      else if (w < 1024) setPageSize(6);\r\n      else setPageSize(9);\r\n    };\r\n    compute();\r\n    window.addEventListener('resize', compute);\r\n    return () => window.removeEventListener('resize', compute);\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    setPage(1);\r\n  }, [resetKey, cat.id]);\r\n\r\n  const safePageSize = Math.max(1, Math.floor(pageSize));\r\n  const pageCount = Math.max(1, Math.ceil(catReports.length / safePageSize));\r\n\r\n  useEffect(() => {\r\n    setPage((p) => Math.min(Math.max(1, p), pageCount));\r\n  }, [pageCount]);\r\n\r\n  const visible = catReports.slice((page - 1) * safePageSize, page * safePageSize);\r\n\r\n  return (\r\n    <div className=\"app-card\">\r\n      <div className=\"p-4 border-b border-gray-100 dark:border-slate-700 flex items-center gap-3 bg-gray-50 dark:bg-slate-900/50\">\r\n        <div className={`p-2 rounded-lg text-white ${cat.color}`}>\r\n          <cat.icon size={20} />\r\n        </div>\r\n        <div className=\"flex flex-wrap items-center justify-between w-full gap-3\">\r\n          <div>\r\n            <h3 className=\"font-bold text-lg text-slate-800 dark:text-white\">{cat.label}</h3>\r\n            <span className=\"text-xs text-slate-500 dark:text-slate-400\">\r\n              {formatNumber(catReports.length)} в•ӘВ¬в”ҳГ©в•Әв–’в”ҳГЁв•Әв–’\r\n            </span>\r\n          </div>\r\n          <PaginationControls page={page} pageCount={pageCount} onPageChange={setPage} />\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"p-2 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3\">\r\n        {visible.map((rep) => (\r\n          <button\r\n            key={rep.id}\r\n            onClick={() => openPanel('REPORT_VIEWER', rep.id)}\r\n            className=\"flex items-start gap-4 p-4 rounded-xl hover:bg-indigo-50 dark:hover:bg-slate-700/50 transition text-right group border border-transparent hover:border-indigo-100 dark:hover:border-slate-600\"\r\n          >\r\n            <div className=\"mt-1 p-2 bg-gray-100 dark:bg-slate-700 rounded-lg group-hover:bg-white dark:group-hover:bg-slate-600 text-slate-500 dark:text-slate-400 transition\">\r\n              <BarChart3 size={18} />\r\n            </div>\r\n            <div>\r\n              <h4 className=\"font-bold text-slate-700 dark:text-slate-200 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition\">\r\n                {rep.title}\r\n              </h4>\r\n              <p className=\"text-xs text-slate-500 dark:text-slate-400 mt-1 leading-relaxed\">\r\n                {rep.description}\r\n              </p>\r\n            </div>\r\n            <ArrowRight\r\n              size={16}\r\n              className=\"mr-auto text-gray-300 group-hover:text-indigo-500 opacity-0 group-hover:opacity-100 transition-all self-center\"\r\n            />\r\n          </button>\r\n        ))}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport const Reports: React.FC = () => {\r\n  const isDesktop = typeof window !== 'undefined' && !!window.desktopDb;\r\n  const [reports, setReports] = useState<ReportDefinition[]>([]);\r\n  const [search, setSearch] = useState('');\r\n  const [financialPrintOpen, setFinancialPrintOpen] = useState(false);\r\n  const [kpis, setKpis] = useState<{\r\n    totalExpected: number;\r\n    totalPaid: number;\r\n    totalLate: number;\r\n    totalUpcoming: number;\r\n    remaining: number;\r\n    lateCount: number;\r\n    activeContracts: number;\r\n    openTickets: number;\r\n    generatedAt?: string;\r\n  } | null>(null);\r\n  const [kpisError, setKpisError] = useState<string | null>(null);\r\n  const [isExportingAll, setIsExportingAll] = useState(false);\r\n  const { openPanel } = useSmartModal();\r\n  const toast = useToast();\r\n\r\n  const dbSignal = useDbSignal();\r\n\r\n  useEffect(() => {\r\n    setReports(DbService.getAvailableReports());\r\n  }, [dbSignal]);\r\n\r\n  useEffect(() => {\r\n    let cancelled = false;\r\n    (async () => {\r\n      try {\r\n        const financial = await runReportSmart('financial_summary');\r\n        const late = await runReportSmart('late_installments');\r\n        const contractsActive = await runReportSmart('contracts_active');\r\n        const openTickets = await runReportSmart('maintenance_open_tickets');\r\n\r\n        const isRecord = (v: unknown): v is Record<string, unknown> =>\r\n          typeof v === 'object' && v !== null;\r\n\r\n        const lookup = new Map<string, unknown>();\r\n        for (const row of Array.isArray(financial?.data) ? financial.data : []) {\r\n          if (!isRecord(row)) continue;\r\n          const item = row.item;\r\n          if (typeof item !== 'string' || !item.trim()) continue;\r\n          lookup.set(item, row.value);\r\n        }\r\n\r\n        const totalExpected = Number(lookup.get('в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в”ҳГӘв”ҳГ©в•Әв•Ј') ?? 0) || 0;\r\n        const totalPaid = Number(lookup.get('в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•Әв•Ўв”ҳГӨ') ?? 0) || 0;\r\n        const totalLate = Number(lookup.get('в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘГәв•ӘВ«в•Әв–’') ?? 0) || 0;\r\n        const totalUpcoming = Number(lookup.get('в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ©в•ӘВәв•ӘВ»в”ҳГ ') ?? 0) || 0;\r\n        const remaining = Number(lookup.get('в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВҝв”ҳГ©в”ҳГЁ') ?? totalExpected - totalPaid) || 0;\r\n\r\n        if (cancelled) return;\r\n        setKpisError(null);\r\n        setKpis({\r\n          totalExpected,\r\n          totalPaid,\r\n          totalLate,\r\n          totalUpcoming,\r\n          remaining,\r\n          lateCount: Array.isArray(late?.data) ? late.data.length : 0,\r\n          activeContracts: Array.isArray(contractsActive?.data) ? contractsActive.data.length : 0,\r\n          openTickets: Array.isArray(openTickets?.data) ? openTickets.data.length : 0,\r\n          generatedAt: financial?.generatedAt,\r\n        });\r\n      } catch (e: unknown) {\r\n        console.error('Failed to compute report KPIs', e);\r\n        if (cancelled) return;\r\n        setKpis(null);\r\n        setKpisError(getErrorMessage(e) || 'в•ӘВ¬в•Әв•Јв•Әв–‘в•Әв–’ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в”ҳГ в”ҳГӨв•ӘВ«в•Әв•Ў в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј');\r\n      }\r\n    })();\r\n    return () => {\r\n      cancelled = true;\r\n    };\r\n  }, [dbSignal]);\r\n\r\n  const filteredReports = useMemo(() => {\r\n    const q = search.trim().toLowerCase();\r\n    if (!q) return reports;\r\n    return reports.filter((r) => {\r\n      const title = String(r.title || '').toLowerCase();\r\n      const desc = String(r.description || '').toLowerCase();\r\n      return title.includes(q) || desc.includes(q);\r\n    });\r\n  }, [reports, search]);\r\n\r\n  const reportsCount = filteredReports.length;\r\n\r\n  const financialPrintData: FinancialReportTemplateData | null = useMemo(() => {\r\n    if (!kpis) return null;\r\n    return {\r\n      periodLabel: kpis.generatedAt ? formatDateYMD(kpis.generatedAt) : undefined,\r\n      totalRevenue: kpis.totalExpected,\r\n      contractsCount: kpis.activeContracts,\r\n      collections: kpis.totalPaid,\r\n      arrears: kpis.totalLate,\r\n      documentTitle: 'в•ӘВ¬в”ҳГ©в•Әв–’в”ҳГЁв•Әв–’ в”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј',\r\n      footerNote: [\r\n        `в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВҝв”ҳГ©в”ҳГЁ в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ: ${formatCurrencyJOD(kpis.remaining, { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`,\r\n        `в•ӘВәв”ҳГӨв”ҳГ©в•ӘВәв•ӘВ»в”ҳГ : ${formatCurrencyJOD(kpis.totalUpcoming, { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`,\r\n        `в•Әв•Јв•ӘВ»в•ӘВ» в•ӘВәв”ҳГӨв”ҳГўв”ҳГ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘГәв•ӘВ«в•Әв–’в•ӘвҢҗ: ${formatNumber(kpis.lateCount)}`,\r\n      ].join('\\n'),\r\n    };\r\n  }, [kpis]);\r\n\r\n  const handlePrintDashboard = () => {\r\n    window.print();\r\n  };\r\n\r\n  const handleExportAllToExcel = async () => {\r\n    if (isExportingAll) return;\r\n    setIsExportingAll(true);\r\n    const tid = toast.loading('в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВ¬в•Әв”Өв•Әв•‘в”ҳГЁв”ҳГӨ в”ҳГўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’ в”ҳГӘв•ӘВ¬в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬...');\r\n\r\n    try {\r\n      const allReportIds = reports.map((r) => r.id);\r\n      const results = await Promise.all(\r\n        allReportIds.map(async (id) => {\r\n          try {\r\n            return { id, res: await runReportSmart(id) };\r\n          } catch {\r\n            return { id, res: null };\r\n          }\r\n        })\r\n      );\r\n\r\n      const sheets: ExtraSheet[] = results\r\n        .filter((r) => r.res && r.res.data)\r\n        .map((r) => {\r\n          const rep = r.res!;\r\n          const headers = rep.columns.map((c) => c.header);\r\n          const dataRows = (rep.data || []).map((row: Record<string, unknown>) =>\r\n            rep.columns.map((col) => row[col.key] ?? '')\r\n          );\r\n          return {\r\n            name: String(rep.title || r.id).slice(0, 31).replace(/[\\\\/:*?\"<>|]/g, '_'),\r\n            rows: [headers, ...dataRows],\r\n          };\r\n        });\r\n\r\n      if (sheets.length === 0) {\r\n        toast.error('в”ҳГӨв”ҳГ  в”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•Әв•Јв•ӘВҪв”ҳГӘв•Әв–’ в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГӨв•ӘВ¬в•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’в”ҳГ§в•ӘВә', { id: tid });\r\n        return;\r\n      }\r\n\r\n      // First sheet will be the Financial Summary KPIs if available\r\n      const kpiRows: (string | number | boolean | null | undefined)[][] = [['в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’/в•ӘВәв”ҳГӨв•ӘВ¬в•Әв•Ўв”ҳГҘв”ҳГЁв”ҳГј', 'в•ӘВәв”ҳГӨв”ҳГ©в”ҳГЁв”ҳГ в•ӘвҢҗ']];\r\n      if (kpis) {\r\n        kpiRows.push(['в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в”ҳГӘв”ҳГ©в•Әв•Ј', kpis.totalExpected]);\r\n        kpiRows.push(['в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•Әв•Ўв”ҳГӨ', kpis.totalPaid]);\r\n        kpiRows.push(['в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘГәв•ӘВ«в•Әв–’', kpis.totalLate]);\r\n        kpiRows.push(['в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ» в•ӘВәв”ҳГӨв”ҳГҘв•Әв”Өв•Әв•–в•ӘвҢҗ', kpis.activeContracts]);\r\n        kpiRows.push(['в•ӘВ¬в•Әв–‘в•ӘВәв”ҳГўв•Әв–’ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗ', kpis.openTickets]);\r\n      }\r\n\r\n      await exportToXlsx(\r\n        'в•ӘВәв”ҳГӨв”ҳГ в”ҳГӨв•ӘВ«в•Әв•Ў в•ӘВәв”ҳГӨв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ',\r\n        [{ key: 'label', header: 'в•ӘВәв”ҳГӨв”ҳГ в•ӘВјв•ӘВәв”ҳГӨ' }, { key: 'value', header: 'в•ӘВәв”ҳГӨв”ҳГҘв•ӘВ¬в”ҳГЁв•ӘВјв•ӘвҢҗ' }],\r\n        kpis ? [\r\n          { label: 'в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в”ҳГӘв”ҳГ©в•Әв•Ј', value: kpis.totalExpected },\r\n          { label: 'в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•Әв•Ўв”ҳГӨ', value: kpis.totalPaid },\r\n          { label: 'в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘГәв•ӘВ«в•Әв–’', value: kpis.totalLate },\r\n          { label: 'в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ» в•ӘВәв”ҳГӨв”ҳГҘв•Әв”Өв•Әв•–в•ӘвҢҗ', value: kpis.activeContracts },\r\n          { label: 'в•ӘВ¬в•Әв–‘в•ӘВәв”ҳГўв•Әв–’ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗ', value: kpis.openTickets },\r\n        ] : [],\r\n        `в•ӘВ¬в”ҳГ©в•Әв–’в”ҳГЁв•Әв–’_в•Әв”Өв•ӘВәв”ҳГ в”ҳГӨ_${new Date().toISOString().slice(0, 10)}.xlsx`,\r\n        { extraSheets: sheets }\r\n      );\r\n\r\n      toast.success('О“ВЈГ  в•ӘВ¬в”ҳГ  в•ӘВ¬в•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’ в”ҳГўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’ в”ҳГјв”ҳГЁ в”ҳГ в”ҳГӨв”ҳГј Excel в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ» в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ', { id: tid });\r\n    } catch (err) {\r\n      console.error('Unified export failed:', err);\r\n      toast.error('О“ВҘГ® в”ҳГјв•Әв”Өв”ҳГӨ в”ҳГјв”ҳГЁ в•ӘВ¬в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГӘв•ӘВ¬в•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӨв”ҳГј', { id: tid });\r\n    } finally {\r\n      setIsExportingAll(false);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"animate-fade-in space-y-8 pb-10\">\r\n      <div className={DS.components.pageHeader}>\r\n        <div>\r\n          <h2 className={`${DS.components.pageTitle} flex items-center gap-2`}>\r\n            <BarChart3 className=\"text-indigo-600\" /> в”ҳГ в•Әв–’в”ҳГўв•Әв–“ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в”ҳГ©в•ӘВ»в”ҳГ \r\n          </h2>\r\n          <p className={DS.components.pageSubtitle}>\r\n            в•ӘВ¬в”ҳГӘв”ҳГӨв”ҳГЁв•ӘВ» в•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’ в•ӘВ¬в”ҳГјв•Әв•Ўв”ҳГЁв”ҳГӨв”ҳГЁв•ӘвҢҗ в•Әв•Јв”ҳГҘ в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  в”ҳГ в•Әв•Ј в•ӘГ‘в”ҳГ в”ҳГўв•ӘВәв”ҳГҘв”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’ в”ҳГӘв•ӘВәв”ҳГӨв•Әв•–в•ӘВҝв•ӘВәв•Әв•Јв•ӘвҢҗ.\r\n          </p>\r\n          {kpis?.generatedAt ? (\r\n            <p className=\"text-xs text-slate-400 dark:text-slate-500 mt-2\">\r\n              в•ӘГів•ӘВ«в•Әв–’ в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ: {formatDateYMD(kpis.generatedAt)}\r\n            </p>\r\n          ) : null}\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"app-card\">\r\n        <div className=\"p-4 border-b border-gray-100 dark:border-slate-700 flex items-center justify-between bg-gray-50 dark:bg-slate-900/50 gap-3\">\r\n          <div>\r\n            <h3 className=\"font-bold text-lg text-slate-800 dark:text-white\">\r\n              в”ҳГ в”ҳГӨв•ӘВ«в•Әв•Ў в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј (в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВЎв”ҳГ©в”ҳГЁв”ҳГ©в”ҳГЁв•ӘвҢҗ)\r\n            </h3>\r\n            <p className=\"text-xs text-slate-500 dark:text-slate-400 mt-1\">\r\n              в”ҳГ в”ҳГ…в•ӘВЎв•ӘВ¬в•Әв”Ӯв•ӘВҝ в”ҳГ в•ӘВҝв•ӘВәв•Әв”Өв•Әв–’в•ӘвҢҗ в”ҳГ в”ҳГҘ в”ҳГ в•ӘВЎв•Әв–’в”ҳГў в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’\r\n            </p>\r\n          </div>\r\n          <div className=\"flex flex-wrap items-center gap-2 w-full max-w-2xl justify-end\">\r\n            {isDesktop && financialPrintData && !kpisError ? (\r\n              <Button\r\n                type=\"button\"\r\n                variant=\"secondary\"\r\n                className=\"gap-2 shrink-0 h-10 font-black\"\r\n                onClick={() => setFinancialPrintOpen(true)}\r\n              >\r\n                <Printer size={16} />\r\n                в•ӘВ¬в•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’ в•ӘВ¬в”ҳГ©в•Әв–’в”ҳГЁв•Әв–’ в”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ\r\n              </Button>\r\n            ) : null}\r\n            <Button\r\n              type=\"button\"\r\n              variant=\"outline\"\r\n              className=\"gap-2 shrink-0 h-10 font-black border-indigo-200 dark:border-indigo-800 text-indigo-700 dark:text-indigo-300 print:hidden\"\r\n              onClick={handleExportAllToExcel}\r\n              disabled={isExportingAll || reports.length === 0}\r\n            >\r\n              <FileSpreadsheet size={16} />\r\n              в•ӘВ¬в•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’ в”ҳГўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в•ӘВәв•Әв–’в”ҳГЁв•Әв–’\r\n            </Button>\r\n            <Button\r\n              type=\"button\"\r\n              variant=\"ghost\"\r\n              className=\"gap-2 shrink-0 h-10 font-black text-slate-600 dark:text-slate-400 print:hidden\"\r\n              onClick={handlePrintDashboard}\r\n            >\r\n              <Printer size={16} />\r\n              в•Әв•–в•ӘВҝв•ӘВәв•Әв•Јв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӨв•ӘВ«в•Әв•Ў\r\n            </Button>\r\n            <div className=\"flex-1 min-w-[200px] max-w-md print:hidden\">\r\n              <Input\r\n                value={search}\r\n                onChange={(e) => setSearch(e.target.value)}\r\n                placeholder=\"в•ӘВәв•ӘВҝв•ӘВЎв•ӘВҪ в•Әв•Јв”ҳГҘ в•ӘВ¬в”ҳГ©в•Әв–’в”ҳГЁв•Әв–’...\"\r\n                icon={<Search size={16} />}\r\n              />\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        {kpisError ? (\r\n          <div className=\"px-4 pb-2\">\r\n            <div className=\"flex items-start gap-2 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900 dark:border-amber-900/50 dark:bg-amber-950/40 dark:text-amber-100\">\r\n              <AlertCircle className=\"mt-0.5 shrink-0\" size={18} aria-hidden />\r\n              <span>{kpisError}</span>\r\n            </div>\r\n          </div>\r\n        ) : null}\r\n\r\n        <div className=\"p-4 grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-3\">\r\n          <div className=\"rounded-xl border border-gray-100 dark:border-slate-700 p-3\">\r\n            <div className=\"text-xs text-slate-500 dark:text-slate-400\">в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘГәв•ӘВ«в•Әв–’ (в”ҳГ в•ӘВ¬в•ӘВҝв”ҳГ©в”ҳГЁ)</div>\r\n            <div className=\"text-lg font-bold text-slate-800 dark:text-white\">\r\n              {formatCurrencyJOD(kpis?.totalLate ?? 0, {\r\n                minimumFractionDigits: 0,\r\n                maximumFractionDigits: 0,\r\n              })}\r\n            </div>\r\n            <div className=\"text-[11px] text-slate-400 dark:text-slate-500 mt-1\">\r\n              {formatNumber(kpis?.lateCount ?? 0)} в”ҳГўв”ҳГ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГӨв•ӘвҢҗ\r\n            </div>\r\n          </div>\r\n          <div className=\"rounded-xl border border-gray-100 dark:border-slate-700 p-3\">\r\n            <div className=\"text-xs text-slate-500 dark:text-slate-400\">в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•Әв•Ўв”ҳГҰв”ҳГӨ</div>\r\n            <div className=\"text-lg font-bold text-slate-800 dark:text-white\">\r\n              {formatCurrencyJOD(kpis?.totalPaid ?? 0, {\r\n                minimumFractionDigits: 0,\r\n                maximumFractionDigits: 0,\r\n              })}\r\n            </div>\r\n          </div>\r\n          <div className=\"rounded-xl border border-gray-100 dark:border-slate-700 p-3\">\r\n            <div className=\"text-xs text-slate-500 dark:text-slate-400\">в•ӘВәв”ҳГӨв”ҳГ©в•ӘВәв•ӘВ»в”ҳГ </div>\r\n            <div className=\"text-lg font-bold text-slate-800 dark:text-white\">\r\n              {formatCurrencyJOD(kpis?.totalUpcoming ?? 0, {\r\n                minimumFractionDigits: 0,\r\n                maximumFractionDigits: 0,\r\n              })}\r\n            </div>\r\n          </div>\r\n          <div className=\"rounded-xl border border-gray-100 dark:border-slate-700 p-3\">\r\n            <div className=\"text-xs text-slate-500 dark:text-slate-400\">в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВҝв”ҳГ©в”ҳГЁ</div>\r\n            <div className=\"text-lg font-bold text-slate-800 dark:text-white\">\r\n              {formatCurrencyJOD(kpis?.remaining ?? 0, {\r\n                minimumFractionDigits: 0,\r\n                maximumFractionDigits: 0,\r\n              })}\r\n            </div>\r\n          </div>\r\n          <div className=\"rounded-xl border border-gray-100 dark:border-slate-700 p-3\">\r\n            <div className=\"text-xs text-slate-500 dark:text-slate-400\">в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в”ҳГӘв”ҳГ©в•Әв•Ј</div>\r\n            <div className=\"text-lg font-bold text-slate-800 dark:text-white\">\r\n              {formatCurrencyJOD(kpis?.totalExpected ?? 0, {\r\n                minimumFractionDigits: 0,\r\n                maximumFractionDigits: 0,\r\n              })}\r\n            </div>\r\n          </div>\r\n          <div className=\"rounded-xl border border-gray-100 dark:border-slate-700 p-3\">\r\n            <div className=\"text-xs text-slate-500 dark:text-slate-400\">в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ» в•ӘВәв”ҳГӨв”ҳГҘв•Әв”Өв•Әв•–в•ӘвҢҗ</div>\r\n            <div className=\"text-lg font-bold text-slate-800 dark:text-white\">\r\n              {formatNumber(kpis?.activeContracts ?? 0)}\r\n            </div>\r\n          </div>\r\n          <div className=\"rounded-xl border border-gray-100 dark:border-slate-700 p-3\">\r\n            <div className=\"text-xs text-slate-500 dark:text-slate-400\">в•ӘВ¬в•Әв–‘в•ӘВәв”ҳГўв•Әв–’ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в”ҳГјв•ӘВ¬в”ҳГӘв•ӘВЎв•ӘвҢҗ</div>\r\n            <div className=\"text-lg font-bold text-slate-800 dark:text-white\">\r\n              {formatNumber(kpis?.openTickets ?? 0)}\r\n            </div>\r\n          </di