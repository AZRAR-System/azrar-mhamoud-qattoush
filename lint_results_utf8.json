r\nexport const NewListingModal: React.FC<NewListingModalProps> = ({ isOpen, onClose, onSubmit, initialData }) => {\r\n  const [formData, setFormData] = React.useState<Partial<в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў_в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј_tbl>>({\r\n    в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: '',\r\n    в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ: '',\r\n    в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬: '',\r\n    в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎ_в”ҳГӨв”ҳГӨв•ӘГ‘в”ҳГЁв•ӘВјв•ӘВәв•Әв–’_в•ӘГәв”ҳГЁв•Әв•ўв•ӘВә: false\r\n  });\r\n\r\n  React.useEffect(() => {\r\n    if (isOpen) {\r\n      if (initialData) {\r\n        setFormData({\r\n          ...initialData,\r\n          в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ: initialData.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ?.toString() || ''\r\n        });\r\n      } else {\r\n        setFormData({\r\n          в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: '',\r\n          в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ: '',\r\n          в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬: '',\r\n          в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎ_в”ҳГӨв”ҳГӨв•ӘГ‘в”ҳГЁв•ӘВјв•ӘВәв•Әв–’_в•ӘГәв”ҳГЁв•Әв•ўв•ӘВә: false\r\n        });\r\n      }\r\n    }\r\n  }, [isOpen, initialData]);\r\n\r\n  const handleSubmit = (e: React.FormEvent) => {\r\n    e.preventDefault();\r\nonSubmit({\r\n      в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: formData.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’,\r\n      в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ: Number(formData.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ),\r\n      в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬: formData.в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬,\r\n      в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎ_в”ҳГӨв”ҳГӨв•ӘГ‘в”ҳГЁв•ӘВјв•ӘВәв•Әв–’_в•ӘГәв”ҳГЁв•Әв•ўв•ӘВә: formData.в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎ_в”ҳГӨв”ҳГӨв•ӘГ‘в”ҳГЁв•ӘВјв•ӘВәв•Әв–’_в•ӘГәв”ҳГЁв•Әв•ўв•ӘВә\r\n    });\r\n    onClose();\r\n  };\r\n\r\n  return (\r\n    <Modal isOpen={is