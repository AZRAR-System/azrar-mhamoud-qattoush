rd,\r\n} from '@/types';\r\nimport {\r\n  Lock,\r\n  Edit2,\r\n  Trash2,\r\n  Download,\r\n  AlertTriangle,\r\n  UserCheck,\r\n  UserX,\r\n  Settings,\r\n  UserPlus,\r\n  ChevronDown,\r\n  ShieldAlert,\r\n  Ban,\r\n  ScrollText,\r\n  Filter,\r\n  RefreshCw,\r\n  Shield,\r\n  BarChart3,\r\n  Search,\r\n  CheckCircle,\r\n  Activity,\r\n  Users,\r\n} from 'lucide-react';\r\nimport { Button } from '@/components/ui/Button';\r\nimport { Card } from '@/components/ui/Card';\r\nimport { auditLog, type AuditLogRecord } from '@/services/auditLog';\r\nimport { exportToXlsx } from '@/utils/xlsx';\r\nimport { Tooltip as ChartTooltip, ResponsiveContainer, PieChart, Pie, Cell } from 'recharts';\r\nimport { useToast } from '@/context/ToastContext';\r\nimport { useSmartModal } from '@/context/ModalContext';\r\nimport { RBACGuard } from '@/components/shared/RBACGuard';\r\nimport { DS } from '@/constants/designSystem';\r\nimport { useDbSignal } from '@/hooks/useDbSignal';\r\nimport { storage } from '@/services/storage';\r\nimport { domainGetSmart } from '@/services/domainQueries';\r\nimport { runReportSmart } from '@/services/reporting';\r\nimport { safeNumber } from '@/utils/safe';\r\nimport { PersonPicker } from '@/components/shared/PersonPicker';\r\nimport { AppModal } from '@/components/ui/AppModal';\r\nimport { StatusBadge } from '@/components/ui/StatusBadge';\r\nimport { formatCurrencyJOD } from '@/utils/format';\r\nimport type { DashboardStats } from '@/services/dbCache';\r\nimport type { LucideIcon } from 'lucide-react';\r\nimport { useResponsivePageSize } from '@/hooks/useResponsivePageSize';\r\nimport { PaginationControls } from '@/components/shared/PaginationControls';\r\n\r\n// --- SUB-COMPONENTS ---\r\n\r\ntype StatCardProps = {\r\n  title: string;\r\n  value: React.ReactNode;\r\n  sub?: React.ReactNode;\r\n  icon: LucideIcon;\r\n  color: string;\r\n};\r\n\r\nconst StatCard = ({ title, value, sub, icon: Icon, color }: StatCardProps) => (\r\n  <div className=\"app-card p-6 flex items-center gap-4\">\r\n    <div className={`p-4 rounded-xl ${color}`}>\r\n      <Icon size={24} className=\"text-white\" />\r\n    </div>\r\n    <div>\r\n      <p className=\"text-sm text-slate-500 dark:text-slate-400 font-bold mb-1\">{title}</p>\r\n      <h3 className=\"text-2xl font-black text-slate-800 dark:text-white\">{value}</h3>\r\n      {sub && <p className=\"text-xs text-slate-400 mt-1\">{sub}</p>}\r\n    </div>\r\n  </div>\r\n);\r\n\r\n// --- MAIN PAGE ---\r\n\r\nexport const AdminControlPanel: React.FC = () => {\r\n  const [activeTab, setActiveTab] = useState<'analytics' | 'activity' | 'users' | 'blacklist'>(\r\n    'analytics'\r\n  );\r\n  const toast = useToast();\r\n  const { openPanel } = useSmartModal();\r\n\r\n  type NewUserForm = {\r\n    в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ : string;\r\n    в•ӘВәв•Әв”Ӯв”ҳГ _в”ҳГӨв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў: string;\r\n    в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’: string;\r\n    в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’: RoleType;\r\n    linkedPersonId: string;\r\n  };\r\n\r\n  const isDesktopFast =\r\n    typeof window !== 'undefined' && storage.isDesktop() && !!window.desktopDb?.domainGet;\r\n\r\n  const fastPersonByIdRef = useRef<Map<string, в•ӘВәв”ҳГӨв•ӘГәв•Әв”Өв•ӘВ«в•ӘВәв•Әв•Ў_tbl>>(new Map());\r\n  const [fastPersonCacheVersion, setFastPersonCacheVersion] = useState(0);\r\n\r\n  // Data States\r\n  const [analytics, setAnalytics] = useState<DashboardStats | null>(null);\r\n  const [logs, setLogs] = useState<в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬_tbl[]>([]);\r\n  const [users, setUsers] = useState<в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ_tbl[]>([]);\r\n  const [people, setPeople] = useState<в•ӘВәв”ҳГӨв•ӘГәв•Әв”Өв•ӘВ«в•ӘВәв•Әв•Ў_tbl[]>([]); // To link employees\r\n  const [allPermissions, setAllPermissions] = useState<в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ_tbl[]>([]);\r\n  const [blacklist, setBlacklist] = useState<BlacklistRecord[]>([]);\r\n\r\n  // Filter States\r\n  const [logFilter, setLogFilter] = useState({ \r\n    user: '', \r\n    action: '', \r\n    dateFrom: '', \r\n    dateTo: '' \r\n  });\r\n  const [userSearch, setUserSearch] = useState('');\r\n  const [blacklistSearch, setBlacklistSearch] = useState('');\r\n  const [showArchivedBlacklist, setShowArchivedBlacklist] = useState(false);\r\n\r\n  const logsPageSize = useResponsivePageSize({\r\n    base: 8,\r\n    sm: 10,\r\n    md: 12,\r\n    lg: 16,\r\n    xl: 20,\r\n    '2xl': 24,\r\n  });\r\n  const usersPageSize = useResponsivePageSize({ base: 6, sm: 8, md: 9, lg: 12, xl: 15, '2xl': 18 });\r\n\r\n  const [logsPage, setLogsPage] = useState(1);\r\n  const [usersPage, setUsersPage] = useState(1);\r\n\r\n  const filteredLogs = useMemo(() => {\r\n    return logs.filter((log: в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬_tbl) => {\r\n      const r = log;\r\n      if (logFilter.user && r.userName !== logFilter.user) return false;\r\n      if (logFilter.action && r.action !== logFilter.action) return false;\r\n      \r\n      const day = r.timestamp?.slice(0, 10);\r\n      if (logFilter.dateFrom && day < logFilter.dateFrom) return false;\r\n      if (logFilter.dateTo && day > logFilter.dateTo) return false;\r\n      \r\n      return true;\r\n    });\r\n  }, [logs, logFilter]);\r\n\r\n  useEffect(() => {\r\n    setLogsPage(1);\r\n  }, [logFilter.user, logFilter.action, logFilter.dateFrom, logFilter.dateTo, logsPageSize]);\r\n\r\n  const logsPageCount = useMemo(\r\n    () => Math.max(1, Math.ceil((filteredLogs.length || 0) / logsPageSize)),\r\n    [filteredLogs.length, logsPageSize]\r\n  );\r\n\r\n  useEffect(() => {\r\n    setLogsPage((p) => Math.min(Math.max(1, p), logsPageCount));\r\n  }, [logsPageCount]);\r\n\r\n  const visibleLogs = useMemo(() => {\r\n    const start = (logsPage - 1) * logsPageSize;\r\n    return filteredLogs.slice(start, start + logsPageSize);\r\n  }, [filteredLogs, logsPage, logsPageSize]);\r\n\r\n  const filteredUsers = useMemo(() => {\r\n    return users.filter((u) => u.в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ .includes(userSearch));\r\n  }, [users, userSearch]);\r\n\r\n  useEffect(() => {\r\n    setUsersPage(1);\r\n  }, [userSearch, usersPageSize]);\r\n\r\n  const usersPageCount = useMemo(\r\n    () => Math.max(1, Math.ceil((filteredUsers.length || 0) / usersPageSize)),\r\n    [filteredUsers.length, usersPageSize]\r\n  );\r\n\r\n  useEffect(() => {\r\n    setUsersPage((p) => Math.min(Math.max(1, p), usersPageCount));\r\n  }, [usersPageCount]);\r\n\r\n  const visibleUsers = useMemo(() => {\r\n    const start = (usersPage - 1) * usersPageSize;\r\n    return filteredUsers.slice(start, start + usersPageSize);\r\n  }, [filteredUsers, usersPage, usersPageSize]);\r\n\r\n  // User Edit Modal State\r\n  const [editingUser, setEditingUser] = useState<в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ_tbl | null>(null);\r\n  const [tempPermissions, setTempPermissions] = useState<string[]>([]); // Array of codes\r\n\r\n  const [employeeCommissionMonthKey, setEmployeeCommissionMonthKey] = useState<string>(() =>\r\n    new Date().toISOString().slice(0, 7)\r\n  );\r\n  const [employeeCommissionSummary, setEmployeeCommissionSummary] = useState<{\r\n    loading: boolean;\r\n    error?: string;\r\n    monthKey: string;\r\n    countThisMonth: number;\r\n    totalOfficeThisMonth: number;\r\n    totalIntroThisMonth: number;\r\n    totalEmployeeThisMonth: number;\r\n    rentOfficeThisMonth: number;\r\n    rentEmployeeThisMonth: number;\r\n    saleOfficeThisMonth: number;\r\n    saleEmployeeThisMonth: number;\r\n    countAll: number;\r\n    totalOfficeAll: number;\r\n    totalIntroAll: number;\r\n    totalEmployeeAll: number;\r\n    rentOfficeAll: number;\r\n    rentEmployeeAll: number;\r\n    saleOfficeAll: number;\r\n    saleEmployeeAll: number;\r\n  } | null>(null);\r\n\r\n  // Add User Modal State\r\n  const [isAddUserModalOpen, setIsAddUserModalOpen] = useState(false);\r\n  const [newUser, setNewUser] = useState<NewUserForm>({\r\n    в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ : '',\r\n    в•ӘВәв•Әв”Ӯв”ҳГ _в”ҳГӨв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў: '',\r\n    в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’: '',\r\n    в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’: 'Employee',\r\n    linkedPersonId: '',\r\n  });\r\n\r\n  const dbSignal = useDbSignal();\r\n\r\n  const loadData = useCallback(() => {\r\n    if (activeTab === 'analytics') {\r\n      setAnalytics(DbService.getAdminAnalytics());\r\n    } else if (activeTab === 'activity') {\r\n      setLogs(auditLog.getAll() as в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬_tbl[]);\r\n    } else if (activeTab === 'users') {\r\n      setUsers(DbService.getSystemUsers());\r\n      setPeople(isDesktopFast ? [] : DbService.getPeople());\r\n      setAllPermissions(DbService.getPermissionDefinitions());\r\n    } else if (activeTab === 'blacklist') {\r\n      setBlacklist(DbService.getBlacklist());\r\n      setPeople(isDesktopFast ? [] : DbService.getPeople());\r\n    }\r\n  }, [activeTab, isDesktopFast]);\r\n\r\n  useEffect(() => {\r\n    loadData();\r\n  }, [dbSignal, loadData]);\r\n\r\n  useEffect(() => {\r\n    let alive = true;\r\n\r\n    const toRecord = (value: unknown): Record<string, unknown> =>\r\n      typeof value === 'object' && value !== null ? (value as Record<string, unknown>) : {};\r\n    const toNumber = (value: unknown): number => {\r\n      const n = Number(value);\r\n      return Number.isFinite(n) ? n : 0;\r\n    };\r\n\r\n    const currentMonthKey =\r\n      String(employeeCommissionMonthKey || '').trim() || new Date().toISOString().slice(0, 7);\r\n    const username = String(editingUser?.в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  || '').trim();\r\n\r\n    if (!editingUser || !username) {\r\n      setEmployeeCommissionSummary(null);\r\n      return () => {\r\n        alive = false;\r\n      };\r\n    }\r\n\r\n    // When opening a new user, default the picker to current month.\r\n    setEmployeeCommissionMonthKey((prev) => (prev ? prev : new Date().toISOString().slice(0, 7)));\r\n\r\n    setEmployeeCommissionSummary({\r\n      loading: true,\r\n      monthKey: currentMonthKey,\r\n      countThisMonth: 0,\r\n      totalOfficeThisMonth: 0,\r\n      totalIntroThisMonth: 0,\r\n      totalEmployeeThisMonth: 0,\r\n      rentOfficeThisMonth: 0,\r\n      rentEmployeeThisMonth: 0,\r\n      saleOfficeThisMonth: 0,\r\n      saleEmployeeThisMonth: 0,\r\n      countAll: 0,\r\n      totalOfficeAll: 0,\r\n      totalIntroAll: 0,\r\n      totalEmployeeAll: 0,\r\n      rentOfficeAll: 0,\r\n      rentEmployeeAll: 0,\r\n      saleOfficeAll: 0,\r\n      saleEmployeeAll: 0,\r\n    });\r\n\r\n    (async () => {\r\n      try {\r\n        const report = await runReportSmart('employee_commissions');\r\n        const rows = Array.isArray(report?.data) ? report.data : [];\r\n\r\n        const userRows = rows.filter(\r\n          (r) => String(toRecord(r)['employeeUsername'] ?? '').trim() === username\r\n        );\r\n        const monthRows = userRows.filter(\r\n          (r) => String(toRecord(r)['date'] ?? '').slice(0, 7) === currentMonthKey\r\n        );\r\n\r\n        const byType = (arr: unknown[], type: string) =>\r\n          arr.filter((r) => String(toRecord(r)['type'] ?? '').trim() === type);\r\n\r\n        const sumOffice = (arr: unknown[]): number =>\r\n          arr.map((r) => toNumber(toRecord(r)['officeCommission'])).reduce((s, n) => s + n, 0);\r\n        const sumEmployee = (arr: unknown[]): number =>\r\n          arr.map((r) => toNumber(toRecord(r)['employeeTotal'])).reduce((s, n) => s + n, 0);\r\n        const sumIntro = (arr: unknown[]): number =>\r\n          arr.map((r) => toNumber(toRecord(r)['intro'])).reduce((s, n) => s + n, 0);\r\n\r\n        const monthRent = byType(monthRows, 'в•ӘГ‘в”ҳГЁв•ӘВјв•ӘВәв•Әв–’');\r\n        const monthSale = byType(monthRows, 'в•ӘВҝв”ҳГЁв•Әв•Ј');\r\n        const allRent = byType(userRows, 'в•ӘГ‘в”ҳГЁв•ӘВјв•ӘВәв•Әв–’');\r\n        const allSale = byType(userRows, 'в•ӘВҝв”ҳГЁв•Әв•Ј');\r\n\r\n        const next = {\r\n          loading: false,\r\n          monthKey: currentMonthKey,\r\n          countThisMonth: monthRows.length,\r\n          totalOfficeThisMonth: sumOffice(monthRows),\r\n          totalIntroThisMonth: sumIntro(monthRows),\r\n          totalEmployeeThisMonth: sumEmployee(monthRows),\r\n          rentOfficeThisMonth: sumOffice(monthRent),\r\n          rentEmployeeThisMonth: sumEmployee(monthRent),\r\n          saleOfficeThisMonth: sumOffice(monthSale),\r\n          saleEmployeeThisMonth: sumEmployee(monthSale),\r\n          countAll: userRows.length,\r\n          totalOfficeAll: sumOffice(userRows),\r\n          totalIntroAll: sumIntro(userRows),\r\n          totalEmployeeAll: sumEmployee(userRows),\r\n          rentOfficeAll: sumOffice(allRent),\r\n          rentEmployeeAll: sumEmployee(allRent),\r\n          saleOfficeAll: sumOffice(allSale),\r\n          saleEmployeeAll: sumEmployee(allSale),\r\n        };\r\n\r\n        if (!alive) return;\r\n        setEmployeeCommissionSummary(next);\r\n      } catch (_e) {\r\n        if (!alive) return;\r\n        setEmployeeCommissionSummary({\r\n          loading: false,\r\n          error: (_e as Error)?.message || 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в”ҳГ в”ҳГӨв•ӘВ«в•Әв•Ў в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘВәв•ӘВ¬',\r\n          monthKey: currentMonthKey,\r\n          countThisMonth: 0,\r\n          totalOfficeThisMonth: 0,\r\n          totalIntroThisMonth: 0,\r\n          totalEmployeeThisMonth: 0,\r\n          rentOfficeThisMonth: 0,\r\n          rentEmployeeThisMonth: 0,\r\n          saleOfficeThisMonth: 0,\r\n          saleEmployeeThisMonth: 0,\r\n          countAll: 0,\r\n          totalOfficeAll: 0,\r\n          totalIntroAll: 0,\r\n          totalEmployeeAll: 0,\r\n          rentOfficeAll: 0,\r\n          rentEmployeeAll: 0,\r\n          saleOfficeAll: 0,\r\n          saleEmployeeAll: 0,\r\n        });\r\n      }\r\n    })();\r\n\r\n    return () => {\r\n      alive = false;\r\n    };\r\n  }, [editingUser, employeeCommissionMonthKey]);\r\n\r\n  // Desktop-fast: resolve linked/blacklist people names lazily via SQL\r\n  useEffect(() => {\r\n    if (!isDesktopFast) return;\r\n    if (activeTab !== 'users' && activeTab !== 'blacklist') return;\r\n    let alive = true;\r\n\r\n    const run = async () => {\r\n      const ids = new Set<string>();\r\n      if (activeTab === 'users') {\r\n        for (const u of users) {\r\n          const pid = String(u.linkedPersonId || '').trim();\r\n          if (pid) ids.add(pid);\r\n        }\r\n      }\r\n      if (activeTab === 'blacklist') {\r\n        for (const rec of blacklist) {\r\n          const pid = String(rec.personId || '').trim();\r\n          if (pid) ids.add(pid);\r\n        }\r\n      }\r\n\r\n      const limited = Array.from(ids).slice(0, 300);\r\n      let changed = false;\r\n\r\n      for (const pid of limited) {\r\n        if (!alive) return;\r\n        if (fastPersonByIdRef.current.has(pid)) continue;\r\n        try {\r\n          const person = await domainGetSmart('people', pid);\r\n          if (person) {\r\n            fastPersonByIdRef.current.set(pid, person);\r\n            changed = true;\r\n          }\r\n        } catch {\r\n          // ignore\r\n        }\r\n      }\r\n\r\n      if (alive && changed) setFastPersonCacheVersion((v) => v + 1);\r\n    };\r\n\r\n    void run();\r\n    return () => {\r\n      alive = false;\r\n    };\r\n  }, [isDesktopFast, activeTab, users, blacklist]);\r\n\r\n  const handleExportLogs = useCallback(() => {\r\n    const data = filteredLogs.map((r) => ({\r\n      id: r.id,\r\n      userName: r.userName,\r\n      action: r.action,\r\n      entity: r.entity,\r\n      entityId: r.entityId ?? '',\r\n      details: r.details ?? '',\r\n      timestamp: r.timestamp,\r\n      ip: r.ip ?? '',\r\n    }));\r\n\r\n    void exportToXlsx(\r\n      'в•Әв”Ӯв•ӘВјв”ҳГӨ_в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©',\r\n      [\r\n        { key: 'timestamp', header: 'в•ӘВәв”ҳГӨв”ҳГӘв”ҳГ©в•ӘВ¬' },\r\n        { key: 'userName', header: 'в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ ' },\r\n        { key: 'action', header: 'в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯ' },\r\n        { key: 'entity', header: 'в•ӘВәв”ҳГӨв”ҳГўв”ҳГЁв•ӘВәв”ҳГҘ' },\r\n        { key: 'entityId', header: 'в”ҳГ в•Әв•Јв•Әв–’в”ҳГј в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘВјв”ҳГӨ' },\r\n        { key: 'details', header: 'в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГјв•ӘВәв•Әв•Ўв”ҳГЁв”ҳГӨ' },\r\n        { key: 'ip', header: 'IP' },\r\n      ],\r\n      data as Record<string, unknown>[],\r\n      `audit-log-${new Date().toISOString().slice(0, 10)}.xlsx`\r\n    );\r\n  }, [filteredLogs]);\r\n\r\n  // --- ACTIONS ---\r\n\r\n  const handleToggleUserStatus = async (id: string, currentStatus: boolean) => {\r\n    const ok = await toast.confirm({\r\n      title: 'в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ»',\r\n      message: currentStatus ? 'в”ҳГ§в”ҳГӨ в•ӘВ¬в•Әв–’в”ҳГЁв•ӘВ» в•ӘГ‘в”ҳГЁв”ҳГ©в•ӘВәв”ҳГј в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝв•ӘЖ’' : 'в”ҳГ§в”ҳГӨ в•ӘВ¬в•Әв–’в”ҳГЁв•ӘВ» в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝв•ӘЖ’',\r\n      confirmText: 'в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ»',\r\n      cancelText: 'в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ',\r\n      isDangerous: currentStatus,\r\n    });\r\n    if (!ok) return;\r\n    DbService.updateUserStatus(id, !currentStatus);\r\n    loadData();\r\n    toast.success(currentStatus ? 'в•ӘВ¬в”ҳГ  в•ӘГ‘в”ҳГЁв”ҳГ©в•ӘВәв”ҳГј в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ' : 'в•ӘВ¬в”ҳГ  в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ');\r\n  };\r\n\r\n  const handleDeleteUser = async (id: string) => {\r\n    const ok = await toast.confirm({\r\n      title: 'в•ӘВЎв•Әв–‘в”ҳГј в”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ ',\r\n      message: 'в”ҳГ§в”ҳГӨ в•ӘГәв”ҳГҘв•ӘВ¬ в”ҳГ в•ӘВ¬в•ӘГәв”ҳГўв•ӘВ» в”ҳГ в”ҳГҘ в•ӘВЎв•Әв–‘в”ҳГј в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв”ҳГҜв•ӘЖ’ в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯ в”ҳГӨв•ӘВә в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВәв•ӘВјв•Әв•Ј в•Әв•Јв”ҳГҘв”ҳГ§.',\r\n      confirmText: 'в•ӘВЎв•Әв–‘в”ҳГј',\r\n      cancelText: 'в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ',\r\n      isDangerous: true,\r\n    });\r\n    if (!ok) return;\r\n    DbService.deleteSystemUser(id);\r\n    loadData();\r\n    toast.success('в•ӘВ¬в”ҳГ  в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ');\r\n  };\r\n\r\n  const handleOpenEditUser = (user: в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ_tbl) => {\r\n    setEditingUser(user);\r\n    // Load existing permissions for this user from DB (not legacy array)\r\n    const perms = DbService.getUserPermissions(user.id);\r\n    setTempPermissions(perms);\r\n  };\r\n\r\n  const handleSaveUser = () => {\r\n    if (!editingUser) return;\r\n\r\n    // Save Role\r\n    DbService.updateUserRole(editingUser.id, editingUser.в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’);\r\n\r\n    // Save Permissions (New Relation Table)\r\n    DbService.updateUserPermissions(editingUser.id, tempPermissions);\r\n\r\n    toast.success('в•ӘВ¬в”ҳГ  в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в”ҳГӘв•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬в”ҳГ§');\r\n    setEditingUser(null);\r\n    loadData();\r\n  };\r\n\r\n  const togglePermission = (code: string) => {\r\n    setTempPermissions((prev) =>\r\n      prev.includes(code) ? prev.filter((p) => p !== code) : [...prev, code]\r\n    );\r\n  };\r\n\r\n  // Add User Actions\r\n  const handleAddUser = (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    try {\r\n      DbService.addSystemUser(newUser);\r\n      loadData();\r\n      setIsAddUserModalOpen(false);\r\n      setNewUser({\r\n        в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ : '',\r\n        в•ӘВәв•Әв”Ӯв”ҳГ _в”ҳГӨв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў: '',\r\n        в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’: '',\r\n        в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’: 'Employee',\r\n        linkedPersonId: '',\r\n      });\r\n      toast.success('в•ӘВ¬в”ҳГ  в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ');\r\n    } catch (err: unknown) {\r\n      const msg = err instanceof Error ? err.message : 'в•ӘВЎв•ӘВ»в•ӘВҪ в•ӘВ«в•Әв•–в•ӘГә в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВ¬в”ҳГӘв”ҳГ©в•Әв•Ј';\r\n      toast.error(msg);\r\n    }\r\n  };\r\n\r\n  const getLinkedPersonName = (id?: string) => {\r\n    if (!id) return null;\r\n    if (isDesktopFast) {\r\n      void fastPersonCacheVersion;\r\n      const p = fastPersonByIdRef.current.get(String(id));\r\n      return p ? p.в•ӘВәв”ҳГӨв•ӘВәв•Әв”Ӯв”ҳГ  : null;\r\n    }\r\n    const p = people.find((p) => p.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв”Өв•ӘВ«в•Әв•Ў === id);\r\n    return p ? p.в•ӘВәв”ҳГӨв•ӘВәв•Әв”Ӯв”ҳГ  : null;\r\n  };\r\n\r\n  const getPersonById = (id?: string) => {\r\n    if (!id) return null;\r\n    if (isDesktopFast) {\r\n      void fastPersonCacheVersion;\r\n      return fastPersonByIdRef.current.get(String(id)) || null;\r\n    }\r\n    return people.find((p) => String(p.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв”Өв•ӘВ«в•Әв•Ў) === String(id)) || null;\r\n  };\r\n\r\n  // Blacklist Actions\r\n  const handleLiftBan = async (id: string) => {\r\n    const ok = await toast.confirm({\r\n      title: 'в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ»',\r\n      message: 'в”ҳГ§в”ҳГӨ в•ӘВ¬в•Әв–’в”ҳГЁв•ӘВ» в•Әв–’в”ҳГјв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВЎв•Әв••в•Әв–’ в•Әв•Јв”ҳГҘ в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•Әв”Өв•ӘВ«в•Әв•Ўв•ӘЖ’',\r\n      confirmText: 'в”ҳГҘв•Әв•Јв”ҳГ ',\r\n      cancelText: 'в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ',\r\n    });\r\n    if (!ok) return;\r\n    DbService.removeFromBlacklist(id);\r\n    toast.success('в•ӘВ¬в”ҳГ  в•Әв–’в”ҳГјв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВЎв•Әв••в•Әв–’');\r\n    loadData();\r\n  };\r\n\r\n  const handleEditBan = (recordId: string) => {\r\n    openPanel('BLACKLIST_FORM', recordId, {\r\n      mode: 'edit',\r\n      onSuccess: () => loadData(),\r\n    });\r\n  };\r\n\r\n  // --- RENDERERS ---\r\n\r\n  const renderAnalytics = () => {\r\n    if (!analytics) return <div>в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ...</div>;\r\n\r\n    const pieData = [\r\n      { name: 'в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ в”ҳГ в•ӘГұв•ӘВјв•Әв–’в•ӘвҢҗ', value: analytics.occupiedProps, color: '#10b981' }, // green\r\n      { name: 'в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ в•Әв”Өв•ӘВәв•Әв•‘в•Әв–’в•ӘвҢҗ', value: analytics.vacantProps, color: '#3b82f6' }, // blue\r\n    ];\r\n\r\n    return (\r\n      <div className=\"space-y-6 animate-fade-in\">\r\n        {/* Top Cards */}\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\r\n          <StatCard\r\n            title=\"в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в”ҳГӘв•ӘВ» в•ӘВәв”ҳГӨв”ҳГҘв•Әв”Өв•Әв•–в•ӘвҢҗ\"\r\n            value={safeNumber(analytics.activeContracts)}\r\n            sub={`${safeNumber(analytics.expiredContracts)} в”ҳГ в”ҳГҘв•ӘВ¬в”ҳГ§в”ҳГЁ`}\r\n            icon={Shield}\r\n            color=\"bg-indigo-500\"\r\n          />\r\n          <StatCard\r\n            title=\"в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв•Әв•Ўв”ҳГЁв”ҳГӨ\"\r\n            value={`${safeNumber(analytics.totalCollected).toLocaleString()} в•ӘВ».в•ӘГә`}\r\n            sub={`${safeNumber(analytics.totalDue).toLocaleString()} в•ӘВ».в•ӘГә в”ҳГ в•ӘВ¬в•ӘГәв•ӘВ«в•Әв–’в•ӘВәв•ӘВ¬`}\r\n            icon={BarChart3}\r\n            color=\"bg-emerald-500\"\r\n          />\r\n          <StatCard\r\n            title=\"в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГјв”ҳГ©в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’в”ҳГЁв•ӘвҢҗ\"\r\n            value={safeNumber(analytics.monthlyAttachments)}\r\n            sub=\"в”ҳГ в”ҳГӨв”ҳГјв•ӘВәв•ӘВ¬ в•ӘВ¬в”ҳГ  в•Әв–’в”ҳГјв•Әв•Јв”ҳГ§в•ӘВә в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’\"\r\n            icon={Download}\r\n            color=\"bg-indigo-500\"\r\n          />\r\n          <StatCard\r\n            title=\"в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГҘв•ӘВҝв”ҳГЁв”ҳГ§в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в”ҳГјв•ӘВ¬в”ҳГӘв•ӘВЎв•ӘвҢҗ\"\r\n            value={safeNumber(analytics.openAlerts)}\r\n            sub=\"в•ӘВ¬в•ӘВ¬в•Әв•–в”ҳГӨв•ӘВҝ в•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯ\"\r\n            icon={AlertTriangle}\r\n            color=\"bg-amber-500\"\r\n          />\r\n        </div>\r\n\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n          {/* Occupancy Chart */}\r\n          <div className=\"app-card p-6\">\r\n            <h3 className=\"font-bold text-slate-700 dark:text-white mb-4\">в•ӘВ¬в”ҳГӘв•Әв–“в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’в•ӘВәв•ӘВ¬</h3>\r\n            <div className=\"h-64 flex items-center justify-center\">\r\n              <ResponsiveContainer width=\"100%\" height=\"100%\">\r\n                <PieChart>\r\n                  <Pie\r\n                    data={pieData}\r\n                    innerRadius={60}\r\n                    outerRadius={80}\r\n                    paddingAngle={5}\r\n                    dataKey=\"value\"\r\n                  >\r\n                    {pieData.map((entry, index) => (\r\n                      <Cell key={index} fill={entry.color} />\r\n                    ))}\r\n                  </Pie>\r\n                  <ChartTooltip />\r\n                </PieChart>\r\n              </ResponsiveContainer>\r\n            </div>\r\n            <div className=\"flex justify-center gap-6 text-sm\">\r\n              <div className=\"flex items-center gap-2\">\r\n                <div className=\"w-3 h-3 bg-emerald-500 rounded-full\"></div> в”ҳГ в•ӘГұв•ӘВјв•Әв–’ (\r\n                {analytics.occupiedProps})\r\n              </div>\r\n              <div className=\"flex items-center gap-2\">\r\n                <div className=\"w-3 h-3 bg-indigo-500 rounded-full\"></div> в•Әв”Өв•ӘВәв•Әв•‘в•Әв–’ (\r\n                {analytics.vacantProps})\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Top Debtors List */}\r\n          <div className=\"app-card p-6\">\r\n            <h3 className=\"font-bold text-slate-700 dark:text-white mb-4\">\r\n              в•ӘГәв•Әв•Јв”ҳГӨв”ҳГ« 10 в”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘГәв•ӘВјв•Әв–’в”ҳГЁв”ҳГҘ в•ӘВ¬в•ӘГәв•ӘВ«в”ҳГЁв•Әв–’в•ӘВәв”ҳГҜ\r\n            </h3>\r\n            <div className=\"overflow-y-auto max-h-64 space-y-3 custom-scrollbar\">\r\n              {analytics.topDebtors &&\r\n                analytics.topDebtors.map((d, i: number) => (\r\n                  <div\r\n                    key={i}\r\n                    className=\"flex justify-between items-center p-3 bg-red-50 dark:bg-red-900/10 rounded-lg border border-red-100 dark:border-red-900/30\"\r\n                  >\r\n                    <div className=\"flex items-center gap-3\">\r\n                      <span className=\"font-bold text-red-600 w-6\">{i + 1}.</span>\r\n                      <span className=\"text-slate-700 dark:text-slate-300 font-medium\">\r\n                        {d.name}\r\n                      </span>\r\n                    </div>\r\n                    <span className=\"font-bold text-red-600\">\r\n                      {safeNumber(d.amount).toLocaleString()} в•ӘВ».в•ӘГә\r\n                    </span>\r\n                  </div>\r\n                ))}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    );\r\n  };\r\n\r\n  const renderActivity = () => {\r\n    return (\r\n      <div className=\"space-y-6 animate-fade-in\">\r\n        {/* Header Actions */}\r\n        <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\r\n          <div className=\"flex items-center gap-3\">\r\n            <div className=\"p-3 bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-200 rounded-2xl shadow-sm\">\r\n              <ScrollText size={24} />\r\n            </div>\r\n            <div>\r\n              <h3 className=\"text-xl font-bold text-slate-800 dark:text-white\">в•Әв”Ӯв•ӘВјв”ҳГӨ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬ в”ҳГӘв•ӘВәв”ҳГӨв•ӘВ¬в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©</h3>\r\n              <p className=\"text-sm text-slate-500 mt-1\">в”ҳГ в•Әв–’в•ӘВәв”ҳГ©в•ӘВҝв•ӘвҢҗ в”ҳГўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВ¬в•ӘВЎв•Әв–’в”ҳГўв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ в”ҳГӘв•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•Әв”Ӯв•ӘвҢҗ в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ .</p>\r\n            </div>\r\n          </div>\r\n          <div className=\"flex flex-wrap gap-2\">\r\n            <Button variant=\"secondary\" onClick={() => loadData()} className=\"gap-2\">\r\n              <RefreshCw size={16} /> в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ\r\n            </Button>\r\n            <Button onClick={() => void handleExportLogs()} className=\"gap-2 bg-emerald-600 hover:bg-emerald-700 text-white shadow-lg shadow-emerald-600/20\">\r\n              <Download size={16} /> в•ӘВ¬в•Әв•Ўв•ӘВ»в”ҳГЁв•Әв–’ Excel\r\n            </Button>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Filters */}\r\n        <Card className=\"p-6\">\r\n          <div className=\"flex items-center gap-2 text-sm font-bold text-slate-700 dark:text-slate-200 mb-4\">\r\n            <Filter size={16} /> в•ӘВ¬в•Әв•Ўв”ҳГјв”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘВјв”ҳГӨв•ӘВәв•ӘВ¬\r\n          </div>\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\r\n            <div className=\"space-y-1\">\r\n              <label className=\"text-[10px] font-black text-slate-400 uppercase px-1\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј</label>\r\n              <input\r\n                placeholder=\"в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ ...\"\r\n                className=\"w-full border p-2.5 rounded-xl text-sm bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-800 outline-none focus:ring-2 focus:ring-indigo-500/20\"\r\n                value={logFilter.user}\r\n                onChange={(e) => setLogFilter({ ...logFilter, user: e.target.value })}\r\n              />\r\n            </div>\r\n            <div className=\"space-y-1\">\r\n              <label className=\"text-[10px] font-black text-slate-400 uppercase px-1\">в”ҳГҘв”ҳГӘв•Әв•Ј в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯ</label>\r\n              <input\r\n                placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ: в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨв•ӘГ® в•ӘВЎв•Әв–‘в”ҳГј...\"\r\n                className=\"w-full border p-2.5 rounded-xl text-sm bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-800 outline-none focus:ring-2 focus:ring-indigo-500/20\"\r\n                value={logFilter.action}\r\n                onChange={(e) => setLogFilter({ ...logFilter, action: e.target.value })}\r\n              />\r\n            </div>\r\n            <div className=\"space-y-1\">\r\n              <label className=\"text-[10px] font-black text-slate-400 uppercase px-1\">в”ҳГ в”ҳГҘ в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«</label>\r\n              <input\r\n                type=\"date\"\r\n                className=\"w-full border p-2.5 rounded-xl text-sm bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-800 outline-none\"\r\n                value={logFilter.dateFrom}\r\n                onChange={(e) => setLogFilter({ ...logFilter, dateFrom: e.target.value })}\r\n              />\r\n            </div>\r\n            <div className=\"space-y-1\">\r\n              <label className=\"text-[10px] font-black text-slate-400 uppercase px-1\">в•ӘГ‘в”ҳГӨв”ҳГ« в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«</label>\r\n              <input\r\n                type=\"date\"\r\n                className=\"w-full border p-2.5 rounded-xl text-sm bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-800 outline-none\"\r\n                value={logFilter.dateTo}\r\n                onChange={(e) => setLogFilter({ ...logFilter, dateTo: e.target.value })}\r\n              />\r\n            </div>\r\n          </div>\r\n        </Card>\r\n\r\n        {/* Table List */}\r\n        <div className=\"app-table-wrapper rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm\">\r\n          <div className=\"p-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between gap-2 bg-white dark:bg-slate-900 shadow-sm z-10\">\r\n            <div className=\"text-[10px] font-black text-slate-500 uppercase tracking-widest px-3 border-r border-slate-200 dark:border-slate-800 ml-4 pl-4 shrink-0\">\r\n              {filteredLogs.length.toLocaleString()} в•Әв”Ӯв•ӘВјв”ҳГӨ\r\n            </div>\r\n            <PaginationControls\r\n              page={logsPage}\r\n              pageCount={logsPageCount}\r\n              onPageChange={setLogsPage}\r\n            />\r\n          </div>\r\n          <div className=\"max-h-[700px] overflow-auto no-scrollbar bg-white dark:bg-slate-900/40\">\r\n            <table className=\"app-table\">\r\n              <thead className=\"app-table-thead !bg-slate-50/50 dark:!bg-slate-900/80 sticky top-0 backdrop-blur-md\">\r\n                <tr>\r\n                  <th className=\"app-table-th\">в•ӘВәв”ҳГӨв”ҳГӘв”ҳГ©в•ӘВ¬</th>\r\n                  <th className=\"app-table-th\">в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ </th>\r\n                  <th className=\"app-table-th\">в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯ</th>\r\n                  <th className=\"app-table-th\">в•ӘВәв”ҳГӨв”ҳГўв”ҳГЁв•ӘВәв”ҳГҘ</th>\r\n                  <th className=\"app-table-th\">IP</th>\r\n                  <th className=\"app-table-th\">в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГјв•ӘВәв•Әв•Ўв”ҳГЁв”ҳГӨ</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody className=\"divide-y divide-slate-100/50 dark:divide-slate-800/50\">\r\n                {visibleLogs.length === 0 ? (\r\n                  <tr>\r\n                    <td colSpan={6} className=\"app-table-empty !py-20 text-slate-400\">\r\n                      <ScrollText size={48} className=\"mx-auto mb-4 opacity-10\" />\r\n                      в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в•Әв”Ӯв•ӘВјв”ҳГӨв•ӘВәв•ӘВ¬ в”ҳГ в•Әв•–в•ӘВәв•ӘВҝв”ҳГ©в•ӘвҢҗ в”ҳГӨв”ҳГ в•Әв•Јв•ӘВәв”ҳГЁв”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв•ӘВҝв•ӘВЎв•ӘВҪ\r\n                    </td>\r\n                  </tr>\r\n                ) : (\r\n                  visibleLogs.map((log) => (\r\n                    <tr key={log.id} className=\"app-table-row group hover:bg-slate-50/50 dark:hover:bg-slate-800/40 transition-colors\">\r\n                      <td className=\"app-table-td font-mono text-[10px] text-slate-500 font-bold whitespace-nowrap\" dir=\"ltr\">\r\n                        {log.timestamp ? new Date(log.timestamp).toLocaleString('ar-JO') : 'О“ГҮГ¶'}\r\n                      </td>\r\n                      <td className=\"app-table-td\">\r\n                        <div className=\"flex items-center gap-3\">\r\n                          <div className=\"w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-xs font-black text-slate-500 shadow-sm group-hover:bg-indigo-600 group-hover:text-white transition-all\">\r\n                            {log.userName?.charAt(0).toUpperCase()}\r\n                          </div>\r\n                          <span className=\"text-sm font-bold text-slate-700 dark:text-slate-200\">\r\n                            {log.userName}\r\n                          </span>\r\n                        </div>\r\n                      </td>\r\n                      <td className=\"app-table-td\">\r\n                        <span className=\"px-2.5 py-1 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-lg text-[10px] font-black border border-indigo-100/50 dark:border-indigo-800/50\">\r\n                          {log.action}\r\n                        </span>\r\n                      </td>\r\n                      <td className=\"app-table-td\">\r\n                        <span className=\"text-xs font-bold text-slate-600 dark:text-slate-400\">\r\n                          {log.entity}\r\n                          {log.entityId && <span className=\"text-slate-400 font-normal mr-1\">#{log.entityId.slice(0, 8)}</span>}\r\n                        </span>\r\n                      </td>\r\n                      <td className=\"app-table-td font-mono text-[10px] text-slate-400\">\r\n                        {log.ip || 'О“ГҮГ¶'}\r\n                      </td>\r\n                      <td className=\"app-table-td max-w-xs xl:max-w-md\">\r\n                        <div className=\"text-[11px] text-slate-500 dark:text-slate-400 truncate hover:whitespace-normal transition-all\" title={log.details}>\r\n                          {log.details || 'О“ГҮГ¶'}\r\n                        </div>\r\n                      </td>\r\n                    </tr>\r\n                  ))\r\n                )}\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    );\r\n  };\r\n\r\n  const renderUsers = () => {\r\n    return (\r\n      <div className=\"animate-fade-in space-y-6\">\r\n        <div className=\"flex justify-between items-center\">\r\n          <input\r\n            placeholder=\"в•ӘВҝв•ӘВЎв•ӘВҪ в•Әв•Јв”ҳГҘ в”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ ...\"\r\n            className=\"border p-2 rounded-xl text-sm w-64 bg-white dark:bg-slate-800 dark:border-slate-600 outline-none\"\r\n            aria-label=\"в•ӘВҝв•ӘВЎв•ӘВҪ в•Әв•Јв”ҳГҘ в”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ \"\r\n            title=\"в•ӘВҝв•ӘВЎв•ӘВҪ в•Әв•Јв”ҳГҘ в”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ \"\r\n            value={userSearch}\r\n            onChange={(e) => setUserSearch(e.target.value)}\r\n          />\r\n          <PaginationControls\r\n            page={usersPage}\r\n            pageCount={usersPageCount}\r\n            onPageChange={setUsersPage}\r\n          />\r\n          <button\r\n            onClick={() => setIsAddUserModalOpen(true)}\r\n            className=\"bg-indigo-600 text-white px-5 py-2.5 rounded-xl hover:bg-indigo-700 flex items-center gap-2 transition shadow-lg shadow-indigo-600/20 font-bold text-sm\"\r\n          >\r\n            <UserPlus size={18} /> в”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»\r\n          </button>\r\n        </div>\r\n\r\n        <div className=\"text-xs text-slate-600 dark:text-slate-400\">\r\n          в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ: {filteredUsers.length.toLocaleString()} в”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ \r\n        </div>\r\n\r\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\r\n          {visibleUsers.map((user) => {\r\n            const linkedName = getLinkedPersonName(user.linkedPersonId);\r\n            return (\r\n              <div\r\n                key={user.id}\r\n                className={`app-card p-6 flex flex-col gap-4 relative overflow-hidden transition hover:shadow-lg\r\n                            ${user.isActive ? 'border-transparent shadow-sm' : 'border-red-100 dark:border-red-900/30 opacity-75'}\r\n                        `}\r\n              >\r\n                {/* Status Badge */}\r\n                <div className=\"absolute top-4 left-4\">\r\n                  <StatusBadge\r\n                    status={user.isActive ? 'в”ҳГҘв•Әв”Өв•Әв•–' : 'в”ҳГ в•Әв•Јв•Әв•–в”ҳГӨ'}\r\n                    className=\"!text-[10px] !px-2 !py-0.5 !border-0\"\r\n                  />\r\n                </div>\r\n\r\n                <div className=\"flex items-center gap-4\">\r\n                  <div\r\n                    className={`w-14 h-14 rounded-full flex items-center justify-center text-xl font-bold text-white shadow-lg\r\n                                    ${user.в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’ === 'SuperAdmin' ? 'bg-purple-600' : user.в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’ === 'Admin' ? 'bg-indigo-600' : 'bg-slate-500'}\r\n                                `}\r\n                  >\r\n                    {user.в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ .charAt(0).toUpperCase()}\r\n                  </div>\r\n                  <div>\r\n                    <h3 className=\"text-lg font-bold text-slate-800 dark:text-white\">\r\n                      {user.в•ӘВәв•Әв”Ӯв”ҳГ _в”ҳГӨв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў || user.в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ }\r\n                    </h3>\r\n                    {user.в•ӘВәв•Әв”Ӯв”ҳГ _в”ҳГӨв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў && (\r\n                      <p\r\n                        className=\"text-[11px] text-slate-500 dark:text-slate-400 font-bold\"\r\n                        dir=\"ltr\"\r\n                      >\r\n                        @{user.в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ }\r\n                      </p>\r\n                    )}\r\n                    <p className=\"text-xs text-slate-500\">{user.в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’}</p>\r\n                    {linkedName && (\r\n                      <p className=\"text-xs text-indigo-500 mt-1 flex items-center gap-1\">\r\n            <span style={{ fontSize: 10 }}>вүЎЖ’Г¶Г№</span> {linkedName}\r\n                      </p>\r\n                    )}\r\n                  </div>\r\n                </div>\r\n\r\n                <div className=\"border-t border-gray-100 dark:border-slate-700 pt-4 flex gap-2\">\r\n                  <button\r\n                    onClick={() => handleOpenEditUser(user)}\r\n                    className=\"flex-1 py-2 bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 rounded-lg text-sm font-bold hover:bg-indigo-100 dark:hover:bg-indigo-900/40 flex items-center justify-center gap-2\"\r\n                  >\r\n                    <Edit2 size={16} /> в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬\r\n                  </button>\r\n                  <button\r\n                    onClick={() => handleToggleUserStatus(user.id, user.isActive)}\r\n                    className={`p-2 rounded-lg transition text-white ${user.isActive ? 'bg-orange-500 hover:bg-orange-600' : 'bg-green-500 hover:bg-green-600'}`}\r\n                    aria-label={user.isActive ? 'в•ӘГ‘в”ҳГЁв”ҳГ©в•ӘВәв”ҳГј в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ' : 'в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ'}\r\n                    title={user.isActive ? 'в•ӘГ‘в”ҳГЁв”ҳГ©в•ӘВәв”ҳГј в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ' : 'в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ'}\r\n                  >\r\n                    {user.isActive ? <UserX size={18} /> : <UserCheck size={18} />}\r\n                  </button>\r\n                  <button\r\n                    onClick={() => handleDeleteUser(user.id)}\r\n                    className=\"p-2 rounded-lg transition text-white bg-red-500 hover:bg-red-600\"\r\n                    aria-label=\"в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ\"\r\n                    title=\"в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ\"\r\n                  >\r\n                    <Trash2 size={18} />\r\n                  </button>\r\n                </div>\r\n              </div>\r\n            );\r\n          })}\r\n        </div>\r\n\r\n        {/* ADD USER MODAL */}\r\n        <AppModal\r\n          open={isAddUserModalOpen}\r\n          title=\"в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»\"\r\n          onClose={() => setIsAddUserModalOpen(false)}\r\n          size=\"md\"\r\n          footer={\r\n            <div className=\"flex justify-end gap-3\">\r\n              <button\r\n                type=\"button\"\r\n                onClick={() => setIsAddUserModalOpen(false)}\r\n                className=\"px-4 py-2 text-slate-700 dark:text-slate-200 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg\"\r\n              >\r\n                в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ\r\n              </button>\r\n              <button\r\n                type=\"submit\"\r\n                form=\"add-user-form\"\r\n                className=\"px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-bold\"\r\n              >\r\n                в•ӘВЎв”ҳГјв•Әв••\r\n              </button>\r\n            </div>\r\n          }\r\n        >\r\n          <form id=\"add-user-form\" onSubmit={handleAddUser} className=\"space-y-4\">\r\n            <div>\r\n              <label\r\n                className=\"block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1\"\r\n                htmlFor=\"admin-add-user-username\"\r\n              >\r\n                в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ \r\n              </label>\r\n              <input\r\n                id=\"admin-add-user-username\"\r\n                required\r\n                className=\"w-full border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-slate-800 dark:text-white rounded-lg p-2.5 focus:ring-2 focus:ring-indigo-500 outline-none\"\r\n                value={newUser.в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ }\r\n                onChange={(e) => setNewUser({ ...newUser, в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ : e.target.value })}\r\n              />\r\n            </div>\r\n            <div>\r\n              <label\r\n                className=\"block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1\"\r\n                htmlFor=\"admin-add-user-display-name\"\r\n              >\r\n                в•ӘВәв”ҳГӨв•ӘВәв•Әв”Ӯв”ҳГ  в”ҳГӨв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў (в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’в”ҳГЁ)\r\n              </label>\r\n              <input\r\n                id=\"admin-add-user-display-name\"\r\n                className=\"w-full border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-slate-800 dark:text-white rounded-lg p-2.5 focus:ring-2 focus:ring-indigo-500 outline-none\"\r\n                value={newUser.в•ӘВәв•Әв”Ӯв”ҳГ _в”ҳГӨв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў || ''}\r\n                onChange={(e) => setNewUser({ ...newUser, в•ӘВәв•Әв”Ӯв”ҳГ _в”ҳГӨв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў: e.target.value })}\r\n                placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•ӘГәв•ӘВЎв”ҳГ в•ӘВ» в”ҳГ в•ӘВЎв”ҳГ в•ӘВ»\"\r\n              />\r\n              <p className=\"text-[10px] text-slate-500 dark:text-slate-400 mt-1\">\r\n                в•Әв”Ӯв”ҳГЁв•Әв••в”ҳГ§в•Әв–’ в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГӘв•ӘВәв•ӘВјв”ҳГ§в•ӘвҢҗ в•ӘВҝв•ӘВ»в”ҳГӨв•ӘВәв”ҳГҜ в”ҳГ в”ҳГҘ в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ .\r\n              </p>\r\n            </div>\r\n            <div>\r\n              <label\r\n                className=\"block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1\"\r\n                htmlFor=\"admin-add-user-password\"\r\n              >\r\n                в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’\r\n              </label>\r\n              <input\r\n                id=\"admin-add-user-password\"\r\n                required\r\n                type=\"password\"\r\n                className=\"w-full border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-slate-800 dark:text-white rounded-lg p-2.5 focus:ring-2 focus:ring-indigo-500 outline-none\"\r\n                value={newUser.в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’}\r\n                onChange={(e) => setNewUser({ ...newUser, в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’: e.target.value })}\r\n              />\r\n            </div>\r\n            <div>\r\n              <label\r\n                className=\"block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1\"\r\n                htmlFor=\"admin-add-user-role\"\r\n              >\r\n                в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘвҢҗ / в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’\r\n              </label>\r\n              <div className=\"relative\">\r\n                <select\r\n                  id=\"admin-add-user-role\"\r\n                  className=\"w-full bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 text-slate-800 dark:text-white rounded-lg p-2.5 pl-10 focus:ring-2 focus:ring-indigo-500 outline-none appearance-none cursor-pointer\"\r\n                  value={newUser.в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’}\r\n                  onChange={(e) => setNewUser({ ...newUser, в•ӘВәв”ҳГӨв•ӘВ»в”ҳГӘв•Әв–’: e.target.value as RoleType })}\r\n                >\r\n                  <option value=\"Employee\">в”ҳГ в”ҳГӘв•Әв••в”ҳГј (в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬ в”ҳГ в•ӘВЎв•ӘВ»в”ҳГӘв•ӘВ»в•ӘвҢҗ)</option>\r\n                  <option value=\"Admin\">в”ҳГ в•ӘВ»в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ  (в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬ в”ҳГўв•ӘВәв”ҳГ в”ҳГӨв•ӘвҢҗ)</option>\r\n                </select>\r\n                <div className=\"absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-500 dark:text-slate-400\">\r\n                  <ChevronDown size={16} />\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            {/* Link to Person (Separation Feature) */}\r\n            <div>\r\n              <label className=\"block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1\">\r\n                в•Әв–’в•ӘВҝв•Әв•– в•ӘВҝв”ҳГ в”ҳГӨв”ҳГј в•Әв”Өв•ӘВ«в•Әв•Ў (в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’в”ҳГЁ)\r\n              </label>\r\n              {isDesktopFast ? (\r\n                <div className=\"space-y-2\">\r\n                  <PersonPicker\r\n                    value={String(newUser.linkedPersonId || '')}\r\n                    onChange={(personId) =>\r\n                      setNewUser({ ...newUser, linkedPersonId: String(personId || '') })\r\n                    }\r\n                    placeholder=\"-- в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв–’в•ӘВ¬в•ӘВҝв•Әв•– --\"\r\n                  />\r\n                  <div className=\"flex justify-end\">\r\n                    <button\r\n                      type=\"button\"\r\n                      onClick={() => setNewUser({ ...newUser, linkedPersonId: '' })}\r\n                      className=\"text-[11px] font-bold text-slate-500 hover:text-slate-700 dark:text-slate-300 dark:hover:text-white\"\r\n                    >\r\n                      в•ӘГ‘в•Әв–“в•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв–’в•ӘВҝв•Әв•–\r\n                    </button>\r\n                  </div>\r\n                </div>\r\n              ) : (\r\n                <div className=\"relative\">\r\n                  <select\r\n                    className=\"w-full bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 text-slate-800 dark:text-white rounded-lg p-2.5 pl-10 focus:ring-2 focus:ring-indigo-500 outline-none appearance-none cursor-pointer\"\r\n                    aria-label=\"в•Әв–’в•ӘВҝв•Әв•– в•ӘВҝв”ҳГ в”ҳГӨв”ҳГј в•Әв”Өв•ӘВ«в•Әв•Ў\"\r\n                    title=\"в•Әв–’в•ӘВҝв•Әв•– в•ӘВҝв”ҳГ в”ҳГӨв”ҳГј в•Әв”Өв•ӘВ«в•Әв•Ў\"\r\n                    value={newUser.linkedPersonId}\r\n                    onChange={(e) => setNewUser({ ...newUser, linkedPersonId: e.target.value })}\r\n                  >\r\n                    <option value=\"\">-- в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв–’в•ӘВ¬в•ӘВҝв•Әв•– --</option>\r\n                    {people.map((p) => (\r\n                      <option key={p.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв”Өв•ӘВ«в•Әв•Ў} value={p.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв”Өв•ӘВ«в•Әв•Ў}>\r\n                        {p.в•ӘВәв”ҳГӨв•ӘВәв•Әв”Ӯв”ҳГ } ({p.в•Әв–’в”ҳГ©в”ҳГ _в”ҳГҘв”ҳГӘв•Әв•Ј_в•ӘВәв”ҳГӨв•Әв”Өв•ӘВ«в•Әв•Ў})\r\n                      </option>\r\n                    ))}\r\n                  </select>\r\n                  <div className=\"absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-500 dark:text-slate-400\">\r\n                    <span style={{ fontSize: 16 }}>вүЎЖ’Г¶Г№</span>\r\n                  </div>\r\n                </div>\r\n              )}\r\n              <p className=\"text-[10px] text-slate-500 dark:text-slate-400 mt-1\">\r\n                в”ҳГЁв”ҳГ…в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в”ҳГӨв•Әв–’в•ӘВҝв•Әв•– в•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ в•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ в•ӘВҝв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј в•ӘГәв”ҳГӘ в•ӘВәв”ҳГӨв•Әв”Өв•ӘВ«в•Әв•Ў в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ .\r\n              </p>\r\n            </div>\r\n          </form>\r\n        </AppModal>\r\n\r\n        {/* EDIT USER MODAL */}\r\n        <AppModal\r\n          open={!!editingUser}\r\n          title={\r\n            editingUser ? (\r\n              <>\r\n                <Settings size={20} className=\"text-indigo-600\" /> в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬:{' '}\r\n                {editingUser.в•ӘВәв•Әв”Ӯв”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ }\r\n              </>\r\n            ) : (\r\n              'в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬'\r\n            )\r\n          }\r\n          onClose={() => setEditingUser(null)}\r\n          size=\"2xl\"\r\n          footer={\r\n            editingUser ? (\r\n              <div className=\"flex justify-end gap-3\">\r\n                <button\r\n                  onClick={() => setEditingUser(null)}\r\n                  className=\"px-5 py-2.5 rounded-xl text-gray-500 hover:bg-gray-200 font-bold transition\"\r\n                >\r\n                  в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ\r\n                </button>\r\n                <button\r\n                  onClick={handleSaveUser}\r\n                  className=\"px-6 py-2.5 rounded-xl bg-indigo-600 text-white hover:bg-indigo-700 font-bold shadow-lg shadow-indigo-600/20 transition\"\r\n                >\r\n                  в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв•ӘВ¬в•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’в•ӘВәв•ӘВ¬\r\n                </button>\r\n              </div>\r\n            ) : null\r\n          }\r\n          bodyClassName=\"p-0\"\r\n        >\r\n          {editingUser ? (\r\n            <div className=\"p-6 space-y-6\">\r\n              {/* Employee Commissions Summary */}\r\n              <div className=\"app-card p-5 rounded-2xl border border-gray-100 dark:border-slate-700\">\r\n                <div className=\"flex items-center justify-between gap-3\">\r\n                  <div className=\"min-w-0\">\r\n                    <div className=\"text-sm font-black text-slate-800 dark:text-white truncate\">\r\n                      в”ҳГ в”ҳГӨв•ӘВ«в•Әв•Ў в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј\r\n                    </div>\r\n                    <div className=\"text-[11px] text-slate-500 dark:text-slate-400 truncate\">\r\n                      в•Әв”Өв•ӘВәв”ҳГ в”ҳГӨ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГӘв•Әв”Ӯв”ҳГЁв•Әв•– в•ӘВәв”ҳГӨв•ӘВ«в•ӘВәв•Әв–’в•ӘВјв”ҳГЁ\r\n                    </div>\r\n                  </div>\r\n                  <div className=\"flex items-center gap-2 flex-shrink-0\">\r\n                    <div className=\"flex items-center gap-2\">\r\n                      <label\r\n                        className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\"\r\n                        htmlFor=\"admin-employee-commission-month\"\r\n                      >\r\n                        в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’\r\n                      </label>\r\n                      <input\r\n                        id=\"admin-employee-commission-month\"\r\n                        type=\"date\"\r\n                        aria-label=\"в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’\"\r\n                        title=\"в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’ (в•ӘВәв•ӘВ«в•ӘВ¬в•Әв–’ в•ӘГәв”ҳГЁ в”ҳГЁв”ҳГӘв”ҳГ  в•Әв•ўв”ҳГ в”ҳГҘ в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’)\"\r\n                        value={employeeCommissionMonthKey ? `${employeeCommissionMonthKey}-01` : ''}\r\n                        onChange={(e) =>\r\n                          setEmployeeCommissionMonthKey(\r\n                            e.target.value ? e.target.value.slice(0, 7) : ''\r\n                          )\r\n                        }\r\n                        className=\"px-2 py-1 rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-800 dark:text-white text-xs\"\r\n                      />\r\n                    </div>\r\n                    <StatusBadge status=\"в”ҳГҘв•Әв”Өв•Әв•–\" />\r\n                  </div>\r\n                </div>\r\n\r\n                {employeeCommissionSummary?.loading ? (\r\n                  <div className=\"mt-4 text-sm text-slate-500 dark:text-slate-400\">\r\n                    в•ӘВјв•ӘВәв•Әв–’в”ҳГ¬ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨО“ГҮВӘ\r\n                  </div>\r\n                ) : employeeCommissionSummary?.error ? (\r\n                  <div className=\"mt-4 text-sm text-red-600\">{employeeCommissionSummary.error}</div>\r\n                ) : (\r\n                  <div className=\"mt-4 space-y-3\">\r\n                    <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-2\">\r\n                      <div className=\"p-3 rounded-xl bg-gray-50 dark:bg-slate-900/30 border border-gray-100 dark:border-slate-700\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•ӘВ»в•ӘВ» ({employeeCommissionSummary?.monthKey})\r\n                        </div>\r\n                        <div className=\"text-sm font-bold text-slate-800 dark:text-white\">\r\n                          в•Әв•Јв•ӘВ»в•ӘВ» в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬: {employeeCommissionSummary?.countThisMonth ?? 0}\r\n                        </div>\r\n                      </div>\r\n                      <div className=\"p-3 rounded-xl bg-emerald-50/60 dark:bg-emerald-900/10 border border-emerald-100 dark:border-emerald-900/30\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј\r\n                        </div>\r\n                        <div className=\"text-lg font-black text-emerald-700 dark:text-emerald-300\">\r\n                          {formatCurrencyJOD(\r\n                            employeeCommissionSummary?.totalEmployeeThisMonth ?? 0,\r\n                            { minimumFractionDigits: 0, maximumFractionDigits: 0 }\r\n                          )}\r\n                        </div>\r\n                      </div>\r\n                      <div className=\"p-3 rounded-xl bg-indigo-50/60 dark:bg-indigo-900/10 border border-indigo-100 dark:border-indigo-900/30\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘВәв•ӘВ¬ (в•ӘВәв”ҳГӨв•ӘГәв•Әв”Ӯв•ӘВәв•Әв”Ӯ)\r\n                        </div>\r\n                        <div className=\"text-lg font-black text-indigo-700 dark:text-indigo-300\">\r\n                          {formatCurrencyJOD(employeeCommissionSummary?.totalOfficeThisMonth ?? 0, {\r\n                            minimumFractionDigits: 0,\r\n                            maximumFractionDigits: 0,\r\n                          })}\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n\r\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\r\n                      <div className=\"p-3 rounded-xl bg-white dark:bg-slate-900/20 border border-gray-100 dark:border-slate-700\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в•ӘВ¬в”ҳГјв•Әв•Ўв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’: в•ӘГ‘в”ҳГЁв•ӘВјв•ӘВәв•Әв–’\r\n                        </div>\r\n                        <div className=\"flex items-center justify-between gap-3 mt-1\">\r\n                          <div className=\"text-xs text-slate-600 dark:text-slate-300\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•ӘВҝ</div>\r\n                          <div className=\"text-sm font-bold text-slate-800 dark:text-white\">\r\n                            {formatCurrencyJOD(\r\n                              employeeCommissionSummary?.rentOfficeThisMonth ?? 0,\r\n                              { minimumFractionDigits: 0, maximumFractionDigits: 0 }\r\n                            )}\r\n                          </div>\r\n                        </div>\r\n                        <div className=\"flex items-center justify-between gap-3\">\r\n                          <div className=\"text-xs text-slate-600 dark:text-slate-300\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј</div>\r\n                          <div className=\"text-sm font-bold text-emerald-700 dark:text-emerald-300\">\r\n                            {formatCurrencyJOD(\r\n                              employeeCommissionSummary?.rentEmployeeThisMonth ?? 0,\r\n                              { minimumFractionDigits: 0, maximumFractionDigits: 0 }\r\n                            )}\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div className=\"p-3 rounded-xl bg-white dark:bg-slate-900/20 border border-gray-100 dark:border-slate-700\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в•ӘВ¬в”ҳГјв•Әв•Ўв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’: в•ӘВҝв”ҳГЁв•Әв•Ј\r\n                        </div>\r\n                        <div className=\"flex items-center justify-between gap-3 mt-1\">\r\n                          <div className=\"text-xs text-slate-600 dark:text-slate-300\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•ӘВҝ</div>\r\n                          <div className=\"text-sm font-bold text-slate-800 dark:text-white\">\r\n                            {formatCurrencyJOD(\r\n                              employeeCommissionSummary?.saleOfficeThisMonth ?? 0,\r\n                              { minimumFractionDigits: 0, maximumFractionDigits: 0 }\r\n                            )}\r\n                          </div>\r\n                        </div>\r\n                        <div className=\"flex items-center justify-between gap-3\">\r\n                          <div className=\"text-xs text-slate-600 dark:text-slate-300\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј</div>\r\n                          <div className=\"text-sm font-bold text-emerald-700 dark:text-emerald-300\">\r\n                            {formatCurrencyJOD(\r\n                              employeeCommissionSummary?.saleEmployeeThisMonth ?? 0,\r\n                              { minimumFractionDigits: 0, maximumFractionDigits: 0 }\r\n                            )}\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n\r\n                    <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-2\">\r\n                      <div className=\"p-3 rounded-xl bg-white dark:bg-slate-900/20 border border-gray-100 dark:border-slate-700\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘВәв•ӘВ¬ (в”ҳГўв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв•ӘВ¬в•Әв–’в•ӘвҢҗ)\r\n                        </div>\r\n                        <div className=\"text-sm font-bold text-slate-800 dark:text-white\">\r\n                          {employeeCommissionSummary?.countAll ?? 0}\r\n                        </div>\r\n                      </div>\r\n                      <div className=\"p-3 rounded-xl bg-amber-50/60 dark:bg-amber-900/10 border border-amber-100 dark:border-amber-900/30\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј (в”ҳГўв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв•ӘВ¬в•Әв–’в•ӘвҢҗ)\r\n                        </div>\r\n                        <div className=\"text-lg font-black text-amber-700 dark:text-amber-300\">\r\n                          {formatCurrencyJOD(employeeCommissionSummary?.totalEmployeeAll ?? 0, {\r\n                            minimumFractionDigits: 0,\r\n                            maximumFractionDigits: 0,\r\n                          })}\r\n                        </div>\r\n                      </div>\r\n                      <div className=\"p-3 rounded-xl bg-purple-50/60 dark:bg-purple-900/10 border border-purple-100 dark:border-purple-900/30\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’ (5%)\r\n                        </div>\r\n                        <div className=\"text-lg font-black text-purple-700 dark:text-purple-300\">\r\n                          {formatCurrencyJOD(employeeCommissionSummary?.totalIntroAll ?? 0, {\r\n                            minimumFractionDigits: 0,\r\n                            maximumFractionDigits: 0,\r\n                          })}\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n\r\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\r\n                      <div className=\"p-3 rounded-xl bg-gray-50/60 dark:bg-slate-900/30 border border-gray-100 dark:border-slate-700\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в”ҳГўв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв•ӘВ¬в•Әв–’в•ӘвҢҗ: в•ӘГ‘в”ҳГЁв•ӘВјв•ӘВәв•Әв–’\r\n                        </div>\r\n                        <div className=\"flex items-center justify-between gap-3 mt-1\">\r\n                          <div className=\"text-xs text-slate-600 dark:text-slate-300\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•ӘВҝ</div>\r\n                          <div className=\"text-sm font-bold text-slate-800 dark:text-white\">\r\n                            {formatCurrencyJOD(employeeCommissionSummary?.rentOfficeAll ?? 0, {\r\n                              minimumFractionDigits: 0,\r\n                              maximumFractionDigits: 0,\r\n                            })}\r\n                          </div>\r\n                        </div>\r\n                        <div className=\"flex items-center justify-between gap-3\">\r\n                          <div className=\"text-xs text-slate-600 dark:text-slate-300\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј</div>\r\n                          <div className=\"text-sm font-bold text-emerald-700 dark:text-emerald-300\">\r\n                            {formatCurrencyJOD(employeeCommissionSummary?.rentEmployeeAll ?? 0, {\r\n                              minimumFractionDigits: 0,\r\n                              maximumFractionDigits: 0,\r\n                            })}\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div className=\"p-3 rounded-xl bg-gray-50/60 dark:bg-slate-900/30 border border-gray-100 dark:border-slate-700\">\r\n                        <div className=\"text-[11px] font-bold text-slate-500 dark:text-slate-400\">\r\n                          в”ҳГўв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв•ӘВ¬в•Әв–’в•ӘвҢҗ: в•ӘВҝв”ҳГЁв•Әв•Ј\r\n                        </div>\r\n                        <div className=\"flex items-center justify-between gap-3 mt-1\">\r\n                          <div className=\"text-xs text-slate-600 dark:text-slate-300\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•ӘВҝ</div>\r\n                          <div className=\"text-sm font-bold text-slate-800 dark:text-white\">\r\n                            {formatCurrencyJOD(employeeCommissionSummary?.saleOfficeAll ?? 0, {\r\n                              minimumFractionDigits: 0,\r\n                              maximumFractionDigits: 0,\r\n                            })}\r\n                          </div>\r\n                        </div>\r\n                        <div className=\"flex items-center justify-between gap-3\">\r\n                          <div className=\"text-xs text-slate-600 dark:text-slate-300\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј</div>\r\n        