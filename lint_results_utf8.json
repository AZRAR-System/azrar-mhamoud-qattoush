в”Өв•Әв–’в•ӘВәв•ӘГӯ_tbl } from '@/types';\nimport { formatCurrencyJOD } from '@/utils/format';\n\nconst t = (s: string) => s;\n\ninterface AgreementModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  onSubmit: (agreement: Partial<в•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘВәв•ӘВ¬_в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј_tbl>) => void;\n  listings: в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў_в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј_tbl[];\n  offers: в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў_в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ_tbl[];\n  getPropertyLabel: (id: string) => string;\n  getPersonName: (id: string) => string;\n  employees: Array<{ id: string; label: string }>;\n  initialData?: в•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘВәв•ӘВ¬_в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј_tbl | null;\n}\n\nexport const AgreementModal: React.FC<AgreementModalProps> = ({ \n  isOpen, \n  onClose, \n  onSubmit,\n  listings,\n  offers,\n  getPropertyLabel,\n  getPersonName,\n  employees,\n  initialData\n}) => {\n  const [step, setStep] = useState(1);\n  const [formData, setFormData] = useState<Partial<в•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘВәв•ӘВ¬_в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј_tbl>>({\n    listingId: '',\n    в•Әв•Јв•Әв–’в•Әв•ў_в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ_в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ : '',\n    в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ: '',\n    в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: '',\n    в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј: '',\n    в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«_в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘвҢҗ: new Date().toISOString().split('T')[0],\n    в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ: 0,\n    в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј: 0,\n    в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ: 0,\n    в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ: 0,\n    в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ_в•ӘВәв”ҳГӨв”ҳГ в•Әв•Ўв•ӘВәв•Әв–’в”ҳГЁв”ҳГј: 0,\n    isCompleted: false,\n    transferDate: '',\n    в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬: '',\n    в”ҳГ в”ҳГӘв•Әв••в”ҳГј_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: '',\n    в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: 0\n  });\n\n  const [commPercentages, setCommPercentages] = useState({\n    seller: 0,\n    buyer: 0\n  });\n\n  // Load initial data\n  useEffect(() => {\n    if (initialData && isOpen) {\n      setFormData({\n        ...initialData,\n        в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«_в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘвҢҗ: initialData.в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«_в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘвҢҗ || new Date().toISOString().split('T')[0],\n      });\n      const price = Number(initialData.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ) || 1;\n      setCommPercentages({\n        seller: (Number(initialData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј) / price) * 100,\n        buyer: (Number(initialData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ) / price) * 100\n      });\n    } else if (!initialData && isOpen) {\n       // Reset for new creation\n       setFormData({\n        listingId: '',\n        в•Әв•Јв•Әв–’в•Әв•ў_в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ_в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ : '',\n        в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ: '',\n        в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: '',\n        в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј: '',\n        в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«_в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘвҢҗ: new Date().toISOString().split('T')[0],\n        в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ: 0,\n        в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј: 0,\n        в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ: 0,\n        в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ: 0,\n        в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ_в•ӘВәв”ҳГӨв”ҳГ в•Әв•Ўв•ӘВәв•Әв–’в”ҳГЁв”ҳГј: 0,\n        isCompleted: false,\n        transferDate: '',\n        в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬: '',\n        в”ҳГ в”ҳГӘв•Әв••в”ҳГј_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: '',\n        в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: 0\n      });\n      setCommPercentages({ seller: 0, buyer: 0 });\n    }\n  }, [initialData, isOpen]);\n\n  // Handle Percentage Changes\n  const handlePctChange = (type: 'seller' | 'buyer', pct: string) => {\n    const p = parseFloat(pct) || 0;\n    const price = Number(formData.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ) || 0;\n    const amount = (price * p) / 100;\n    \n    setCommPercentages(prev => ({ ...prev, [type]: p }));\n    setFormData(prev => ({ \n      ...prev, \n      [type === 'seller' ? 'в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј' : 'в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ']: amount \n    }));\n  };\n\n  // Handle Amount Changes (manually)\n  const handleAmountChange = (type: 'seller' | 'buyer', amt: string) => {\n    const a = parseFloat(amt) || 0;\n    const price = Number(formData.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ) || 1;\n    const p = (a / price) * 100;\n    \n    setCommPercentages(prev => ({ ...prev, [type]: p }));\n    setFormData(prev => ({ \n      ...prev, \n      [type === 'seller' ? 'в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј' : 'в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ']: a \n    }));\n  };\n\n  // Auto-calculate total and intake commission\n  useEffect(() => {\n    const seller = Number(formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј) || 0;\n    const buyer = Number(formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ) || 0;\n    const total = seller + buyer;\n    const intake = total * 0.05; // 5% Rule\n\n    if (formData.в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ !== total || formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’ !== intake) {\n      setFormData(prev => ({ \n        ...prev, \n        в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ: total,\n        в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: intake\n      }));\n    }\n  }, [formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј, formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ]);\n\n  const steps = [\n    { id: 1, label: t('в•Әв–’в•ӘВҝв•Әв•– в•ӘВәв”ҳГӨв•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў'), icon: Check },\n    { id: 2, label: t('в•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ© в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’ в”ҳГӘв•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ'), icon: Coins },\n    { id: 3, label: t('в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ« в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ©в”ҳГӨ'), icon: Check },\n    { id: 4, label: t('в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в”ҳГӘв•ӘВәв”ҳГӨв•ӘВЎв”ҳГјв•Әв••'), icon: FileSignature }\n  ];\n\n  const activeListings = useMemo(() => listings.filter(l => l.в•ӘВәв”ҳГӨв•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ === 'Active' || l.id === formData.listingId), [listings, formData.listingId]);\n  const availableOffers = useMemo(() => {\n    if (!formData.listingId) return [];\n    return offers.filter(o => o.listingId === formData.listingId && (o.в•ӘВәв”ҳГӨв•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ === 'Pending' || o.id === formData.в•Әв•Јв•Әв–’в•Әв•ў_в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ_в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ ));\n  }, [offers, formData.listingId, formData.в•Әв•Јв•Әв–’в•Әв•ў_в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ_в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ ]);\n\n  const handleSubmit = () => {\n    onSubmit({\n      ...formData,\n      в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ: Number(formData.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ),\n      в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј: Number(formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј),\n      в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ: Number(formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ),\n      в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ: Number(formData.в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ),\n      в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ_в•ӘВәв”ҳГӨв”ҳГ в•Әв•Ўв•ӘВәв•Әв–’в”ҳГЁв”ҳГј: Number(formData.в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ_в•ӘВәв”ҳГӨв”ҳГ в•Әв•Ўв•ӘВәв•Әв–’в”ҳГЁв”ҳГј),\n      в”ҳГ в”ҳГӘв•Әв••в”ҳГј_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: formData.в”ҳГ в”ҳГӘв•Әв••в”ҳГј_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’,\n      в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: Number(formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’)\n    });\n    onClose();\n    setStep(1);\n  };\n\n  const handleListingChange = (id: string) => {\n    const l = listings.find(item => item.id === id);\n    setFormData(prev => ({\n      ...prev,\n      listingId: id,\n      в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: l?.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’,\n      в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј: l?.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•ӘВәв”ҳГӨв”ҳГў,\n      в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ: l?.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ || 0,\n      в•Әв•Јв•Әв–’в•Әв•ў_в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ_в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ : '',\n      в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ: ''\n    }));\n  };\n\n  const handleOfferChange = (id: string) => {\n    const o = offers.find(item => item.id === id);\n    setFormData(prev => ({\n      ...prev,\n      в•Әв•Јв•Әв–’в•Әв•ў_в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ_в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ : id,\n      в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ: o?.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ || o?.в”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ_в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ  || '',\n      в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ: o?.в”ҳГ©в”ҳГЁв”ҳГ в•ӘвҢҗ_в•ӘВәв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў || o?.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў || prev.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ\n    }));\n  };\n\n  return (\n    <Modal isOpen={isOpen} onClose={onClose} title={initialData ? t('в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ в•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј') : t('в•ӘГ‘в”ҳГҘв•Әв”Өв•ӘВәв•ӘГӯ в•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘвҢҗ в•ӘВҝв”ҳГЁв•Әв•Ј в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»в•ӘвҢҗ')} icon={<FileSignature size={24} />} size=\"lg\">\n      <div className=\"p-2\">\n        <div className=\"flex items-center justify-between mb-8 bg-slate-50 dark:bg-slate-800 p-4 rounded-2xl\">\n          {steps.map((s, idx) => (\n            <React.Fragment key={s.id}>\n              <div className={`flex flex-col items-center gap-2 ${step >= s.id ? 'text-indigo-600' : 'text-gray-400'}`}>\n                <div className={`w-10 h-10 rounded-full flex items-center justify-center border-2 ${step > s.id ? 'bg-green-500 text-white border-green-500' : step === s.id ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-gray-100 text-gray-400 border-gray-200'}`}>\n                  {step > s.id ? <Check size={18} /> : <span>{idx + 1}</span>}\n                </div>\n                <span className=\"text-[10px] font-bold\">{s.label}</span>\n              </div>\n              {idx < steps.length - 1 && (\n                <div className={`flex-1 h-1 mx-2 rounded ${step > s.id ? 'bg-green-500' : 'bg-gray-200'}`} />\n              )}\n            </React.Fragment>\n          ))}\n        </div>\n\n        <div className=\"min-h-[350px] space-y-6\">\n          {step === 1 && (\n            <div className=\"space-y-6\">\n              <div>\n                <label className=\"text-sm font-black text-slate-700 dark:text-slate-300 mb-2 block\">\n                  {t('в•ӘВәв•ӘВ«в•ӘВ¬в•Әв–’ в•Әв•Јв•Әв–’в•Әв•ў в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј (в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’)')}\n                </label>\n                <select\n                  value={formData.listingId}\n                  onChange={(e) => handleListingChange(e.target.value)}\n                  className=\"w-full p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-950 text-slate-700 dark:text-slate-200 font-bold shadow-soft\"\n                  required\n                >\n                  <option value=\"\">{t('--- в•ӘВәв•ӘВ«в•ӘВ¬в•Әв–’ в•Әв•Јв•Әв–’в•Әв•ў в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј ---')}</option>\n                  {activeListings.map(l => (\n                    <option key={l.id} value={l.id}>\n                      {getPropertyLabel(l.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’)} - {formatCurrencyJOD(l.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ)}\n                    </option>\n                  ))}\n                </select>\n              </div>\n\n              {formData.listingId && (\n                <div>\n                  <label className=\"text-sm font-black text-slate-700 dark:text-slate-300 mb-2 block\">\n                    {t('в•ӘВәв•ӘВ«в•ӘВ¬в•Әв–’ в•Әв•Јв•Әв–’в•Әв•ў в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в•ӘВ¬в•ӘВҝв•Әв•–')}\n                  </label>\n                  {availableOffers.length > 0 ? (\n                    <select\n                      value={formData.в•Әв•Јв•Әв–’в•Әв•ў_в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ_в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ }\n                      onChange={(e) => handleOfferChange(e.target.value)}\n                      className=\"w-full p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-950 text-slate-700 dark:text-slate-200 font-bold shadow-soft\"\n                      required\n                    >\n                      <option value=\"\">{t('--- в•ӘВәв•ӘВ«в•ӘВ¬в•Әв–’ в•Әв•Јв•Әв–’в•Әв•ў в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ ---')}</option>\n                      {availableOffers.map(o => (\n                        <option key={o.id} value={o.id}>\n                          {getPersonName(o.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ || o.в”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ_в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ  || '')} - {formatCurrencyJOD(o.в”ҳГ©в”ҳГЁв”ҳГ в•ӘвҢҗ_в•ӘВәв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў || o.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў || 0)}\n                        </option>\n                      ))}\n                    </select>\n                  ) : (\n                    <div className=\"p-4 bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400 rounded-xl text-sm flex items-center gap-2 border border-amber-100 dark:border-amber-800\">\n                      <AlertCircle size={18} />\n                      {t('в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў в•Әв”Өв•Әв–’в•ӘВәв•ӘГӯ в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©в•ӘвҢҗ в”ҳГӨв”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’. в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘв”ҳГў в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Јв•ӘвҢҗ в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в•Әв–’в•ӘВҝв•Әв•– в•Әв•Јв•Әв–’в•Әв•ў в”ҳГ в•ӘВЎв•ӘВ»в•ӘВ».')}\n                    </div>\n                  )}\n                </div>\n              )}\n            </div>\n          )}\n\n          {step === 2 && (\n            <div className=\"space-y-8 animate-in fade-in slide-in-from-bottom-4\">\n              <div className=\"p-6 bg-indigo-50/50 dark:bg-indigo-900/10 rounded-2xl border border-indigo-100 dark:border-indigo-900/30\">\n                <label className=\"text-lg font-black text-indigo-900 dark:text-indigo-300 mb-4 flex items-center gap-2\">\n                  <BadgePercent size={24} />\n                  {t('в•Әв”Ӯв•Әв•Јв•Әв–’ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ© в”ҳГӘ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘВәв•ӘВ¬')}\n                </label>\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                  <div className=\"md:col-span-2\">\n                    <label className=\"text-sm font-black text-slate-600 dark:text-slate-400 mb-2 block\">{t('в•Әв”Ӯв•Әв•Јв•Әв–’ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ')}</label>\n                    <Input \n                      type=\"number\" \n                      value={formData.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ} \n                      onChange={(e) => setFormData({...formData, в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ: e.target.value})} \n                      className=\"text-xl font-black text-indigo-600 h-14\"\n                    />\n                  </div>\n                  \n                  <div className=\"p-4 bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800\">\n                    <label className=\"text-xs font-black text-slate-500 mb-2 block uppercase tracking-wider\">{t('в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•ӘВәв”ҳГӨв”ҳГў (в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј)')}</label>\n                    <div className=\"flex gap-2\">\n                       <Input \n                        type=\"number\" \n                        value={formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘВҝв•ӘВәв•ӘВӘв•Әв•Ј} \n                        onChange={(e) => handleAmountChange('seller', e.target.value)}\n                        placeholder=\"0.00\"\n                        className=\"flex-1\"\n                      />\n                      <div className=\"relative w-24\">\n                        <Input \n                          type=\"number\" \n                          value={commPercentages.seller.toFixed(1)} \n                          onChange={(e) => handlePctChange('seller', e.target.value)}\n                          className=\"pr-6 text-indigo-600 font-bold\"\n                        />\n                        <span className=\"absolute right-2 top-1/2 -translate-y-1/2 text-xs text-indigo-400\">%</span>\n                      </div>\n                    </div>\n                  </div>\n\n                  <div className=\"p-4 bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800\">\n                    <label className=\"text-xs font-black text-slate-500 mb-2 block uppercase tracking-wider\">{t('в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ')}</label>\n                    <div className=\"flex gap-2\">\n                      <Input \n                        type=\"number\" \n                        value={formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ} \n                        onChange={(e) => handleAmountChange('buyer', e.target.value)}\n                        placeholder=\"0.00\"\n                        className=\"flex-1\"\n                      />\n                      <div className=\"relative w-24\">\n                        <Input \n                          type=\"number\" \n                          value={commPercentages.buyer.toFixed(1)} \n                          onChange={(e) => handlePctChange('buyer', e.target.value)}\n                          className=\"pr-6 text-indigo-600 font-bold\"\n                        />\n                        <span className=\"absolute right-2 top-1/2 -translate-y-1/2 text-xs text-indigo-400\">%</span>\n                      </div>\n                    </div>\n                  </div>\n\n                  <div className=\"md:col-span-2 p-4 bg-emerald-50 dark:bg-emerald-900/10 rounded-xl border border-emerald-100 dark:border-emerald-800/30 flex justify-between items-center\">\n                    <span className=\"font-black text-emerald-800 dark:text-emerald-400\">{t('в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в”ҳГўв•ӘВ¬в•ӘВҝ :')}</span>\n                    <span className=\"text-2xl font-black text-emerald-600\">{formatCurrencyJOD(formData.в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ)}</span>\n                  </div>\n\n                  <div className=\"md:col-span-2\">\n                    <label className=\"text-sm font-black text-slate-600 dark:text-slate-400 mb-2 block\">{t('в”ҳГ в•Әв•Ўв•ӘВәв•Әв–’в”ҳГЁв”ҳГј/в•Әв–’в•Әв”Ӯв”ҳГӘв”ҳГ  в•ӘВ¬в”ҳГ©в•ӘВ»в”ҳГЁв•Әв–’в”ҳГЁв•ӘвҢҗ в•ӘГәв•ӘВ«в•Әв–’в”ҳГ«')}</label>\n                    <Input \n                      type=\"number\" \n                      value={formData.в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ_в•ӘВәв”ҳГӨв”ҳГ в•Әв•Ўв•ӘВәв•Әв–’в”ҳГЁв”ҳГј} \n                      onChange={(e) => setFormData({...formData, в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ_в•ӘВәв”ҳГӨв”ҳГ в•Әв•Ўв•ӘВәв•Әв–’в”ҳГЁв”ҳГј: e.target.value})}\n                      placeholder=\"0.00\"\n                    />\n                  </div>\n\n                  <div className=\"md:col-span-2 pt-4 border-t border-slate-100 dark:border-slate-800\">\n                    <label className=\"text-sm font-black text-slate-700 dark:text-slate-300 mb-4 block flex items-center gap-2\">\n                      <CheckCircle size={18} className=\"text-indigo-500\" />\n                      {t('в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’ (Listing Commission)')}\n                    </label>\n                    <div className=\"grid grid-cols-2 gap-4\">\n                      <div>\n                        <label className=\"text-xs font-bold text-slate-500 mb-1 block\">{t('в”ҳГ в”ҳГӘв•Әв••в”ҳГј в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ')}</label>\n                        <select\n                          value={formData.в”ҳГ в”ҳГӘв•Әв••в”ҳГј_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’}\n                          onChange={(e) => setFormData({...formData, в”ҳГ в”ҳГӘв•Әв••в”ҳГј_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: e.target.value})}\n                          className=\"w-full p-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-200 font-bold\"\n                        >\n                          <option value=\"\">{t('--- в•ӘВәв•ӘВ«в•ӘВ¬в•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв••в”ҳГј ---')}</option>\n                          {employees.map(emp => (\n                            <option key={emp.id} value={emp.id}>{emp.label}</option>\n                          ))}\n                        </select>\n                      </div>\n                      <div>\n                        <label className=\"text-xs font-bold text-slate-500 mb-1 block\">{t('в”ҳГ©в”ҳГЁв”ҳГ в•ӘвҢҗ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ')}</label>\n                        <Input \n                          type=\"number\" \n                          value={formData.в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’} \n                          onChange={(e) => setFormData({...formData, в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ_в•Әв•Јв”ҳГ©в•ӘВәв•Әв–’: e.target.value})}\n                          placeholder=\"0.00\"\n                        />\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          )}\n\n          {step === 3 && (\n            <div className=\"space-y-6\">\n              <div>\n                <label className=\"text-sm font-black text-slate-700 dark:text-slate-300 mb-2 block\">\n                  {t('в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ« в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГҘв•ӘВәв•Әв–“в”ҳГӨ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в”ҳГӘв”ҳГ©в•Әв•Ј')}\n                </label>\n                <Input\n                  type=\"date\"\n                  value={formData.transferDate}\n                  onChange={(e) => setFormData({ ...formData, transferDate: e.target.value })}\n                  required\n                />\n              </div>\n              <div>\n                <label className=\"text-sm font-black text-slate-700 dark:text-slate-300 mb-2 block\">\n                  {t('в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в”ҳГјв•ӘВәв”ҳГ©в”ҳГЁв•ӘвҢҗ')}\n                </label>\n                <textarea\n                  className=\"w-full p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-200 font-bold shadow-soft\"\n                  rows={4}\n                  value={formData.в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬}\n                  onChange={(e) => setFormData({ ...formData, в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬: e.target.value })}\n                  placeholder={t('в•Әв”Өв•Әв–’в”ҳГӘв•Әв•– в•ӘВ«в•ӘВәв•Әв•Ўв•ӘвҢҗв•ӘГ® в•ӘВ¬в”ҳГјв•ӘВәв•Әв•Ўв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Јв•ӘГ® в•ӘВәв”ҳГӨв•ӘВ«...')}\n                />\n              </div>\n            </div>\n          )}\n\n          {step === 4 && (\n            <div className=\"text-center py-4 space-y-6\">\n              <div className=\"bg-indigo-50 dark:bg-indigo-900/30 rounded-[2.5rem] p-8 max-w-md mx-auto border border-indigo-100 dark:border-indigo-800 shadow-2xl relative overflow-hidden\">\n                <div className=\"absolute top-0 right-0 p-4 opacity-10\">\n                   <Coins size={120} />\n                </div>\n                <FileSignature size={56} className=\"mx-auto text-indigo-600 mb-4\" />\n                <h3 className=\"text-2xl font-black text-slate-800 dark:text-slate-100 mb-2\">\n                  {t('в”ҳГ в•Әв–’в•ӘВәв•ӘВјв•Әв•Јв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬')}\n                </h3>\n                <div className=\"text-right space-y-4 mt-6 text-sm\">\n                  <div className=\"flex justify-between border-b border-slate-200 dark:border-slate-700 pb-2\">\n                    <span className=\"text-slate-500\">{t('в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’:')}</span>\n                    <span className=\"font-black\">{getPropertyLabel(formData.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ©в•ӘВәв•Әв–’ || '')}</span>\n                  </div>\n                  <div className=\"flex justify-between border-b border-slate-200 dark:border-slate-700 pb-2\">\n                    <span className=\"text-slate-500\">{t('в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ:')}</span>\n                    <span className=\"font-black\">{getPersonName(formData.в•Әв–’в”ҳГ©в”ҳГ _в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•ӘВ¬в•Әв–’в”ҳГЁ || '')}</span>\n                  </div>\n                  <div className=\"flex justify-between border-b border-slate-200 dark:border-slate-700 pb-2\">\n                    <span className=\"text-slate-500\">{t('в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’ в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ:')}</span>\n                    <span className=\"font-black text-indigo-600 text-lg\">{formatCurrencyJOD(formData.в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв•Әв–’_в•ӘВәв”ҳГӨв”ҳГҘв”ҳГ§в•ӘВәв•ӘВӘв”ҳГЁ || 0)}</span>\n                  </div>\n                  <div className=\"flex justify-between bg-emerald-50 dark:bg-emerald-900/20 p-3 rounded-lg\">\n                    <span className=\"text-emerald-700 dark:text-emerald-400 font-bold\">{t('в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘВәв•ӘВ¬:')}</span>\n                    <span className=\"font-black text-emerald-600\">{formatCurrencyJOD(formData.в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ_в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ || 0)}</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          )}\n        </div>\n\n        <div className=\"flex gap-4 pt-6 border-t border-slate-100 dark:border-slate-700 mt-6\">\n          {step > 1 && (\n            <Button type=\"button\" variant=\"outline\" className=\"px-8 rounded-xl font-black h-12\" onClick={() => setStep(step - 1)}>\n              {t('в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘВәв•ӘВҝв”ҳГ©')}\n            </Button>\n          )}\n          <div className=\"flex-1\" />\n          {step < steps.length ? (\n            <Button \n              type=\"button\" \n              onClick={() => setStep(step + 1)} \n              disabled={step === 1 &&