# Copy to .env.desktop or merge into your local env (see .gitignore).
# Desktop (Electron) mode — keep secrets out of version control.

# Optional: seed first admin when storage has no users (use a strong password locally)
# VITE_SEED_DEFAULT_ADMIN=true
# VITE_SEED_DEFAULT_ADMIN_USERNAME=admin
# VITE_SEED_DEFAULT_ADMIN_PASSWORD=choose_a_strong_password

VITE_USE_REAL_SERVER=false
VITE_API_BASE_URL=http://localhost:5000/api

# Multi-device / server-backed desktop (uncomment as needed):
# VITE_USE_REAL_SERVER=true
# VITE_ALLOW_SERVER_IN_DESKTOP=true
# VITE_API_BASE_URL=http://192.168.1.18:5000/api
# VITE_API_KEY=YOUR_KEY
